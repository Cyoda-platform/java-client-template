{"version":"1.0","name":"Cart Workflow","desc":"Workflow for Cart entity based on functional requirements: NEW -> ACTIVE on first add (reserve & recalc), ACTIVE -> CHECKING_OUT when user starts checkout (requires non-empty cart), CHECKING_OUT -> CONVERTED when order created from paid payment, CHECKING_OUT -> CHECKOUT_FAILED on payment failure. Reservations handled by processors; totals recalculated on add.","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"initial_to_new","next":"NEW","manual":false}]},"NEW":{"transitions":[{"name":"add_line_to_activate","next":"ACTIVE","manual":false,"processors":[{"name":"ReserveOnAddProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"ACTIVE":{"transitions":[{"name":"start_checkout","next":"CHECKING_OUT","manual":true,"criterion":{"type":"function","function":{"name":"CartNotEmptyCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"CHECKING_OUT":{"transitions":[{"name":"checkout_payment_failed","next":"CHECKOUT_FAILED","manual":false,"criterion":{"type":"function","function":{"name":"PaymentFailedCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"checkout_paid_create_order","next":"CONVERTED","manual":false,"processors":[{"name":"CreateOrderFromPaidProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"CHECKOUT_FAILED":{"transitions":[]},"CONVERTED":{"transitions":[]}}}