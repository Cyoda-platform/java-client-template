{
    "version": "1.0",
    "name": "Cart Workflow",
    "desc": "Manages shopping cart lifecycle from creation to conversion.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "CREATE_ON_FIRST_ADD",
                    "next": "ACTIVE",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CartRecalculateTotalsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "ACTIVE": {
            "transitions": [
                {
                    "name": "ADD_ITEM",
                    "next": "ACTIVE",
                    "manual": true,
                    "processors": [
                        {
                            "name": "CartRecalculateTotalsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "DECREMENT_ITEM",
                    "next": "ACTIVE",
                    "manual": true,
                    "processors": [
                        {
                            "name": "CartRecalculateTotalsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "REMOVE_ITEM",
                    "next": "ACTIVE",
                    "manual": true,
                    "processors": [
                        {
                            "name": "CartRecalculateTotalsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "OPEN_CHECKOUT",
                    "next": "CHECKING_OUT",
                    "manual": true
                }
            ]
        },
        "CHECKING_OUT": {
            "transitions": [
                {
                    "name": "CHECKOUT",
                    "next": "CONVERTED",
                    "manual": true
                }
            ]
        },
        "CONVERTED": {
            "transitions": []
        }
    }
}