{
  "version": "1.0",
  "name": "Order",
  "desc": "Order lifecycle workflow for OMS - manages order fulfillment from creation to delivery",
  "initialState": "initial",
  "active": true,
  "states": {
    "initial": {
      "transitions": [
        {
          "name": "CREATE_ORDER_FROM_PAID",
          "next": "waiting_to_fulfill",
          "manual": false,
          "processors": [
            {
              "name": "CreateOrderFromPaid",
              "executionMode": "ASYNC_NEW_TX",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 5000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "waiting_to_fulfill": {
      "transitions": [
        {
          "name": "START_PICKING",
          "next": "picking",
          "manual": true
        }
      ]
    },
    "picking": {
      "transitions": [
        {
          "name": "READY_TO_SEND",
          "next": "waiting_to_send",
          "manual": true
        }
      ]
    },
    "waiting_to_send": {
      "transitions": [
        {
          "name": "MARK_SENT",
          "next": "sent",
          "manual": true
        }
      ]
    },
    "sent": {
      "transitions": [
        {
          "name": "MARK_DELIVERED",
          "next": "delivered",
          "manual": true
        }
      ]
    },
    "delivered": {
      "transitions": []
    }
  }
}
