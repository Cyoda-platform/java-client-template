{
    "version": "1.0",
    "name": "Order Workflow",
    "desc": "Manages order fulfillment from creation to delivery",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "initialize_order",
                    "next": "WAITING_TO_FULFILL",
                    "manual": false
                }
            ]
        },
        "WAITING_TO_FULFILL": {
            "transitions": [
                {
                    "name": "create_order_from_paid",
                    "next": "PICKING",
                    "manual": false,
                    "processors": [
                        {
                            "name": "OrderCreateFromPaidProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "PICKING": {
            "transitions": [
                {
                    "name": "ready_to_send",
                    "next": "WAITING_TO_SEND",
                    "manual": true
                }
            ]
        },
        "WAITING_TO_SEND": {
            "transitions": [
                {
                    "name": "mark_sent",
                    "next": "SENT",
                    "manual": true
                }
            ]
        },
        "SENT": {
            "transitions": [
                {
                    "name": "mark_delivered",
                    "next": "DELIVERED",
                    "manual": true
                }
            ]
        },
        "DELIVERED": {
            "transitions": [
                {
                    "name": "end_process",
                    "next": "initial_state",
                    "manual": false
                }
            ]
        }
    }
}