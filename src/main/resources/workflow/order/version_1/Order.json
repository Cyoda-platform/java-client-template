{
  "version": "1.0",
  "name": "Order Workflow",
  "desc": "Workflow for Order entity: creation, validation, confirmation and fulfillment (shipped/cancelled).",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "initial_to_created",
          "next": "CREATED",
          "manual": false
        }
      ]
    },
    "CREATED": {
      "transitions": [
        {
          "name": "validate_order",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "ValidateOrderProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_passed",
          "next": "CONFIRMED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "OrderValidationCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "CONFIRMED": {
      "transitions": [
        {
          "name": "mark_shipped",
          "next": "SHIPPED",
          "manual": true,
          "processors": [
            {
              "name": "FulfillOrderProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "mark_cancelled",
          "next": "CANCELLED",
          "manual": true,
          "processors": [
            {
              "name": "FulfillOrderProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SHIPPED": {
      "transitions": []
    },
    "CANCELLED": {
      "transitions": []
    }
  }
}