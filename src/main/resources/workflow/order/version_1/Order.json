{
    "version": "1.0",
    "name": "Order Workflow",
    "desc": "Description of the workflow for Order",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "CREATE_ORDER_FROM_PAID",
                    "next": "WAITING_TO_FULFILL",
                    "manual": false,
                    "processors": [
                        {
                            "name": "OrderCreateFromPaidProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "PaymentIsPaidCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "WAITING_TO_FULFILL": {
            "transitions": [
                {
                    "name": "START_PICKING",
                    "next": "PICKING",
                    "manual": false
                }
            ]
        },
        "PICKING": {
            "transitions": [
                {
                    "name": "READY_TO_SEND",
                    "next": "WAITING_TO_SEND",
                    "manual": true
                }
            ]
        },
        "WAITING_TO_SEND": {
            "transitions": [
                {
                    "name": "MARK_SENT",
                    "next": "SENT",
                    "manual": true
                }
            ]
        },
        "SENT": {
            "transitions": [
                {
                    "name": "MARK_DELIVERED",
                    "next": "DELIVERED",
                    "manual": true
                }
            ]
        },
        "DELIVERED": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "final_state",
                    "manual": false
                }
            ]
        }
    }
}