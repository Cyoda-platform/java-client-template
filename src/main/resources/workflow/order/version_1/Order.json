{
  "version": "1.0",
  "name": "Order Workflow",
  "desc": "Workflow for Order lifecycle from placement to shipment",
  "initialState": "WAITING_TO_FULFILL",
  "active": true,
  "states": {
    "WAITING_TO_FULFILL": {
      "transitions": [
        {
          "name": "start_picking",
          "next": "PICKING",
          "manual": true,
          "processors": [
            {
              "name": "StartPickingProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PICKING": {
      "transitions": [
        {
          "name": "mark_sent",
          "next": "SENT",
          "manual": true,
          "processors": [
            {
              "name": "MarkSentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SENT": {
      "transitions": []
    }
  }
}