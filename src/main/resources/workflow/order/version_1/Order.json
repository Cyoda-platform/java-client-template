{
    "version": "1.0",
    "name": "Order Lifecycle Workflow",
    "desc": "Order fulfillment workflow with single shipment per order",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_waiting_to_fulfill",
                    "next": "WAITING_TO_FULFILL",
                    "manual": false,
                    "processors": [
                        {
                            "name": "OrderCreateProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "OrderCreateCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "WAITING_TO_FULFILL": {
            "transitions": [
                {
                    "name": "transition_to_picking",
                    "next": "PICKING",
                    "manual": true,
                    "processors": [
                        {
                            "name": "OrderStartPickingProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "PICKING": {
            "transitions": [
                {
                    "name": "transition_to_waiting_to_send",
                    "next": "WAITING_TO_SEND",
                    "manual": true,
                    "processors": [
                        {
                            "name": "OrderReadyToSendProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "WAITING_TO_SEND": {
            "transitions": [
                {
                    "name": "transition_to_sent",
                    "next": "SENT",
                    "manual": true,
                    "processors": [
                        {
                            "name": "OrderMarkSentProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "SENT": {
            "transitions": [
                {
                    "name": "transition_to_delivered",
                    "next": "DELIVERED",
                    "manual": true,
                    "processors": [
                        {
                            "name": "OrderMarkDeliveredProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "DELIVERED": {
            "transitions": [
                {
                    "name": "transition_to_final_state",
                    "next": "final_state",
                    "manual": false
                }
            ]
        },
        "final_state": {
            "transitions": []
        }
    }
}