{
  "version": "1.0",
  "name": "User Workflow",
  "desc": "Workflow for user validation, review, activation and blocking.",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "created_to_validating",
          "next": "validating",
          "manual": false,
          "processors": [
            {
              "name": "ValidateUserProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "valid_to_active",
          "next": "active",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "UserValidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "duplicate_to_needs_review",
          "next": "needs_review",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DuplicateFoundCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "needs_review": {
      "transitions": [
        {
          "name": "admin_approve",
          "next": "active",
          "manual": true,
          "processors": [
            {
              "name": "AdminApproveProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "admin_block",
          "next": "blocked",
          "manual": true,
          "processors": [
            {
              "name": "AdminBlockProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "active": {
      "transitions": [
        {
          "name": "admin_block_from_active",
          "next": "blocked",
          "manual": true,
          "processors": [
            {
              "name": "AdminBlockProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "blocked": {
      "transitions": []
    }
  }
}