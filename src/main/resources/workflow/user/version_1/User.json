{
  "version": "1.0",
  "name": "User Workflow",
  "desc": "Workflow for User entity: creation, validation, verification and activation",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "init_to_created",
          "next": "CREATED",
          "manual": false
        }
      ]
    },
    "CREATED": {
      "transitions": [
        {
          "name": "validate_user",
          "next": "VALIDATION",
          "manual": false,
          "processors": [
            {
              "name": "ValidateUserProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATION": {
      "transitions": [
        {
          "name": "send_verification",
          "next": "VERIFICATION",
          "manual": false,
          "processors": [
            {
              "name": "SendVerificationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VERIFICATION": {
      "transitions": [
        {
          "name": "email_verified_check",
          "next": "ACTIVE",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IsEmailVerifiedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ACTIVE": {
      "transitions": []
    }
  }
}