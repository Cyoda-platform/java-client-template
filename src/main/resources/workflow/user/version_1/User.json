{"version":"1.0","name":"User Workflow","desc":"Workflow for User entity derived from functional requirements: creation, validation, verification, activation, suspension, reinstatement review and archival. Designed as an acyclic FSM (no loops).","initialState":"none","active":true,"states":{"created":{"transitions":[{"name":"to_validation","next":"validation","manual":false,"processors":[{"name":"ValidateUserProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"validation":{"transitions":[{"name":"to_verification","next":"verification","manual":false,"processors":[{"name":"VerifyIdentityProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"verification":{"transitions":[{"name":"to_active_when_contact_verified","next":"active","manual":false,"criterion":{"type":"function","function":{"name":"UserContactVerifiedCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"to_suspended_when_sanctioned","next":"suspended","manual":false,"criterion":{"type":"function","function":{"name":"UserSanctionCheckCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"active":{"transitions":[{"name":"suspend_manual","next":"suspended","manual":true}]},"suspended":{"transitions":[{"name":"request_reinstate_manual","next":"reinstate_review","manual":true},{"name":"archive_manual","next":"archived","manual":true}]},"reinstate_review":{"transitions":[{"name":"approve_reinstate_manual","next":"active_reactivated","manual":true,"processors":[{"name":"VerifyIdentityProcessor","config":{"calculationNodesTags":"cyoda_application"}}]},{"name":"decline_reinstate_manual","next":"archived","manual":true}]},"active_reactivated":{"transitions":[{"name":"archive_after_reactivation_manual","next":"archived","manual":true}]},"archived":{"transitions":[]}}}