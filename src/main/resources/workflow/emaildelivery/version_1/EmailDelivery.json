{
    "version": "1.0",
    "name": "EmailDelivery Workflow",
    "desc": "Manages individual email delivery attempts and tracking.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_pending",
                    "next": "pending",
                    "manual": false
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "name": "transition_to_sent",
                    "next": "sent",
                    "manual": false,
                    "processors": [
                        {
                            "name": "EmailDeliveryCreationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_failed",
                    "next": "failed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "EmailDeliveryFailureProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "sent": {
            "transitions": [
                {
                    "name": "transition_to_delivered",
                    "next": "delivered",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "EmailDeliverySuccessCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "transition_to_bounced",
                    "next": "bounced",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "EmailDeliveryBounceCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "delivered": {
            "transitions": [
                {
                    "name": "transition_to_opened",
                    "next": "opened",
                    "manual": false,
                    "processors": [
                        {
                            "name": "EmailDeliveryOpenProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "opened": {
            "transitions": [
                {
                    "name": "transition_to_clicked",
                    "next": "clicked",
                    "manual": false,
                    "processors": [
                        {
                            "name": "EmailDeliveryClickProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "failed": {
            "transitions": [
                {
                    "name": "transition_to_terminal",
                    "next": "terminal",
                    "manual": false
                }
            ]
        },
        "bounced": {
            "transitions": [
                {
                    "name": "transition_to_terminal",
                    "next": "terminal",
                    "manual": false
                }
            ]
        },
        "terminal": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "end",
                    "manual": false
                }
            ]
        },
        "end": {
            "transitions": []
        }
    }
}