{
    "version": "1.0",
    "name": "Product Workflow",
    "desc": "Workflow for Product entity derived from functional requirements (inventory updates, lifecycle and discontinuation).",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "create_product",
                    "next": "NEW",
                    "manual": false
                }
            ]
        },
        "NEW": {
            "transitions": [
                {
                    "name": "publish_product",
                    "next": "ACTIVE",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PublishProductProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "discard_product",
                    "next": "DISCONTINUED",
                    "manual": true
                }
            ]
        },
        "ACTIVE": {
            "transitions": [
                {
                    "name": "deplete_to_out_of_stock",
                    "next": "OUT_OF_STOCK",
                    "manual": false,
                    "processors": [
                        {
                            "name": "DecrementStockProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "StockDepletedCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "decrement_to_low_stock",
                    "next": "LOW_STOCK",
                    "manual": false,
                    "processors": [
                        {
                            "name": "DecrementStockProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "StockLowCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "manual_discontinue",
                    "next": "DISCONTINUED",
                    "manual": true
                }
            ]
        },
        "LOW_STOCK": {
            "transitions": [
                {
                    "name": "low_to_out_of_stock",
                    "next": "OUT_OF_STOCK",
                    "manual": false,
                    "processors": [
                        {
                            "name": "DecrementStockProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "StockDepletedCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "manual_discontinue_from_low",
                    "next": "DISCONTINUED",
                    "manual": true
                }
            ]
        },
        "OUT_OF_STOCK": {
            "transitions": [
                {
                    "name": "manual_discontinue_from_out",
                    "next": "DISCONTINUED",
                    "manual": true
                }
            ]
        },
        "DISCONTINUED": {
            "transitions": []
        }
    }
}