{
    "version": "1.0",
    "name": "Product Workflow",
    "desc": "Description of the workflow for Product",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_NEW",
                    "next": "NEW",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ProductCreateProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "NEW": {
            "transitions": [
                {
                    "name": "transition_to_ACTIVE",
                    "next": "ACTIVE",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ProductActivateProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "ACTIVE": {
            "transitions": [
                {
                    "name": "transition_to_ACTIVE_add_item",
                    "next": "ACTIVE",
                    "manual": true,
                    "processors": [
                        {
                            "name": "ProductRecalculateTotalsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_ACTIVE_update_item",
                    "next": "ACTIVE",
                    "manual": true,
                    "processors": [
                        {
                            "name": "ProductRecalculateTotalsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_ACTIVE_remove_item",
                    "next": "ACTIVE",
                    "manual": true,
                    "processors": [
                        {
                            "name": "ProductRecalculateTotalsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_CHECKING_OUT",
                    "next": "CHECKING_OUT",
                    "manual": true
                }
            ]
        },
        "CHECKING_OUT": {
            "transitions": [
                {
                    "name": "transition_to_CONVERTED",
                    "next": "CONVERTED",
                    "manual": true
                }
            ]
        },
        "CONVERTED": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "end_state",
                    "manual": false
                }
            ]
        },
        "end_state": {
            "transitions": []
        }
    }
}