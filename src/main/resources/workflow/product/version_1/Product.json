{
    "version": "1.0",
    "name": "Product Workflow",
    "desc": "Workflow for Product entity from functional requirements (mermaid diagram translated)",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "initial_to_persisted",
                    "next": "PERSISTED",
                    "manual": false
                }
            ]
        },
        "PERSISTED": {
            "transitions": [
                {
                    "name": "persisted_to_enriching",
                    "next": "ENRICHING",
                    "manual": false,
                    "processors": [
                        {
                            "name": "EnrichProductProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "ENRICHING": {
            "transitions": [
                {
                    "name": "enriching_to_validating",
                    "next": "VALIDATING",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "EnrichmentCompleteCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "VALIDATING": {
            "transitions": [
                {
                    "name": "validating_to_ready",
                    "next": "READY",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ValidateProductProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        },
                        {
                            "name": "IndexProductProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "ProductValidCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "validating_to_invalid",
                    "next": "INVALID",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ValidateProductProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "simple",
                        "jsonPath": "$.validation.valid",
                        "operation": "EQUALS",
                        "value": false
                    }
                }
            ]
        },
        "READY": {
            "transitions": []
        },
        "INVALID": {
            "transitions": []
        }
    }
}