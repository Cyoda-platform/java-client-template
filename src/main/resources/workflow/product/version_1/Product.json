{
  "version": "1.0",
  "name": "Product Workflow",
  "desc": "Workflow for Product entity: created via API then validated and marked active for UI reads.",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "init_to_created",
          "next": "CREATED",
          "manual": false
        }
      ]
    },
    "CREATED": {
      "transitions": [
        {
          "name": "created_to_active",
          "next": "ACTIVE",
          "manual": false,
          "processors": [
            {
              "name": "ProductValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            },
            {
              "name": "ProductAvailableProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ACTIVE": {
      "transitions": []
    }
  }
}