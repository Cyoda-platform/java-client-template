{
  "version": "1.0",
  "name": "EmailDispatch Workflow",
  "desc": "Workflow for the EmailDispatch entity managing the sending of cat fact emails.",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "send_email",
          "next": "sending",
          "manual": false,
          "processors": [
            {
              "name": "SendEmailProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "sending": {
      "transitions": [
        {
          "name": "email_sent",
          "next": "sent",
          "manual": false
        },
        {
          "name": "send_failed",
          "next": "failed",
          "manual": false
        }
      ]
    },
    "sent": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}
