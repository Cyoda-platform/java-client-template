{
    "version": "1.0",
    "name": "AdoptionRequest Workflow",
    "desc": "Workflow for handling adoption requests",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_pending",
                    "next": "PENDING",
                    "manual": false
                }
            ]
        },
        "PENDING": {
            "transitions": [
                {
                    "name": "transition_to_validation",
                    "next": "VALIDATION",
                    "manual": false,
                    "processors": [
                        {
                            "name": "AdoptionRequestProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "VALIDATION": {
            "transitions": [
                {
                    "name": "transition_to_approved",
                    "next": "APPROVED",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "ValidateRequestCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "transition_to_rejected",
                    "next": "REJECTED",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "ValidateRequestCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "APPROVED": {
            "transitions": [
                {
                    "name": "transition_to_user_notified",
                    "next": "USER_NOTIFIED",
                    "manual": false,
                    "processors": [
                        {
                            "name": "NotifyUserProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "REJECTED": {
            "transitions": [
                {
                    "name": "transition_to_user_notified",
                    "next": "USER_NOTIFIED",
                    "manual": false,
                    "processors": [
                        {
                            "name": "NotifyUserProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "USER_NOTIFIED": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "final_state",
                    "manual": false
                }
            ]
        },
        "final_state": {
            "transitions": []
        }
    }
}