{
  "version": "1.0",
  "name": "ImportJob Workflow",
  "desc": "Workflow for ImportJob",
  "initialState": "PENDING",
  "active": true,
  "states": {
    "PENDING": {
      "transitions": [
        {
          "name": "start_import",
          "next": "IN_PROGRESS",
          "manual": true
        }
      ]
    },
    "IN_PROGRESS": {
      "transitions": [
        {
          "name": "fetch_data",
          "next": "PROCESSING",
          "manual": false,
          "processors": [
            {
              "name": "ImportFetchProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PROCESSING": {
      "transitions": [
        {
          "name": "complete_import",
          "next": "COMPLETED",
          "manual": false,
          "processors": [
            {
              "name": "ImportSummaryProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "fail_import",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.errorMessage",
            "operation": "NOT_EQUALS",
            "value": ""
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}