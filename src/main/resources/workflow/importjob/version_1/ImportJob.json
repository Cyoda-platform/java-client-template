{
  "version": "1.0",
  "name": "ImportJob Workflow",
  "desc": "Workflow to validate, enrich and persist Hacker News items for an import job",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "initial_to_validating",
          "next": "validating",
          "manual": false,
          "processors": [
            {
              "name": "ValidateHnItemProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "validation_success",
          "next": "processed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationIsValidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failure",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationIsInvalidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "processed": {
      "transitions": [
        {
          "name": "process_and_persist",
          "next": "completed",
          "manual": false,
          "processors": [
            {
              "name": "ProcessImportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}