{
  "version": "1.0",
  "name": "ImportJob Workflow",
  "desc": "Orchestration workflow for bulk import jobs (CSV/JSON).",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "created_to_validating",
          "next": "validating",
          "manual": false,
          "processors": [
            {
              "name": "ValidateImportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "valid_to_importing",
          "next": "importing",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ImportValidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "invalid_to_failed",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ImportInvalidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "importing": {
      "transitions": [
        {
          "name": "importing_to_completed",
          "next": "completed",
          "manual": false,
          "processors": [
            {
              "name": "ProcessImportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "importing_to_failed_on_errors",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ImportHasErrorsCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}