{"version":"1.0","name":"ImportJob Workflow","desc":"Workflow for ImportJob based on functional requirements: validate source, execute import (fetch/transform/upsert/notify), and finalize as COMPLETED or FAILED.","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"to_pending","next":"PENDING","manual":false}]},"PENDING":{"transitions":[{"name":"start_validation","next":"VALIDATING","manual":false,"processors":[{"name":"ValidateSourceProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"VALIDATING":{"transitions":[{"name":"validation_passed_to_running","next":"RUNNING","manual":false,"criterion":{"type":"function","function":{"name":"SourceReachableCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"validation_failed_to_failed","next":"FAILED","manual":false,"criterion":{"type":"function","function":{"name":"SourceUnreachableCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"RUNNING":{"transitions":[{"name":"execute_import","next":"EXECUTING","manual":false,"processors":[{"name":"ExecuteImportProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"EXECUTING":{"transitions":[{"name":"finalize_to_completed","next":"COMPLETED","manual":false,"criterion":{"type":"simple","jsonPath":"$.failedCount","operation":"EQUALS","value":0}},{"name":"finalize_to_failed","next":"FAILED","manual":false,"criterion":{"type":"simple","jsonPath":"$.failedCount","operation":"GREATER_THAN","value":0}}]},"COMPLETED":{"transitions":[]},"FAILED":{"transitions":[]}}}