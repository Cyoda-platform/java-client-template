{"version":"1.0","name":"ImportJob Workflow","desc":"Workflow for ImportJob based on functional requirements: validation -> enrichment -> persistence -> completion/failed -> notification","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"start_to_pending","next":"PENDING","manual":false}]},"PENDING":{"transitions":[{"name":"pending_to_validating","next":"VALIDATING","manual":false,"processors":[{"name":"ValidatePayloadProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"VALIDATING":{"transitions":[{"name":"validating_to_enriching_if_valid","next":"ENRICHING","manual":false,"criterion":{"type":"simple","jsonPath":"$.validation.isValid","operation":"EQUALS","value":true}},{"name":"validating_to_failed_if_invalid","next":"FAILED","manual":false,"criterion":{"type":"simple","jsonPath":"$.validation.isValid","operation":"EQUALS","value":false}}]},"ENRICHING":{"transitions":[{"name":"enriching_to_persisting","next":"PERSISTING","manual":false,"processors":[{"name":"AddImportTimestampProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"PERSISTING":{"transitions":[{"name":"persisting_execute_persist","next":"PERSISTED","manual":false,"processors":[{"name":"PersistHNItemProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"PERSISTED":{"transitions":[{"name":"persisted_to_completed_if_success","next":"COMPLETED","manual":false,"criterion":{"type":"simple","jsonPath":"$.persistResult.success","operation":"EQUALS","value":true}},{"name":"persisted_to_failed_if_failure","next":"FAILED","manual":false,"criterion":{"type":"simple","jsonPath":"$.persistResult.success","operation":"EQUALS","value":false}}]},"COMPLETED":{"transitions":[{"name":"completed_to_notifying","next":"NOTIFYING","manual":false,"processors":[{"name":"MarkJobCompletedProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"NOTIFYING":{"transitions":[{"name":"notifying_terminal","next":"NOTIFYING","ma