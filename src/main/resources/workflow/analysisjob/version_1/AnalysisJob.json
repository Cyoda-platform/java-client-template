{
  "version": "1.0",
  "name": "AnalysisJob Workflow",
  "desc": "Workflow for AnalysisJob orchestration entity",
  "initialState": "PENDING",
  "active": true,
  "states": {
    "PENDING": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "AnalysisValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_success",
          "next": "QUEUED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IsCsvAvailableCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationFailureProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "QUEUED": {
      "transitions": [
        {
          "name": "execute_analysis",
          "next": "RUNNING",
          "manual": false,
          "processors": [
            {
              "name": "AnalysisExecutorProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "RUNNING": {
      "transitions": [
        {
          "name": "report_ready_check",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "CheckReportReadyCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "report_failed_check",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FailureHandlerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "NOTIFICATION",
          "manual": false,
          "processors": [
            {
              "name": "NotificationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "NOTIFICATION": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}