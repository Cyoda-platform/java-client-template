{
    "version": "1.0",
    "name": "IngestionJob Workflow",
    "desc": "Workflow for IngestionJob derived from the functional requirements (PENDING -> VALIDATING -> FETCHING -> MAPPING -> COMPLETED/FAILED -> NOTIFY)",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "start_to_pending",
                    "next": "PENDING",
                    "manual": false
                }
            ]
        },
        "PENDING": {
            "transitions": [
                {
                    "name": "pending_to_validating",
                    "next": "VALIDATING",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ValidateJobProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "VALIDATING": {
            "transitions": [
                {
                    "name": "validating_to_fetching",
                    "next": "FETCHING",
                    "manual": false,
                    "processors": [
                        {
                            "name": "FetchPetstoreDataProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "FETCHING": {
            "transitions": [
                {
                    "name": "fetch_success_to_mapping",
                    "next": "MAPPING",
                    "manual": false,
                    "processors": [
                        {
                            "name": "MapAndPersistPetsProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "FetchSuccessCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "fetch_failed_to_failed",
                    "next": "FAILED",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "FetchFailedCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "MAPPING": {
            "transitions": [
                {
                    "name": "mapping_success_to_completed",
                    "next": "COMPLETED",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "MappingSuccessCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "mapping_failed_to_failed",
                    "next": "FAILED",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "MappingFailedCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "COMPLETED": {
            "transitions": [
                {
                    "name": "completed_to_notify",
                    "next": "NOTIFY",
                    "manual": false,
                    "processors": [
                        {
                            "name": "NotifyProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "FAILED": {
            "transitions": [
                {
                    "name": "failed_to_notify",
                    "next": "NOTIFY",
                    "manual": false,
                    "processors": [
                        {
                            "name": "NotifyProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "NOTIFY": {
            "transitions": []
        }
    }
}