{
  "version": "1.0",
  "name": "IngestionJob Workflow",
  "desc": "Workflow for ingestion job orchestration: validation, fetching, persisting activities, analysis trigger, completion and notification",
  "initialState": "PENDING",
  "active": true,
  "states": {
    "PENDING": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "ValidateJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_passed",
          "next": "FETCHING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationPassedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "fetch_activities",
          "next": "PERSISTING",
          "manual": false,
          "processors": [
            {
              "name": "FetchActivitiesProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PERSISTING": {
      "transitions": [
        {
          "name": "persist_activities",
          "next": "ANALYSIS_TRIGGERED",
          "manual": false,
          "processors": [
            {
              "name": "PersistActivitiesProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ANALYSIS_TRIGGERED": {
      "transitions": [
        {
          "name": "analysis_success",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "AnalysisSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "analysis_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "AnalysisFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": [
        {
          "name": "notify_if_needed",
          "next": "NOTIFIED",
          "manual": false,
          "processors": [
            {
              "name": "NotifyIfFailureOrReportReadyProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "notify_failure",
          "next": "NOTIFIED",
          "manual": false,
          "processors": [
            {
              "name": "NotifyIfFailureOrReportReadyProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED": {
      "transitions": []
    }
  }
}