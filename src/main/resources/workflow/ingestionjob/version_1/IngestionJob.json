{
  "version": "1.0",
  "name": "IngestionJob Workflow",
  "desc": "Workflow for IngestionJob orchestration entity",
  "initialState": "PENDING",
  "active": true,
  "states": {
    "PENDING": {
      "transitions": [
        {
          "name": "schedule_if_due",
          "next": "QUEUED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ScheduleDateCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "QUEUED": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "IN_PROGRESS",
          "manual": false,
          "processors": [
            {
              "name": "StartIngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "IN_PROGRESS": {
      "transitions": [
        {
          "name": "fetch_activities",
          "next": "FETCHING",
          "manual": false,
          "processors": [
            {
              "name": "FetchActivitiesProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "validate_fetch_results",
          "next": "VALIDATING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidateFetchCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "persist_activities",
          "next": "COMPLETED_STORE",
          "manual": false,
          "processors": [
            {
              "name": "PersistActivitiesProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "COMPLETED_STORE": {
      "transitions": [
        {
          "name": "mark_completed",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "mark_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": [
        {
          "name": "notify_admin",
          "next": "NOTIFIED",
          "manual": false,
          "processors": [
            {
              "name": "NotifyAdminProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}