{
  "version": "1.0",
  "name": "Location Workflow",
  "desc": "Workflow for Location entity: validate created locations, mark validated locations for activation, and handle invalid locations.",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "init_to_pending_validation",
          "next": "PENDING_VALIDATION",
          "manual": false
        }
      ]
    },
    "PENDING_VALIDATION": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "ValidateLocationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_passed",
          "next": "VALIDATED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationPassedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failed",
          "next": "INVALID",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "VALIDATED": {
      "transitions": [
        {
          "name": "manual_activate",
          "next": "ACTIVE",
          "manual": true,
          "processors": [
            {
              "name": "TagLocationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ACTIVE": {
      "transitions": []
    },
    "INVALID": {
      "transitions": []
    }
  }
}