{
  "version": "1.0",
  "name": "CatFact Workflow",
  "desc": "Workflow for CatFact entity: fetch -> validate -> ready/invalid -> archive",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "transition_to_pending",
          "next": "PENDING",
          "manual": false
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "name": "pending_to_validating",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "ValidateFactProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validating_to_ready",
          "next": "READY",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.validation_status",
            "operation": "EQUALS",
            "value": "VALID"
          }
        },
        {
          "name": "validating_to_invalid",
          "next": "INVALID",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.validation_status",
            "operation": "EQUALS",
            "value": "INVALID"
          }
        }
      ]
    },
    "READY": {
      "transitions": [
        {
          "name": "ready_to_archived",
          "next": "ARCHIVED",
          "manual": false,
          "processors": [
            {
              "name": "ArchiveFactProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INVALID": {
      "transitions": [
        {
          "name": "invalid_to_archived",
          "next": "ARCHIVED",
          "manual": false,
          "processors": [
            {
              "name": "ArchiveFactProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ARCHIVED": {
      "transitions": []
    }
  }
}