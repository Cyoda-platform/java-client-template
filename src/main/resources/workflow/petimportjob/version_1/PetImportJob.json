{
  "version": "1.0",
  "name": "PetImportJob Workflow",
  "desc": "Workflow for PetImportJob entity",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "start_fetch",
          "next": "FETCHING",
          "manual": false,
          "processors": [
            {
              "name": "FetchFromPetstoreProcessor",
              "config": { "calculationNodesTags": "cyoda_application" }
            }
          ]
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "fetch_success",
          "next": "TRANSFORMING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchSuccessCriterion",
              "config": { "calculationNodesTags": "cyoda_application" }
            }
          }
        },
        {
          "name": "fetch_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchFailedCriterion",
              "config": { "calculationNodesTags": "cyoda_application" }
            }
          }
        }
      ]
    },
    "TRANSFORMING": {
      "transitions": [
        {
          "name": "to_persisting",
          "next": "PERSISTING",
          "manual": false,
          "processors": [
            {
              "name": "TransformPetDataProcessor",
              "config": { "calculationNodesTags": "cyoda_application" }
            }
          ]
        }
      ]
    },
    "PERSISTING": {
      "transitions": [
        {
          "name": "persist_success",
          "next": "COMPLETED",
          "manual": false,
          "processors": [
            {
              "name": "PersistPetProcessor",
              "config": { "calculationNodesTags": "cyoda_application" }
            }
          ]
        },
        {
          "name": "persist_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PersistFailureCriterion",
              "config": { "calculationNodesTags": "cyoda_application" }
            }
          }
        }
      ]
    },
    "COMPLETED": { "transitions": [] },
    "FAILED": { "transitions": [] }
  }
}