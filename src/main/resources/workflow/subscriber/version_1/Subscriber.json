{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Registration, optional verification, activation and notification delivery for Subscriber entity",
  "initialState": "REGISTERED",
  "active": true,
  "states": {
    "REGISTERED": {
      "transitions": [
        {
          "name": "registered_to_pending",
          "next": "PENDING_VERIFICATION",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": { "name": "NeedsVerificationCriterion", "config": { "calculationNodesTags": "cyoda_application" } }
          }
        },
        {
          "name": "registered_to_active",
          "next": "ACTIVE",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": { "name": "NoVerificationRequiredCriterion", "config": { "calculationNodesTags": "cyoda_application" } }
          }
        }
      ]
    },
    "PENDING_VERIFICATION": {
      "transitions": [
        {
          "name": "pending_to_active",
          "next": "ACTIVE",
          "manual": false,
          "criterion": { "type": "function", "function": { "name": "SubscriberVerificationPassed", "config": { "calculationNodesTags": "cyoda_application" } } }
        }
      ]
    },
    "ACTIVE": { "transitions": [ { "name": "active_to_inactive", "next": "INACTIVE", "manual": true } ] },
    "INACTIVE": { "transitions": [ { "name": "inactive_to_active", "next": "ACTIVE", "manual": true } ] }
  }
}