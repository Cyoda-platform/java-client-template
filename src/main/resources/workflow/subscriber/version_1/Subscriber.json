{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Workflow for Subscriber entity creation and validation",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_contact_details",
          "next": "validated",
          "manual": false,
          "processors": [
            {
              "name": "ValidateSubscriberContactProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "persist_subscriber",
          "next": "persisted",
          "manual": false,
          "processors": [
            {
              "name": "PersistSubscriberProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "persisted": {
      "transitions": []
    }
  }
}
