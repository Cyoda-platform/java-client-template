{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Workflow for processing subscriber entities",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_contact",
          "next": "validated",
          "manual": false,
          "processors": [
            {
              "name": "ValidateSubscriberContactProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "persist",
          "next": "persisted",
          "manual": false
        }
      ]
    },
    "persisted": {
      "transitions": []
    }
  }
}
