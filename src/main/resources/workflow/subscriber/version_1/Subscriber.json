{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Workflow for Subscriber entity managing subscription creation and notification.",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "activate",
          "next": "active",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberActivationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "active": {
      "transitions": [
        {
          "name": "notify",
          "next": "notified",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberNotificationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "notified": {
      "transitions": []
    }
  }
}
