{"version":"1.0","name":"Subscriber Workflow","desc":"Workflow for Subscriber entity derived from functional requirements (registration, activation, suspension, resume and deletion). Adapted to avoid cyclic transitions while preserving processors and decision criteria.","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"initial_to_created","next":"CREATED","manual":false}]},"CREATED":{"transitions":[{"name":"activate_subscriber","next":"ACTIVE","manual":true,"processors":[{"name":"ActivationProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"ACTIVE":{"transitions":[{"name":"suspend_from_active","next":"SUSPENDED","manual":true,"criterion":{"type":"simple","jsonPath":"$.action","operation":"EQUALS","value":"suspend"},"processors":[{"name":"SuspendProcessor","config":{"calculationNodesTags":"cyoda_application"}}]},{"name":"delete_from_active","next":"DELETED","manual":true,"criterion":{"type":"simple","jsonPath":"$.action","operation":"EQUALS","value":"delete"},"processors":[{"name":"DeleteProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"SUSPENDED":{"transitions":[{"name":"resume_subscriber","next":"REACTIVATED","manual":true,"processors":[{"name":"ResumeProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"REACTIVATED":{"transitions":[{"name":"delete_after_reactivation","next":"DELETED","manual":true,"criterion":{"type":"simple","jsonPath":"$.action","operation":"EQUALS","value":"delete"},"processors":[{"name":"DeleteProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"DELETED":{"transitions":[]}}}