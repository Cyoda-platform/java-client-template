{
    "version": "1.0",
    "name": "BulkUpload Workflow",
    "desc": "Manages the bulk upload process for importing multiple HN items from JSON files.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_validated",
                    "next": "validated",
                    "manual": false
                }
            ]
        },
        "validated": {
            "transitions": [
                {
                    "name": "transition_to_processing",
                    "next": "processing",
                    "manual": false,
                    "processors": [
                        {
                            "name": "BulkUploadValidationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "name": "transition_to_completed",
                    "next": "completed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "BulkUploadCompletionProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_partially_completed",
                    "next": "partially_completed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "BulkUploadPartialCompletionProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_failed",
                    "next": "failed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "BulkUploadFailureProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "completed": {
            "transitions": []
        },
        "partially_completed": {
            "transitions": [
                {
                    "name": "transition_to_processing_retry_failed",
                    "next": "processing",
                    "manual": true,
                    "processors": [
                        {
                            "name": "BulkUploadRetryProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "failed": {
            "transitions": [
                {
                    "name": "transition_to_validated_retry",
                    "next": "validated",
                    "manual": true
                }
            ]
        }
    }
}