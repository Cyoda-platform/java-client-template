{"version":"1.0","name":"BatchJob Workflow","desc":"Finite-state workflow for BatchJob based on functional requirements (PENDING -> TRIGGERED -> FETCHING -> TRANSFORMING -> STORING -> REPORTING -> PUBLISHING -> COMPLETED/FAILED). Processors limited to StartJobProcessor and GenerateReportProcessor; intermediate transitions driven by criteria.","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"initialize_to_pending","next":"PENDING","manual":false}]},"PENDING":{"transitions":[{"name":"pending_to_triggered","next":"TRIGGERED","manual":false}]},"TRIGGERED":{"transitions":[{"name":"triggered_to_fetching","next":"FETCHING","manual":false,"processors":[{"name":"StartJobProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"FETCHING":{"transitions":[{"name":"fetching_to_transforming_on_fetch_complete","next":"TRANSFORMING","manual":false,"criterion":{"type":"function","function":{"name":"FetchCompleteCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"TRANSFORMING":{"transitions":[{"name":"transforming_to_storing_on_transform_complete","next":"STORING","manual":false,"criterion":{"type":"function","function":{"name":"TransformCompleteCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"STORING":{"transitions":[{"name":"storing_to_reporting_and_generate_report","next":"REPORTING","manual":false,"processors":[{"name":"GenerateReportProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"REPORTING":{"transitions":[{"name":"reporting_to_publishing_on_report_ready","next":"PUBLISHING","manual":false,"criterion":{"type":"function","function":{"name":"ReportReadyCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"PUBLISHING":{"transitions":[{"name":"publishing_to_completed_on_publish_success","next":"COMPLETED","manual":false,"criterion":{"type":"function","function":{"name":"PublishSuccessCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"publishing_to_failed_on_publish_failure","next":"FAILED","manual":false,"criterion":{"type":"function","function":{"name":"PublishFailureCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"COMPLETED":{"transitions":[]},"FAILED":{"transitions":[]}}}