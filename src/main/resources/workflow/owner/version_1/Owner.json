{"version":"1.0","name":"Owner Workflow","desc":"Workflow for Owner entity based on functional requirements (verification, suspension, archival). Linear, acyclic flow with explicit criteria and processors.","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"init_to_unverified","next":"UNVERIFIED","manual":false}]},"UNVERIFIED":{"transitions":[{"name":"start_verification","next":"PENDING_VERIFICATION","manual":false,"processors":[{"name":"VerifyOwnerProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"PENDING_VERIFICATION":{"transitions":[{"name":"verification_success","next":"VERIFIED","manual":false,"criterion":{"type":"function","function":{"name":"ContactValidCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"verification_failed_suspend","next":"SUSPENDED","manual":false,"criterion":{"type":"function","function":{"name":"ContactInvalidCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"VERIFIED":{"transitions":[{"name":"detect_violation_suspend","next":"SUSPENDED","manual":false,"criterion":{"type":"function","function":{"name":"ViolationDetectedCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"archive_owner_manual","next":"ARCHIVED","manual":true,"processors":[{"name":"ArchiveOwnerProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"SUSPENDED":{"transitions":[{"name":"manual_reinstate_request","next":"REINSTATED","manual":true}]},"REINSTATED":{"transitions":[{"name":"archive_after_reinstate","next":"ARCHIVED","manual":true}]},"ARCHIVED":{"transitions":[]}}}