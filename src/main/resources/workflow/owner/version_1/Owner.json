{
  "version": "1.0",
  "name": "Owner Workflow",
  "desc": "Workflow for Owner entity based on functional requirements",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "start_verification",
          "next": "VERIFICATION",
          "manual": false,
          "processors": [
            {
              "name": "OwnerVerificationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VERIFICATION": {
      "transitions": [
        {
          "name": "verification_ok",
          "next": "VERIFIED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "VerificationOkCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "verification_failed",
          "next": "SUSPENDED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "VerificationFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "VERIFIED": {
      "transitions": [
        {
          "name": "activate_owner",
          "next": "ACTIVE",
          "manual": false
        }
      ]
    },
    "ACTIVE": {
      "transitions": [
        {
          "name": "flag_owner",
          "next": "SUSPENDED_PENDING",
          "manual": true,
          "processors": [
            {
              "name": "FlagOwnerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "archive_owner",
          "next": "ARCHIVED",
          "manual": true,
          "processors": [
            {
              "name": "ArchiveOwnerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SUSPENDED_PENDING": {
      "transitions": [
        {
          "name": "reinstate_owner",
          "next": "ACTIVE_REINSTATED",
          "manual": true,
          "processors": [
            {
              "name": "ReinstateOwnerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ACTIVE_REINSTATED": {
      "transitions": [
        {
          "name": "finalize_active",
          "next": "ARCHIVED",
          "manual": true
        }
      ]
    },
    "SUSPENDED": {
      "transitions": [
        {
          "name": "manual_reinstate",
          "next": "ACTIVE_REINSTATED",
          "manual": true
        }
      ]
    },
    "ARCHIVED": {
      "transitions": []
    }
  }
}