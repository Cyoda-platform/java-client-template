{
  "version": "1.0",
  "name": "Pet Workflow",
  "desc": "Workflow for Pet entity (new -> validation -> enrichment -> available -> reserved -> adopted -> post_adoption -> archived). Minimal distinct processors reused across transitions to limit processor count.",
  "initialState": "none",
  "active": true,
  "states": {
    "NEW": {
      "transitions": [
        {
          "name": "to_validation",
          "next": "VALIDATION",
          "manual": false,
          "processors": [
            {
              "name": "PetValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATION": {
      "transitions": [
        {
          "name": "validation_to_enrichment_if_valid",
          "next": "ENRICHMENT",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PetValidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          },
          "processors": [
            {
              "name": "PetLifecycleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "validation_to_archived_if_invalid",
          "next": "ARCHIVED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PetValidationFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          },
          "processors": [
            {
              "name": "PetLifecycleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ENRICHMENT": {
      "transitions": [
        {
          "name": "enrichment_to_available_if_success",
          "next": "AVAILABLE",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PetEnrichmentSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "enrichment_to_archived_if_failed",
          "next": "ARCHIVED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PetEnrichmentFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "AVAILABLE": {
      "transitions": [
        {
          "name": "available_to_reserved_manual_request",
          "next": "RESERVED",
          "manual": true,
          "processors": [
            {
              "name": "PetLifecycleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "RESERVED": {
      "transitions": [
        {
          "name": "reserved_to_adopted_manual_approval",
          "next": "ADOPTED",
          "manual": true,
          "processors": [
            {
              "name": "PetLifecycleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ADOPTED": {
      "transitions": [
        {
          "name": "adopted_to_post_adoption",
          "next": "POST_ADOPTION",
          "manual": false,
          "processors": [
            {
              "name": "PetLifecycleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "POST_ADOPTION": {
      "transitions": [
        {
          "name": "post_adoption_to_archived",
          "next": "ARCHIVED",
          "manual": false,
          "processors": [
            {
              "name": "PetLifecycleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ARCHIVED": {
      "transitions": []
    }
  }
}
