{
  "version": "1.0",
  "name": "DailyReport Workflow",
  "desc": "Workflow for DailyReport aggregation and publishing",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "start_aggregation",
          "next": "AGGREGATING",
          "manual": false,
          "processors": [
            {
              "name": "AggregateProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "AGGREGATING": {
      "transitions": [
        {
          "name": "detect_anomalies",
          "next": "ANALYZED",
          "manual": false,
          "processors": [
            {
              "name": "DetectAnomaliesProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ANALYZED": {
      "transitions": [
        {
          "name": "aggregation_complete",
          "next": "READY",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "AggregationCompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "READY": {
      "transitions": [
        {
          "name": "publish_report",
          "next": "PUBLISHING",
          "manual": false,
          "processors": [
            {
              "name": "PublishReportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PUBLISHING": {
      "transitions": [
        {
          "name": "publish_success",
          "next": "PUBLISHED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PublishSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "publish_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PublishFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "PUBLISHED": {
      "transitions": [
        {
          "name": "archive_after_retention",
          "next": "ARCHIVED",
          "manual": false,
          "processors": [
            {
              "name": "RetentionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": []
    },
    "ARCHIVED": {
      "transitions": []
    }
  }
}