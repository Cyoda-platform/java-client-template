{
  "version": "1.0",
  "name": "SyncJob Workflow",
  "desc": "Workflow for SyncJob entity according to the functional requirements",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "to_validate",
          "next": "VALIDATE",
          "manual": false,
          "processors": [
            {
              "name": "ValidateJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATE": {
      "transitions": [
        {
          "name": "to_fetching",
          "next": "FETCHING",
          "manual": false,
          "processors": [
            {
              "name": "FetchPetstoreDataProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "to_transform_on_success",
          "next": "TRANSFORM",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "to_failed_on_fetch_error",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchErrorCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "TRANSFORM": {
      "transitions": [
        {
          "name": "to_persist",
          "next": "PERSIST",
          "manual": false,
          "processors": [
            {
              "name": "TransformToPetProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PERSIST": {
      "transitions": [
        {
          "name": "to_completed_on_success",
          "next": "COMPLETED",
          "manual": false,
          "processors": [
            {
              "name": "PersistPetsProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "to_failed_on_persistence_error",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PersistenceErrorCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "FAILED": {
      "transitions": []
    },
    "COMPLETED": {
      "transitions": []
    }
  }
}