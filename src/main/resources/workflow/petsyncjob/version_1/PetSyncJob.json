{
  "version": "1.0",
  "name": "PetSyncJob Workflow",
  "desc": "Workflow for PetSyncJob: orchestrates fetch, parse, persist and finalization with clear success/failure criteria.",
  "initialState": "none",
  "active": true,
  "states": {
    "none": {
      "transitions": [
        {
          "name": "create_job",
          "next": "PENDING",
          "manual": false
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "name": "enqueue_fetch",
          "next": "FETCHING",
          "manual": false,
          "processors": [
            {
              "name": "StartFetchProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "fetch_success",
          "next": "PARSING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "fetch_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "FetchFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "PARSING": {
      "transitions": [
        {
          "name": "parse_success",
          "next": "PERSISTING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ParseSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "parse_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ParseFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "PERSISTING": {
      "transitions": [
        {
          "name": "run_persist",
          "next": "PERSIST_DECISION",
          "manual": false,
          "processors": [
            {
              "name": "PersistProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PERSIST_DECISION": {
      "transitions": [
        {
          "name": "persist_success",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PersistSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "persist_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PersistFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}