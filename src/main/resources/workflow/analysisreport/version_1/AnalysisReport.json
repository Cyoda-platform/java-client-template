{
  "version": "1.0",
  "name": "AnalysisReport Workflow",
  "desc": "Workflow for AnalysisReport lifecycle",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "created_to_validating",
          "next": "validating",
          "manual": false,
          "processors": [
            {
              "name": "ValidateReportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "report_incomplete",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ReportIncompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "report_complete",
          "next": "ready",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ReportCompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ready": {
      "transitions": [
        {
          "name": "ready_to_archived",
          "next": "archived",
          "manual": true,
          "processors": [
            {
              "name": "ArchiveProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "failed_to_retry_pending",
          "next": "retry_pending",
          "manual": true,
          "processors": [
            {
              "name": "RetryProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "retry_pending": {
      "transitions": [
        {
          "name": "retry_to_validating",
          "next": "validating",
          "manual": false,
          "processors": [
            {
              "name": "RetryProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "archived": {
      "transitions": []
    }
  }
}