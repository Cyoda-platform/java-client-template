{
    "version": "1.0",
    "name": "Shipment Workflow",
    "desc": "Manages shipment processing in parallel with order workflow.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "CREATE_SHIPMENT",
                    "next": "PICKING",
                    "manual": false
                }
            ]
        },
        "PICKING": {
            "transitions": [
                {
                    "name": "READY_TO_SEND",
                    "next": "WAITING_TO_SEND",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ShipmentReadyToSendProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "WAITING_TO_SEND": {
            "transitions": [
                {
                    "name": "MARK_SENT",
                    "next": "SENT",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ShipmentMarkSentProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "SENT": {
            "transitions": [
                {
                    "name": "MARK_DELIVERED",
                    "next": "DELIVERED",
                    "manual": false,
                    "processors": [
                        {
                            "name": "ShipmentMarkDeliveredProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "DELIVERED": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "final_state",
                    "manual": false
                }
            ]
        },
        "final_state": {
            "transitions": []
        }
    }
}