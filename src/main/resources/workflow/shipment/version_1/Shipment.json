{
    "version": "1.0",
    "name": "Shipment Workflow",
    "desc": "Manages shipment lifecycle synchronized with order states.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "initialize_shipment",
                    "next": "PICKING",
                    "manual": false
                }
            ]
        },
        "PICKING": {
            "transitions": [
                {
                    "name": "ready_to_send",
                    "next": "WAITING_TO_SEND",
                    "manual": true,
                    "processors": [
                        {
                            "name": "ShipmentReadyToSendProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "WAITING_TO_SEND": {
            "transitions": [
                {
                    "name": "mark_sent",
                    "next": "SENT",
                    "manual": true,
                    "processors": [
                        {
                            "name": "ShipmentMarkSentProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "SENT": {
            "transitions": [
                {
                    "name": "mark_delivered",
                    "next": "DELIVERED",
                    "manual": true,
                    "processors": [
                        {
                            "name": "ShipmentMarkDeliveredProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "DELIVERED": {
            "transitions": []
        }
    }
}