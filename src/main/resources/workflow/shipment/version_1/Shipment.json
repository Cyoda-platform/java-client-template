{
    "version": "1.0",
    "name": "Shipment Workflow",
    "desc": "Description of the workflow for Shipment",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_picking",
                    "next": "PICKING",
                    "manual": false
                }
            ]
        },
        "PICKING": {
            "transitions": [
                {
                    "name": "transition_to_picking",
                    "next": "PICKING",
                    "manual": false
                },
                {
                    "name": "transition_to_waiting_to_send",
                    "next": "WAITING_TO_SEND",
                    "manual": false
                }
            ]
        },
        "WAITING_TO_SEND": {
            "transitions": [
                {
                    "name": "transition_to_sent",
                    "next": "SENT",
                    "manual": false
                }
            ]
        },
        "SENT": {
            "transitions": [
                {
                    "name": "transition_to_delivered",
                    "next": "DELIVERED",
                    "manual": false
                }
            ]
        },
        "DELIVERED": {
            "transitions": [
                {
                    "name": "transition_to_end",
                    "next": "[*]",
                    "manual": false
                }
            ]
        }
    }
}