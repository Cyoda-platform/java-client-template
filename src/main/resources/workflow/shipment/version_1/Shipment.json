{
    "version": "1.0",
    "name": "Shipment Workflow",
    "desc": "Workflow for Shipment entity matching functional requirements (PICKING -> WAITING_TO_SEND -> SENT -> DELIVERED)",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "create_shipment",
                    "next": "PICKING",
                    "manual": false,
                    "processors": [
                        {
                            "name": "CreateShipmentProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "PICKING": {
            "transitions": [
                {
                    "name": "pick_complete",
                    "next": "WAITING_TO_SEND",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PickCompleteProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "ShipmentReadyCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "WAITING_TO_SEND": {
            "transitions": [
                {
                    "name": "mark_sent",
                    "next": "SENT",
                    "manual": true,
                    "processors": [
                        {
                            "name": "MarkSentAction",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "SENT": {
            "transitions": [
                {
                    "name": "mark_delivered",
                    "next": "DELIVERED",
                    "manual": true,
                    "processors": [
                        {
                            "name": "MarkDeliveredAction",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "DELIVERED": {
            "transitions": []
        }
    }
}