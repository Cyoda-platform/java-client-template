{
  "version": "1.0",
  "name": "ReportJob Workflow",
  "desc": "Workflow for ReportJob orchestration",
  "initialState": "PENDING",
  "active": true,
  "states": {
    "PENDING": {
      "transitions": [
        {
          "name": "to_validating",
          "next": "VALIDATING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidateJobCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "to_fetching",
          "next": "FETCHING",
          "manual": false,
          "processors": [
            {
              "name": "StartFetchProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "to_aggregating",
          "next": "AGGREGATING",
          "manual": false,
          "processors": [
            {
              "name": "FetchBookingsProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "AGGREGATING": {
      "transitions": [
        {
          "name": "to_completed",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "AggregateSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "to_failed",
          "next": "FAILED",
          "manual": false,
          "processors": [
            {
              "name": "OnAggregationErrorProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "COMPLETED": {
      "transitions": [
        {
          "name": "to_notify",
          "next": "NOTIFY",
          "manual": true
        }
      ]
    },
    "NOTIFY": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}