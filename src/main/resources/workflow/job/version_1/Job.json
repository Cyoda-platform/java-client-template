{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity: validate parameters, execute ingestion, finalize and notify based on functional requirements",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "persist_to_pending",
          "next": "PENDING",
          "manual": false
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "ValidateJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_passed",
          "next": "EXECUTING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationPassedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "EXECUTING": {
      "transitions": [
        {
          "name": "execute_ingestion",
          "next": "FINALIZING",
          "manual": false,
          "processors": [
            {
              "name": "ExecuteIngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FINALIZING": {
      "transitions": [
        {
          "name": "processing_succeeded",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ProcessingSucceededCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "processing_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ProcessingFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}