{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for orchestration Job entity (import, reconciliation)",
  "initialState": "NEW",
  "active": true,
  "states": {
    "NEW": {
      "transitions": [
        {
          "name": "new_to_validating",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "ValidateJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validated_to_scheduled",
          "next": "SCHEDULED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failed_to_failed",
          "next": "FAILED",
          "manual": false,
          "processors": [
            {
              "name": "ValidationFailureProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SCHEDULED": {
      "transitions": [
        {
          "name": "scheduled_to_running",
          "next": "RUNNING",
          "manual": false,
          "processors": [
            {
              "name": "ScheduleJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "RUNNING": {
      "transitions": [
        {
          "name": "running_to_completed",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "running_to_failed",
          "next": "FAILED",
          "manual": false,
          "processors": [
            {
              "name": "JobFailureProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}