{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity managing data ingestion and notification process",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "validate_job_parameters",
          "next": "ingesting",
          "manual": false,
          "processors": [
            {
              "name": "ValidateJobParametersProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "fetch_laureate_data",
          "next": "fetching_laureates",
          "manual": false,
          "processors": [
            {
              "name": "FetchLaureateDataProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "fetching_laureates": {
      "transitions": [
        {
          "name": "save_laureates",
          "next": "succeeded",
          "manual": false,
          "processors": [
            {
              "name": "SaveLaureateEntitiesProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        },
        {
          "name": "fail_ingestion",
          "next": "failed",
          "manual": false
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
