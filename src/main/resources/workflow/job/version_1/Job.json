{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job orchestration entity",
  "initialState": "SCHEDULED",
  "active": true,
  "states": {
    "SCHEDULED": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "INGESTING",
          "manual": false,
          "processors": [
            {
              "name": "StartIngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INGESTING": {
      "transitions": [
        {
          "name": "fetch_from_source",
          "next": "PARSING",
          "manual": false,
          "processors": [
            {
              "name": "FetchFromSourceProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 30000
              }
            }
          ]
        }
      ]
    },
    "PARSING": {
      "transitions": [
        {
          "name": "parse_response",
          "next": "DISPATCHING",
          "manual": false,
          "processors": [
            {
              "name": "ParseResponseProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DISPATCHING": {
      "transitions": [
        {
          "name": "dispatch_records",
          "next": "AGGREGATING",
          "manual": false,
          "processors": [
            {
              "name": "DispatchRecordsProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "executionMode": "ASYNC_NEW_TX"
              }
            }
          ]
        }
      ]
    },
    "AGGREGATING": {
      "transitions": [
        {
          "name": "to_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.failureCount",
            "operation": "GREATER_THAN",
            "value": 0
          }
        },
        {
          "name": "to_succeeded",
          "next": "SUCCEEDED",
          "manual": false,
          "criterion": {
            "type": "group",
            "operator": "AND",
            "conditions": [
              {
                "type": "simple",
                "jsonPath": "$.failureCount",
                "operation": "EQUALS",
                "value": 0
              },
              {
                "type": "simple",
                "jsonPath": "$.processedCount",
                "operation": "GREATER_THAN",
                "value": 0
              }
            ]
          }
        }
      ]
    },
    "SUCCEEDED": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "executionMode": "ASYNC_NEW_TX"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "executionMode": "ASYNC_NEW_TX"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED_SUBSCRIBERS": {
      "transitions": []
    }
  }
}