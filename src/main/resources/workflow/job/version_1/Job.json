{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job orchestration",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "to_validating",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "ValidateJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "valid_params",
          "next": "SCHEDULING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "invalid_params",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "SCHEDULING": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "INGESTION_TRIGGERED",
          "manual": false,
          "processors": [
            {
              "name": "StartIngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INGESTION_TRIGGERED": {
      "transitions": [
        {
          "name": "ingestion_complete",
          "next": "PROCESSING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionCompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "ingestion_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "PROCESSING": {
      "transitions": [
        {
          "name": "assemble_report",
          "next": "PUBLISHING",
          "manual": false,
          "processors": [
            {
              "name": "AssembleReportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PUBLISHING": {
      "transitions": [
        {
          "name": "delivery_success",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DeliverySuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "delivery_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DeliveryFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": { "transitions": [] },
    "FAILED": { "transitions": [] }
  }
}