{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for orchestration of ingestion jobs",
  "initialState": "SCHEDULED",
  "active": true,
  "states": {
    "SCHEDULED": {
      "transitions": [
        {
          "name": "start_ingest",
          "next": "INGESTING",
          "manual": false,
          "processors": [
            {
              "name": "IngestJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INGESTING": {
      "transitions": [
        {
          "name": "transition_to_succeeded",
          "next": "SUCCEEDED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobSucceededCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "transition_to_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "SUCCEEDED": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "notify_subscribers_on_failure",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED_SUBSCRIBERS": {
      "transitions": [
        {
          "name": "complete",
          "next": "COMPLETED",
          "manual": false
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    }
  }
}