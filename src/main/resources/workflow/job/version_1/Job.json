{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity based on ingestion and notification process",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "validate_job",
          "next": "ingesting",
          "manual": false,
          "processors": [
            {
              "name": "JobValidationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "fetch_and_save_laureates",
          "next": "success_or_failure",
          "manual": false,
          "processors": [
            {
              "name": "LaureateIngestionProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "success_or_failure": {
      "transitions": [
        {
          "name": "check_success",
          "next": "succeeded",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "check_failure",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "NotificationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers_failure",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "FailureNotificationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
