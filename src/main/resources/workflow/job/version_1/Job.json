{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity translated from functional requirements mermaid diagram",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "persist_to_scheduled",
          "next": "SCHEDULED",
          "manual": false
        }
      ]
    },
    "SCHEDULED": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "INGESTING",
          "manual": false,
          "processors": [
            {
              "name": "ScheduleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            },
            {
              "name": "IngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INGESTING": {
      "transitions": [
        {
          "name": "ingestion_success",
          "next": "SUCCEEDED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          },
          "processors": [
            {
              "name": "JobCompletionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "ingestion_failure",
          "next": "FAILED",
          "manual": false,
          "processors": [
            {
              "name": "IngestionFailureProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            },
            {
              "name": "JobRetryProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SUCCEEDED": {
      "transitions": [
        {
          "name": "notify_on_success",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "notify_on_failure",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "RetryExceededCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          },
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED_SUBSCRIBERS": {
      "transitions": []
    }
  }
}