{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity managing ingestion job lifecycle",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "validate_api_endpoint",
          "next": "validating",
          "manual": false
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "start_ingesting",
          "next": "ingesting",
          "manual": false,
          "processors": [
            {
              "name": "JobProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        },
        {
          "name": "validation_failed",
          "next": "failed",
          "manual": false
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "ingestion_succeeded",
          "next": "succeeded",
          "manual": false
        },
        {
          "name": "ingestion_failed",
          "next": "failed",
          "manual": false
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberNotifier",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberNotifier",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
