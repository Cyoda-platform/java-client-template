{"version":"1.0","name":"Job Workflow","desc":"Workflow for Job entity per functional requirements: SCHEDULED -> INGESTING (JobIngestionProcessor) -> SUCCEEDED/FAILED (FetchSuccess/FailureCriterion) -> NOTIFIED_SUBSCRIBERS (NotifySubscribersProcessor) -> COMPLETED (terminal, audit stored).","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"initialize_to_scheduled","next":"SCHEDULED","manual":false}]},"SCHEDULED":{"transitions":[{"name":"start_ingestion","next":"INGESTING","manual":false,"processors":[{"name":"JobIngestionProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"INGESTING":{"transitions":[{"name":"ingestion_success","next":"SUCCEEDED","manual":false,"criterion":{"type":"function","function":{"name":"FetchSuccessCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"ingestion_failure","next":"FAILED","manual":false,"criterion":{"type":"function","function":{"name":"FetchFailureCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"SUCCEEDED":{"transitions":[{"name":"notify_after_success","next":"NOTIFIED_SUBSCRIBERS","manual":false,"processors":[{"name":"NotifySubscribersProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"FAILED":{"transitions":[{"name":"notify_after_failure","next":"NOTIFIED_SUBSCRIBERS","manual":false,"processors":[{"name":"NotifySubscribersProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"NOTIFIED_SUBSCRIBERS":{"transitions":[{"name":"complete_job","next":"COMPLETED","manual":false}]},"COMPLETED":{"transitions":[]}}}