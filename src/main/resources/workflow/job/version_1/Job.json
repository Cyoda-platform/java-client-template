{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job orchestration entity handling validation, fetching, normalization, comparison and persistence",
  "initialState": "PENDING",
  "active": true,
  "states": {
    "PENDING": {
      "transitions": [
        {
          "name": "validate_job",
          "next": "VALIDATING",
          "manual": false
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_passed",
          "next": "FETCHING",
          "manual": false,
          "processors": [
            {
              "name": "JobValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "validation_failed",
          "next": "FAILED",
          "manual": false
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "fetch_complete",
          "next": "NORMALIZING",
          "manual": false,
          "processors": [
            {
              "name": "JobFetchProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "fetch_failed",
          "next": "FAILED",
          "manual": false
        }
      ]
    },
    "NORMALIZING": {
      "transitions": [
        {
          "name": "normalize_complete",
          "next": "COMPARING",
          "manual": false,
          "processors": [
            {
              "name": "NormalizeProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "COMPARING": {
      "transitions": [
        {
          "name": "records_ok",
          "next": "PERSISTING",
          "manual": false,
          "processors": [
            {
              "name": "DedupAndVersionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "processing_error",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ProcessingErrorCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "PERSISTING": {
      "transitions": [
        {
          "name": "persist_complete",
          "next": "COMPLETED",
          "manual": false,
          "processors": [
            {
              "name": "PersistLaureateProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "persist_failed",
          "next": "FAILED",
          "manual": false
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": [
        {
          "name": "apply_retry_policy",
          "next": "RETRY_WAIT",
          "manual": false,
          "processors": [
            {
              "name": "JobRetryProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "escalate_manual",
          "next": "ESCALATED",
          "manual": true
        }
      ]
    },
    "RETRY_WAIT": {
      "transitions": [
        {
          "name": "retry_limit_reached",
          "next": "ESCALATED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "RetryExhaustedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ESCALATED": {
      "transitions": []
    }
  }
}