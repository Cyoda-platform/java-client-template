{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity as specified in functional requirements",
  "initialState": "SCHEDULED",
  "active": true,
  "states": {
    "SCHEDULED": {
      "transitions": [
        {
          "name": "schedule_to_ingesting",
          "next": "INGESTING",
          "manual": false,
          "processors": [
            {
              "name": "JobScheduleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INGESTING": {
      "transitions": [
        {
          "name": "ingesting_to_succeeded",
          "next": "SUCCEEDED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionCompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "ingesting_to_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionErrorCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "SUCCEEDED": {
      "transitions": [
        {
          "name": "succeeded_to_downstream",
          "next": "DOWNSTREAM_PROCESSING",
          "manual": false,
          "processors": [
            {
              "name": "DownstreamTriggerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "failed_to_notified",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DOWNSTREAM_PROCESSING": {
      "transitions": [
        {
          "name": "downstream_to_notified",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED_SUBSCRIBERS": {
      "transitions": [
        {
          "name": "notified_to_completed",
          "next": "COMPLETED",
          "manual": false
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    }
  }
}