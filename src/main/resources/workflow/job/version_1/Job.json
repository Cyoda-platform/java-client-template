{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity: validation, execution, failure handling, retry scheduling and escalation. Processors: JobValidationProcessor, ExecuteJobProcessor. Criteria: JobValidationCriterion, JobValidationFailureCriterion, JobExecutionExceptionCriterion, JobRetryCriterion, JobMaxAttemptsExceededCriterion.",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "to_pending",
          "next": "PENDING",
          "manual": false
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "name": "validate_job",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "JobValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_passes",
          "next": "EXECUTING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_fails",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "EXECUTING": {
      "transitions": [
        {
          "name": "execution_success",
          "next": "COMPLETED",
          "manual": false,
          "processors": [
            {
              "name": "ExecuteJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "execution_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobExecutionExceptionCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": [
        {
          "name": "retry_if_possible",
          "next": "RETRY_SCHEDULED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobRetryCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "escalate_to_admin",
          "next": "ESCALATED",
          "manual": true,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobMaxAttemptsExceededCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "RETRY_SCHEDULED": {
      "transitions": []
    },
    "ESCALATED": {
      "transitions": []
    }
  }
}