{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job orchestration entity",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "enqueue",
          "next": "PENDING",
          "manual": false,
          "processors": [
            {
              "name": "CreateJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "name": "start",
          "next": "RUNNING",
          "manual": false,
          "processors": [
            {
              "name": "StartJobProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "RUNNING": {
      "transitions": [
        {
          "name": "succeed_transition",
          "next": "SUCCESS",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "fail_transition",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "SUCCESS": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}