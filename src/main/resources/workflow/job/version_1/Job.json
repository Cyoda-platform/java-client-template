{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow managing Job entity states and processing for data ingestion and notification",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "validate_job",
          "next": "ingesting",
          "manual": false,
          "processors": [
            {
              "name": "JobValidator",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "fetch_data",
          "next": "succeeded",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionSuccessCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          }
        },
        {
          "name": "ingestion_failed",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionFailureCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          }
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberNotificationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberNotificationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
