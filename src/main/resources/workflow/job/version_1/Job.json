{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity managing ingestion and notification process",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "validate_job",
          "next": "ingesting",
          "manual": false,
          "processors": [
            {
              "name": "JobValidationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "fetch_data_success",
          "next": "succeeded",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {"name": "JobDataFetchSuccessCriterion", "config": {"calculationNodesTags": "cyoda_application"}}
          }
        },
        {
          "name": "fetch_data_failure",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {"name": "JobDataFetchFailureCriterion", "config": {"calculationNodesTags": "cyoda_application"}}
          }
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "JobNotifySubscribersProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "JobNotifySubscribersProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
