{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity based on functional requirements",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "initialize_job",
          "next": "SCHEDULED",
          "manual": false
        }
      ]
    },
    "SCHEDULED": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "INGESTING",
          "manual": false,
          "processors": [
            {
              "name": "StartIngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INGESTING": {
      "transitions": [
        {
          "name": "to_parsing",
          "next": "PARSING",
          "manual": false
        }
      ]
    },
    "PARSING": {
      "transitions": [
        {
          "name": "to_validating",
          "next": "VALIDATING",
          "manual": false
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "to_persisting",
          "next": "PERSISTING",
          "manual": false
        }
      ]
    },
    "PERSISTING": {
      "transitions": [
        {
          "name": "persist_success",
          "next": "SUCCEEDED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PersistSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "persist_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PersistFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "SUCCEEDED": {
      "transitions": [
        {
          "name": "notify_subscribers_on_success",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "notify_subscribers_on_failure",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED_SUBSCRIBERS": {
      "transitions": []
    }
  }
}