{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow that manages Job lifecycle: scheduling, ingestion, downstream processing and notifications.",
  "initialState": "SCHEDULED",
  "active": true,
  "states": {
    "SCHEDULED": {
      "transitions": [
        {
          "name": "schedule_to_ingesting",
          "next": "INGESTING",
          "manual": false,
          "processors": [
            {
              "name": "JobScheduleProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INGESTING": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "INGESTION_PROCESS",
          "manual": false,
          "processors": [
            {
              "name": "JobIngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 300000
              }
            }
          ]
        }
      ]
    },
    "INGESTION_PROCESS": {
      "transitions": [
        {
          "name": "ingestion_succeeded",
          "next": "SUCCEEDED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionCompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "ingestion_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionErrorCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "SUCCEEDED": {
      "transitions": [
        {
          "name": "trigger_downstream",
          "next": "DOWNSTREAM_PROCESSING",
          "manual": false,
          "processors": [
            {
              "name": "DownstreamTriggerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "notify_after_failure",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "DOWNSTREAM_PROCESSING": {
      "transitions": [
        {
          "name": "after_downstream_notify",
          "next": "NOTIFIED_SUBSCRIBERS",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "NOTIFIED_SUBSCRIBERS": {
      "transitions": [
        {
          "name": "finalize_job",
          "next": "COMPLETED",
          "manual": false,
          "processors": [
            {
              "name": "JobLoggingProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    }
  }
}