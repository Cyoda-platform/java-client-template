{"version":"1.0","name":"Job Workflow","desc":"Workflow for Job entity based on functional requirements: creation, validation, execution, analysis, persistence, notification enqueueing and archival (no loops). Processors limited to JobExecutionProcessor and PersistResultsProcessor.","initialState":"initial_state","active":true,"states":{"initial_state":{"transitions":[{"name":"initial_to_created","next":"CREATED","manual":false}]},"CREATED":{"transitions":[{"name":"created_to_validating_on_valid","next":"VALIDATING","manual":false,"criterion":{"type":"function","function":{"name":"JobValidationCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"created_to_failed_on_invalid","next":"FAILED","manual":false,"criterion":{"type":"function","function":{"name":"JobValidationFailureCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"VALIDATING":{"transitions":[{"name":"validating_to_running","next":"RUNNING","manual":false,"processors":[{"name":"JobExecutionProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"RUNNING":{"transitions":[{"name":"running_to_analyzing","next":"ANALYZING","manual":false}]},"ANALYZING":{"transitions":[{"name":"analyzing_to_persisting","next":"PERSISTING","manual":false,"processors":[{"name":"PersistResultsProcessor","config":{"calculationNodesTags":"cyoda_application"}}]}]},"PERSISTING":{"transitions":[{"name":"persisting_to_completed_on_success","next":"COMPLETED","manual":false,"criterion":{"type":"function","function":{"name":"PersistSuccessCriterion","config":{"calculationNodesTags":"cyoda_application"}}}},{"name":"persisting_to_failed_on_failure","next":"FAILED","manual":false,"criterion":{"type":"function","function":{"name":"PersistFailureCriterion","config":{"calculationNodesTags":"cyoda_application"}}}}]},"COMPLETED":{"transitions":[{"name":"completed_to_notification_queued","next":"NOTIFICATION_QUEUED","manual":false}]},"NOTIFICATION_QUEUED":{"transitions":[{"name":"notification_queued_to_archived_manual","next":"ARCHIVED","manual":true}]},"FAILED":{"transitions":[{"name":"failed_to_archived_manual","next":"ARCHIVED","manual":true}]},"ARCHIVED":{"transitions":[]}}}