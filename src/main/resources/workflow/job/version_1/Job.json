{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity managing ingestion and notification process",
  "initialState": "pending",
  "active": true,
  "states": {
    "pending": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "validating",
          "manual": false
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "validation_successful",
          "next": "ingesting",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failed",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "ingestion_successful",
          "next": "succeeded",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          },
          "processors": [
            {
              "name": "LaureateIngestionProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "ingestion_failed",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "SubscribersNotificationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "SubscribersNotificationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": [
        {
          "name": "job_complete",
          "next": "end",
          "manual": false
        }
      ]
    },
    "end": {
      "transitions": []
    }
  }
}
