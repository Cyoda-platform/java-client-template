{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity managing the ingestion lifecycle of Nobel laureates data.",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "ingesting",
          "manual": false,
          "processors": [
            {
              "name": "JobIngestionProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "success",
          "next": "succeeded",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "failure",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "JobNotificationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "JobNotificationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
