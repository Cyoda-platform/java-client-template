{
    "version": "1.0",
    "name": "Report Workflow",
    "desc": "Workflow for Report entity generated by ReportJob processors (CREATED -> GENERATING -> COMPLETED -> AVAILABLE / FAILED)",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "init_to_created",
                    "next": "CREATED",
                    "manual": false
                }
            ]
        },
        "CREATED": {
            "transitions": [
                {
                    "name": "store_report_and_generate",
                    "next": "GENERATING",
                    "manual": false,
                    "processors": [
                        {
                            "name": "StoreReportProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "GENERATING": {
            "transitions": [
                {
                    "name": "render_success",
                    "next": "COMPLETED",
                    "manual": false,
                    "processors": [
                        {
                            "name": "RenderReportProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "simple",
                        "jsonPath": "$.rendering.success",
                        "operation": "EQUALS",
                        "value": true
                    }
                },
                {
                    "name": "render_failure",
                    "next": "FAILED",
                    "manual": false,
                    "criterion": {
                        "type": "simple",
                        "jsonPath": "$.rendering.success",
                        "operation": "EQUALS",
                        "value": false
                    }
                }
            ]
        },
        "COMPLETED": {
            "transitions": [
                {
                    "name": "link_resources_and_make_available",
                    "next": "AVAILABLE",
                    "manual": false,
                    "processors": [
                        {
                            "name": "LinkResourcesProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "AVAILABLE": {
            "transitions": []
        },
        "FAILED": {
            "transitions": []
        }
    }
}