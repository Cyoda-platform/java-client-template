{
  "version": "1.0",
  "name": "WeeklySend Workflow",
  "desc": "Orchestration workflow for WeeklySend: draft, schedule, prepare, send, complete/fail, reporting",
  "initialState": "DRAFT",
  "active": true,
  "states": {
    "DRAFT": {
      "transitions": [
        {
          "name": "schedule_send",
          "next": "SCHEDULED",
          "manual": false,
          "processors": [
            {
              "name": "ScheduleSendProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SCHEDULED": {
      "transitions": [
        {
          "name": "prepare_recipients",
          "next": "PREPARING",
          "manual": false,
          "processors": [
            {
              "name": "PrepareRecipientsProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PREPARING": {
      "transitions": [
        {
          "name": "start_send",
          "next": "SENDING",
          "manual": false,
          "processors": [
            {
              "name": "StartSendProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SENDING": {
      "transitions": [
        {
          "name": "complete_send",
          "next": "SENT",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "SendCompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "fail_send",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "SendFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "SENT": {
      "transitions": [
        {
          "name": "aggregate_reporting",
          "next": "REPORTING",
          "manual": false,
          "processors": [
            {
              "name": "AggregateReportingProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "REPORTING": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}