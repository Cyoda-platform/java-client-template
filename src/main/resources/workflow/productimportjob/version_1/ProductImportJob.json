{
  "version": "1.0",
  "name": "ProductImportJob Workflow",
  "desc": "Workflow for importing products from external sources",
  "initialState": "PENDING",
  "active": true,
  "states": {
    "PENDING": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "StartImportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validate_job_criteria",
          "next": "FETCHING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidateImportJobCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "FETCHING": {
      "transitions": [
        {
          "name": "fetch_payload",
          "next": "TRANSFORMING",
          "manual": false,
          "processors": [
            {
              "name": "FetchImportProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "TRANSFORMING": {
      "transitions": [
        {
          "name": "transform_rows",
          "next": "PERSISTING",
          "manual": false,
          "processors": [
            {
              "name": "TransformProductProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "PERSISTING": {
      "transitions": [
        {
          "name": "persist_products",
          "next": "POST_PROCESSING",
          "manual": false,
          "processors": [
            {
              "name": "PersistProductProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "POST_PROCESSING": {
      "transitions": [
        {
          "name": "finalize_success",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ImportSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "finalize_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ImportFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": [
        {
          "name": "notify_admin_success",
          "next": "DONE",
          "manual": false,
          "processors": [
            {
              "name": "NotifyAdminProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "notify_admin_failure",
          "next": "DONE",
          "manual": false,
          "processors": [
            {
              "name": "NotifyAdminProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DONE": {
      "transitions": []
    }
  }
}