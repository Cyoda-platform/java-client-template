{
    "version": "1.0",
    "name": "HNItem Workflow",
    "desc": "Manages the lifecycle of Hacker News items from creation/import through validation, enrichment, indexing, and final processing.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "transition_to_validated",
                    "next": "validated",
                    "manual": false
                }
            ]
        },
        "validated": {
            "transitions": [
                {
                    "name": "transition_to_enriched",
                    "next": "enriched",
                    "manual": false,
                    "processors": [
                        {
                            "name": "HNItemValidationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "transition_to_indexed",
                    "next": "indexed",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "HNItemNoEnrichmentNeededCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "enriched": {
            "transitions": [
                {
                    "name": "transition_to_indexed",
                    "next": "indexed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "HNItemIndexingProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "indexed": {
            "transitions": [
                {
                    "name": "transition_to_processed",
                    "next": "processed",
                    "manual": false,
                    "processors": [
                        {
                            "name": "HNItemFinalizationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "processed": {
            "transitions": [
                {
                    "name": "transition_to_validated",
                    "next": "validated",
                    "manual": true,
                    "processors": [
                        {
                            "name": "HNItemReprocessingProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        }
    }
}