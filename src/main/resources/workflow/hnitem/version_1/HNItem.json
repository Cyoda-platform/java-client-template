{
  "version": "1.0",
  "name": "HNItem Workflow",
  "desc": "Workflow for HNItem business entity",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "enrich_item",
          "next": "ENRICHED",
          "manual": false,
          "processors": [
            {
              "name": "EnrichProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ENRICHED": {
      "transitions": [
        {
          "name": "dedupe_then_store",
          "next": "AVAILABLE",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DeduplicationCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "dedupe_ignored",
          "next": "DUPLICATE_HANDLED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DeduplicationIgnoredCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "AVAILABLE": {
      "transitions": []
    },
    "DUPLICATE_HANDLED": {
      "transitions": []
    }
  }
}