{
  "version": "1.0",
  "name": "Pet Workflow",
  "desc": "Workflow for Pet entity derived from the functional requirements (state diagram translated to FSM JSON).",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "init_to_created",
          "next": "CREATED",
          "manual": false
        }
      ]
    },
    "CREATED": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "PetValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_passed",
          "next": "ENRICHING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ENRICHING": {
      "transitions": [
        {
          "name": "enrich_and_check_availability",
          "next": "AVAILABILITY_CHECK",
          "manual": false,
          "processors": [
            {
              "name": "EnrichmentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "AVAILABILITY_CHECK": {
      "transitions": [
        {
          "name": "availability_is_available",
          "next": "READY",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.status",
            "operation": "EQUALS",
            "value": "AVAILABLE"
          }
        },
        {
          "name": "availability_is_not_available",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.status",
            "operation": "NOT_EQUALS",
            "value": "AVAILABLE"
          }
        }
      ]
    },
    "READY": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}