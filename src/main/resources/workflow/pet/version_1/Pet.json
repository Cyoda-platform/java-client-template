{
  "version": "1.0",
  "name": "Pet, Owner and PetIngestionJob Workflows",
  "desc": "Workflows for Pet, Owner and PetIngestionJob entities derived from functional requirements",
  "initialState": "none",
  "active": true,
  "states": {
    "PetWorkflow": {
      "transitions": [
        {
          "name": "noop_to_start", 
          "next": "NEW",
          "manual": false
        }
      ]
    },
    "NEW": {
      "transitions": [
        {
          "name": "to_validation",
          "next": "VALIDATION",
          "manual": false,
          "processors": [
            {
              "name": "ProcessPetValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATION": {
      "transitions": [
        {
          "name": "validation_pass",
          "next": "ENRICHMENT",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PetValidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_fail",
          "next": "VALIDATION_FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "PetInvalidCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ENRICHMENT": {
      "transitions": [
        {
          "name": "to_available",
          "next": "AVAILABLE",
          "manual": false,
          "processors": [
            {
              "name": "EnrichPetProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATION_FAILED": {
      "transitions": [
        {
          "name": "validation_failed_archive",
          "next": "ARCHIVED",
          "manual": false,
          "processors": [
            {
              "name": "ValidationFailedProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "AVAILABLE": {
      "transitions": [
        {
          "name": "create_adoption_request",
          "next": "RESERVED",
          "manual": true,
          "processors": [
            {
              "name": "CreateAdoptionRequestProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "RESERVED": {
      "transitions": [
        {
          "name": "approve_adoption",
          "next": "ADOPTED",
          "manual": true,
          "processors": [
            {
              "name": "ApproveAdoptionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ADOPTED": {
      "transitions": [
        {
          "name": "post_adoption",
          "next": "POST_ADOPTION",
          "manual": false,
          "processors": [
            {
              "name": "PostAdoptionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "POST_ADOPTION": {
      "transitions": [
        {
          "name": "archive_after_adoption",
          "next": "ARCHIVED",
          "manual": false,
          "processors": [
            {
              "name": "ArchivePetProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ARCHIVED": {
      "transitions": []
    },
    "OwnerWorkflow": {
      "transitions": [
        {
          "name": "noop_to_start_owner",
          "next": "CREATED",
          "manual": false
        }
      ]
    },
    "CREATED": {
      "transitions": [
        {
          "name": "verify_owner",
          "next": "VERIFIED",
          "manual": false,
          "processors": [
            {
              "name": "VerifyOwnerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VERIFIED": {
      "transitions": [
        {
          "name": "activate_owner",
          "next": "ACTIVE",
          "manual": false,
          "processors": [
            {
              "name": "ActivateOwnerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ACTIVE": {
      "transitions": [
        {
          "name": "suspend_owner",
          "next": "SUSPENDED",
          "manual": true,
          "processors": [
            {
              "name": "SuspendOwnerProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "SUSPENDED": {
      "transitions": []
    },
    "PetIngestionJobWorkflow": {
      "transitions": [
        {
          "name": "noop_to_start_job",
          "next": "PENDING",
          "manual": false
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "name": "start_ingestion",
          "next": "RUNNING",
          "manual": true,
          "processors": [
            {
              "name": "StartIngestionProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "RUNNING": {
      "transitions": [
        {
          "name": "ingestion_completed",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ImportSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "ingestion_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ImportFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}