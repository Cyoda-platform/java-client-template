{
    "version": "1.0",
    "name": "Pet Workflow",
    "desc": "Manages the lifecycle of pets in the store from creation to sale.",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "create_pet",
                    "next": "draft",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PetCreationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "draft": {
            "transitions": [
                {
                    "name": "make_available",
                    "next": "available",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetValidationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ],
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "PetValidityCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                }
            ]
        },
        "available": {
            "transitions": [
                {
                    "name": "reserve_pet",
                    "next": "pending",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetReservationProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                },
                {
                    "name": "direct_sale",
                    "next": "sold",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetSaleProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "name": "cancel_reservation",
                    "next": "available",
                    "manual": true
                },
                {
                    "name": "sell_pet",
                    "next": "sold",
                    "manual": true,
                    "processors": [
                        {
                            "name": "PetSaleProcessor",
                            "executionMode": "SYNC",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "sold": {
            "transitions": [
                {
                    "name": "end_state",
                    "next": "end",
                    "manual": false
                }
            ]
        },
        "end": {
            "transitions": []
        }
    }
}