{
  "version": "1.0",
  "name": "Pet",
  "desc": "Pet workflow for managing pet adoption lifecycle",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "initialize_pet",
          "next": "available",
          "manual": false,
          "processors": [
            {
              "name": "PetInitializationProcessor",
              "executionMode": "SYNC",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "available": {
      "transitions": [
        {
          "name": "reserve_pet",
          "next": "reserved",
          "manual": true,
          "processors": [
            {
              "name": "PetReservationProcessor",
              "executionMode": "SYNC",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          ],
          "criterion": {
            "type": "function",
            "function": {
              "name": "PetAvailabilityCriterion",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 3000,
                "retryPolicy": "FIXED"
              }
            }
          }
        }
      ]
    },
    "reserved": {
      "transitions": [
        {
          "name": "cancel_reservation",
          "next": "available",
          "manual": true
        },
        {
          "name": "complete_sale",
          "next": "sold",
          "manual": true,
          "processors": [
            {
              "name": "PetSaleProcessor",
              "executionMode": "SYNC",
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application",
                "responseTimeoutMs": 5000,
                "retryPolicy": "FIXED"
              }
            }
          ]
        }
      ]
    },
    "sold": {
      "transitions": []
    }
  }
}
