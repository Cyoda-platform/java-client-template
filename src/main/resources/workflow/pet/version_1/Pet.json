{
    "version": "1.0",
    "name": "Pet Workflow",
    "desc": "Workflow for Pet entity based on functional requirements (validation, enrichment, availability decision, notification, adoption).",
    "initialState": "initial_state",
    "active": true,
    "states": {
        "initial_state": {
            "transitions": [
                {
                    "name": "initial_to_persisted",
                    "next": "PERSISTED",
                    "manual": false
                }
            ]
        },
        "PERSISTED": {
            "transitions": [
                {
                    "name": "to_validated",
                    "next": "VALIDATED",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PetValidationProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "VALIDATED": {
            "transitions": [
                {
                    "name": "to_enriched",
                    "next": "ENRICHED",
                    "manual": false,
                    "processors": [
                        {
                            "name": "PetEnrichmentProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "ENRICHED": {
            "transitions": [
                {
                    "name": "to_available_by_criterion",
                    "next": "AVAILABLE",
                    "manual": false,
                    "criterion": {
                        "type": "function",
                        "function": {
                            "name": "AvailabilityCriterion",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    }
                },
                {
                    "name": "manual_mark_adopted",
                    "next": "ADOPTED",
                    "manual": true
                }
            ]
        },
        "AVAILABLE": {
            "transitions": [
                {
                    "name": "to_notified",
                    "next": "NOTIFIED",
                    "manual": false,
                    "processors": [
                        {
                            "name": "NotifyCatalogProcessor",
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            }
                        }
                    ]
                }
            ]
        },
        "NOTIFIED": {
            "transitions": []
        },
        "ADOPTED": {
            "transitions": []
        }
    }
}