{
  "version": "1.0",
  "name": "Payment Workflow",
  "desc": "Workflow to authorize and capture payments during checkout",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "initiate_payment",
          "next": "payment_initiated",
          "manual": false,
          "processors": [
            {
              "name": "PaymentInitiationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "payment_initiated": {
      "transitions": [
        {
          "name": "authorized",
          "next": "authorized",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.status",
            "operation": "EQUALS",
            "value": "AUTHORIZED"
          }
        },
        {
          "name": "failed",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "simple",
            "jsonPath": "$.status",
            "operation": "NOT_EQUALS",
            "value": "AUTHORIZED"
          }
        }
      ]
    },
    "authorized": {
      "transitions": [
        {
          "name": "capture",
          "next": "captured",
          "manual": false,
          "processors": [
            {
              "name": "PaymentCaptureProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "captured": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}