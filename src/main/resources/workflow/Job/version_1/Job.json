{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity managing ingestion job lifecycle",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "validate_job",
          "next": "ingesting",
          "manual": false,
          "processors": [
            {
              "name": "JobValidationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "fetch_and_create_laureates",
          "next": "succeeded",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionSuccessCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          },
          "processors": [
            {
              "name": "IngestNobelLaureatesProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        },
        {
          "name": "fetch_and_fail",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobIngestionFailedCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          },
          "processors": [
            {
              "name": "IngestNobelLaureatesProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "NotifySubscribersProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
