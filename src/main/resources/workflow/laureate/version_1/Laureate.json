{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Validation, enrichment, deduplication, persistence and optional manual review for Laureate entity",
  "initialState": "IMPORTED",
  "active": true,
  "states": {
    "IMPORTED": {
      "transitions": [
        {
          "name": "imported_to_validating",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "LaureateValidationProcessor",
              "config": { "calculationNodesTags": "cyoda_application" }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validating_to_enriching",
          "next": "ENRICHING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": { "name": "LaureateValidationPassedCriterion", "config": { "calculationNodesTags": "cyoda_application" } }
          }
        },
        {
          "name": "validating_to_invalid",
          "next": "INVALID",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": { "name": "LaureateValidationFailedCriterion", "config": { "calculationNodesTags": "cyoda_application" } }
          }
        }
      ]
    },
    "INVALID": {
      "transitions": [
        { "name": "invalid_to_review", "next": "REVIEW", "manual": true }
      ]
    },
    "REVIEW": {
      "transitions": [
        {
          "name": "review_to_enriching",
          "next": "ENRICHING",
          "manual": false,
          "processors": [
            { "name": "LaureateManualReviewHandler", "config": { "calculationNodesTags": "cyoda_application" } }
          ]
        }
      ]
    },
    "ENRICHING": {
      "transitions": [
        {
          "name": "enriching_to_dedup",
          "next": "DEDUP_CHECK",
          "manual": false,
          "processors": [
            { "name": "LaureateEnrichmentProcessor", "config": { "calculationNodesTags": "cyoda_application" } }
          ]
        }
      ]
    },
    "DEDUP_CHECK": {
      "transitions": [
        {
          "name": "dedup_to_stored",
          "next": "STORED",
          "manual": false,
          "processors": [
            { "name": "LaureateDedupMergeProcessor", "config": { "calculationNodesTags": "cyoda_application" } }
          ]
        }
      ]
    },
    "STORED": {
      "transitions": [
        {
          "name": "stored_to_emit",
          "next": "EMITTED",
          "manual": false,
          "processors": [
            { "name": "LaureateNotificationEmitter", "config": { "calculationNodesTags": "cyoda_application" } }
          ]
        }
      ]
    },
    "EMITTED": { "transitions": [] }
  }
}