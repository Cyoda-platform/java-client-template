{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity creation and enrichment",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_fields",
          "next": "validated",
          "manual": false,
          "processors": [
            {
              "name": "ValidationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "enrich_data",
          "next": "enriched",
          "manual": false,
          "processors": [
            {
              "name": "EnrichmentProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "enriched": {
      "transitions": [
        {
          "name": "persist_data",
          "next": "stored",
          "manual": false
        }
      ]
    },
    "stored": {
      "transitions": []
    }
  }
}
