{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity: validation, enrichment and persistence triggered by Job ingestion",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "transition_to_persisted_by_job",
          "next": "PERSISTED_BY_JOB",
          "manual": false
        }
      ]
    },
    "PERSISTED_BY_JOB": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "LaureateValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_success",
          "next": "ENRICHED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failure",
          "next": "VALIDATION_FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ENRICHED": {
      "transitions": [
        {
          "name": "enriched_to_stored",
          "next": "STORED",
          "manual": false,
          "processors": [
            {
              "name": "LaureateEnrichmentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            },
            {
              "name": "PersistLaureateProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATION_FAILED": {
      "transitions": [
        {
          "name": "failed_to_stored",
          "next": "STORED",
          "manual": false,
          "processors": [
            {
              "name": "PersistLaureateProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "STORED": {
      "transitions": []
    }
  }
}