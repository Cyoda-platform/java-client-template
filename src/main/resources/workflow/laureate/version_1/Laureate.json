{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity creation and validation",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_fields",
          "next": "validated",
          "manual": false,
          "processors": [
            {
              "name": "LaureateValidationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "enrich_fields",
          "next": "enriched",
          "manual": false,
          "processors": [
            {
              "name": "LaureateEnrichmentProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "enriched": {
      "transitions": []
    }
  }
}
