{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity processing (enrichment, matching, notifications)",
  "initialState": "PERSISTED",
  "active": true,
  "states": {
    "PERSISTED": {
      "transitions": [
        {
          "name": "start_enrichment",
          "next": "ENRICHING",
          "manual": false,
          "processors": [
            {
              "name": "EnrichmentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ENRICHING": {
      "transitions": [
        {
          "name": "enrichment_complete",
          "next": "MATCHING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "EnrichmentCompleteCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "MATCHING": {
      "transitions": [
        {
          "name": "found_subscribers",
          "next": "SCHEDULING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "SubscriberMatchCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "requires_manual_review",
          "next": "MANUAL_REVIEW",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ManualFlagCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "no_matches",
          "next": "AUDIT",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "NoSubscriberMatchCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "MANUAL_REVIEW": {
      "transitions": [
        {
          "name": "manual_approve",
          "next": "SCHEDULING",
          "manual": true
        },
        {
          "name": "manual_reject",
          "next": "AUDIT",
          "manual": true
        }
      ]
    },
    "SCHEDULING": {
      "transitions": [
        {
          "name": "schedule_dispatch",
          "next": "DELIVERING",
          "manual": false,
          "processors": [
            {
              "name": "ScheduleNotificationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DELIVERING": {
      "transitions": [
        {
          "name": "delivery_success",
          "next": "DELIVERED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DeliverySuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "delivery_failure",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DeliveryFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "DELIVERED": {
      "transitions": [
        {
          "name": "audit_after_delivery",
          "next": "AUDIT",
          "manual": false,
          "processors": [
            {
              "name": "AuditProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "FAILED": {
      "transitions": [
        {
          "name": "allow_retry",
          "next": "RETRYING",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "NotificationRetryCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "give_up",
          "next": "AUDIT",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "NotificationGiveUpCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "RETRYING": {
      "transitions": [
        {
          "name": "retry_exhausted",
          "next": "AUDIT",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "RetryExhaustedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "AUDIT": {
      "transitions": []
    }
  }
}