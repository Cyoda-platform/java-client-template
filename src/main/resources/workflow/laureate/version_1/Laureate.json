{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity handling validation and enrichment",
  "initialState": "validation",
  "active": true,
  "states": {
    "validation": {
      "transitions": [
        {
          "name": "validate_fields",
          "next": "enrichment",
          "manual": false,
          "processors": [
            {
              "name": "LaureateValidationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "enrichment": {
      "transitions": [
        {
          "name": "enrich_data",
          "next": "persisted",
          "manual": false,
          "processors": [
            {
              "name": "LaureateEnrichmentProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "persisted": {
      "transitions": []
    }
  }
}
