{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Finite-state workflow for Laureate entity based on functional requirements: validation, enrichment, persistence, and rejection handling.",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "persist_laureate_event",
          "next": "PERSISTED",
          "manual": false
        }
      ]
    },
    "PERSISTED": {
      "transitions": [
        {
          "name": "validate_laureate",
          "next": "VALIDATED",
          "manual": false,
          "processors": [
            {
              "name": "ValidateLaureateProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATED": {
      "transitions": [
        {
          "name": "to_enrich_on_valid",
          "next": "ENRICHED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          },
          "processors": [
            {
              "name": "EnrichLaureateProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "to_rejected_on_failure",
          "next": "REJECTED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ENRICHED": {
      "transitions": [
        {
          "name": "persist_after_enrichment",
          "next": "PERSISTED_FINAL",
          "manual": false
        }
      ]
    },
    "PERSISTED_FINAL": {
      "transitions": []
    },
    "REJECTED": {
      "transitions": []
    }
  }
}