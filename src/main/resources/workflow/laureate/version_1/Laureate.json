{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity covering enrichment, matching, notification scheduling and audit",
  "initialState": "PERSISTED",
  "active": true,
  "states": {
    "PERSISTED": {
      "transitions": [
        {
          "name": "start_enrichment",
          "next": "ENRICHING",
          "manual": false
        }
      ]
    },
    "ENRICHING": {
      "transitions": [
        {
          "name": "enrich_complete",
          "next": "MATCHING",
          "manual": false,
          "processors": [
            {
              "name": "EnrichmentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "MATCHING": {
      "transitions": [
        {
          "name": "matches_found",
          "next": "SCHEDULING",
          "manual": false,
          "processors": [
            {
              "name": "MatchingProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "no_matches",
          "next": "AUDIT",
          "manual": false
        }
      ]
    },
    "SCHEDULING": {
      "transitions": [
        {
          "name": "schedule_notifications",
          "next": "DELIVERING",
          "manual": false,
          "processors": [
            {
              "name": "ScheduleNotificationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DELIVERING": {
      "transitions": [
        {
          "name": "delivery_success",
          "next": "AUDIT",
          "manual": false,
          "processors": [
            {
              "name": "NotificationDispatchProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "delivery_failed",
          "next": "RETRYING",
          "manual": false
        }
      ]
    },
    "RETRYING": {
      "transitions": [
        {
          "name": "retry_attempt",
          "next": "DELIVERING",
          "manual": false,
          "processors": [
            {
              "name": "NotificationRetryProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "retry_exhausted",
          "next": "AUDIT",
          "manual": false
        }
      ]
    },
    "AUDIT": {
      "transitions": []
    }
  }
}