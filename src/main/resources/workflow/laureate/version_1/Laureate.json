{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow that manages Laureate lifecycle: import, validate, enrich, deduplicate and store.",
  "initialState": "IMPORTED",
  "active": true,
  "states": {
    "IMPORTED": {
      "transitions": [
        {
          "name": "import_to_validating",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "LaureatePersistenceProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_failed",
          "next": "INVALID",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "LaureateValidationFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_passed",
          "next": "ENRICHING",
          "manual": false,
          "processors": [
            {
              "name": "LaureateEnrichmentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "INVALID": {
      "transitions": [
        {
          "name": "send_to_review",
          "next": "REVIEW",
          "manual": true
        }
      ]
    },
    "ENRICHING": {
      "transitions": [
        {
          "name": "enrich_to_dedup",
          "next": "DEDUP_CHECK",
          "manual": false,
          "processors": [
            {
              "name": "LaureateDedupMergeProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DEDUP_CHECK": {
      "transitions": [
        {
          "name": "dedup_to_stored",
          "next": "STORED",
          "manual": false,
          "processors": [
            {
              "name": "LaureateNotificationEmitter",
              "config": {
                "calculationNodesTags": "cyoda_application",
                "executionMode": "ASYNC_SAME_TX"
              }
            }
          ]
        }
      ]
    },
    "REVIEW": {
      "transitions": [
        {
          "name": "reviewed_to_enrich",
          "next": "ENRICHING",
          "manual": false,
          "processors": [
            {
              "name": "LaureateEnrichmentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "STORED": {
      "transitions": []
    }
  }
}