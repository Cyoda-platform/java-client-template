{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity based on functional requirements: validation, deduplication/normalization, enrichment and publication with rejection on missing required fields.",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "init_to_raw",
          "next": "RAW",
          "manual": false
        }
      ]
    },
    "RAW": {
      "transitions": [
        {
          "name": "raw_to_validating",
          "next": "VALIDATING",
          "manual": false,
          "processors": [
            {
              "name": "LaureateValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATING": {
      "transitions": [
        {
          "name": "validation_success",
          "next": "VALIDATED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidationSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_missing_fields",
          "next": "REJECTED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "MissingRequiredFieldsCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "VALIDATED": {
      "transitions": [
        {
          "name": "validated_to_deduped_and_enrich",
          "next": "DEDUPED",
          "manual": false,
          "processors": [
            {
              "name": "ProcessingPipelineProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DEDUPED": {
      "transitions": [
        {
          "name": "deduped_to_enriched",
          "next": "ENRICHED",
          "manual": false
        }
      ]
    },
    "ENRICHED": {
      "transitions": [
        {
          "name": "enriched_to_published",
          "next": "PUBLISHED",
          "manual": false
        }
      ]
    },
    "PUBLISHED": {
      "transitions": []
    },
    "REJECTED": {
      "transitions": []
    }
  }
}