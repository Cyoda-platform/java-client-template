{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for Laureate entity: validation, enrichment, deduplication and persistence as defined in functional requirements.",
  "initialState": "initial_state",
  "active": true,
  "states": {
    "initial_state": {
      "transitions": [
        {
          "name": "initial_to_persisted",
          "next": "PERSISTED",
          "manual": false
        }
      ]
    },
    "PERSISTED": {
      "transitions": [
        {
          "name": "persisted_to_validated",
          "next": "VALIDATED",
          "manual": false,
          "processors": [
            {
              "name": "ValidationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATED": {
      "transitions": [
        {
          "name": "validated_to_enriched",
          "next": "ENRICHED",
          "manual": false,
          "processors": [
            {
              "name": "EnrichmentProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "ENRICHED": {
      "transitions": [
        {
          "name": "enriched_to_deduplicated",
          "next": "DEDUPLICATED",
          "manual": false,
          "processors": [
            {
              "name": "DeduplicationProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "DEDUPLICATED": {
      "transitions": [
        {
          "name": "deduplicated_to_stored",
          "next": "STORED",
          "manual": false,
          "processors": [
            {
              "name": "PersistenceProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "deduplication_failed",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "DeduplicationFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "STORED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}