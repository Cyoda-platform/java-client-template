{
  "desc": "Workflow for processing Pet entity lifecycle events",
  "id": "pet_workflow",
  "initialState": "none",
  "name": "Pet entity workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "transition_to_validation",
          "next": "validate_pet",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "e9df0d46-65c9-11b2-965a-2e0ad7d884c5"
              },
              "name": "PetProcessor"
            }
          ]
        }
      ]
    },
    "validate_pet": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetValidCriterion"
            },
            "type": "function"
          },
          "id": "valid_pet_transition",
          "next": "enrich_pet"
        },
        {
          "id": "invalid_pet_transition",
          "next": "end_invalid"
        }
      ]
    },
    "enrich_pet": {
      "transitions": [
        {
          "id": "enrich_and_route",
          "next": "create_pet_event"
        }
      ]
    },
    "create_pet_event": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetAvailableCriterion"
            },
            "type": "function"
          },
          "id": "created_event_transition",
          "next": "end_created"
        },
        {
          "criterion": {
            "function": {
              "name": "PetAdoptedCriterion"
            },
            "type": "function"
          },
          "id": "adopted_event_transition",
          "next": "end_adopted"
        },
        {
          "id": "updated_event_transition",
          "next": "end_updated"
        }
      ]
    },
    "end_created": {
      "transitions": []
    },
    "end_adopted": {
      "transitions": []
    },
    "end_updated": {
      "transitions": []
    },
    "end_invalid": {
      "transitions": []
    }
  },
  "version": "1.0"
}