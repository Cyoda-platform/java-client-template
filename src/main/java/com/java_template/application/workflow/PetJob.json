{
    "desc": "Workflow managing PetJob lifecycle from submission to completion or failure",
    "id": "petjob_workflow",
    "initialState": "none",
    "name": "PetJob workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "start_processing",
                    "next": "pending",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetJobProcessor"
                        }
                    ]
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "HasValidJobTypeAndPayloadCriterion"
                        },
                        "type": "function"
                    },
                    "id": "validate_job_type_and_payload",
                    "next": "processing"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "InvalidJobTypeOrPayloadCriterion"
                        },
                        "type": "function"
                    },
                    "id": "invalid_job_type_or_payload",
                    "next": "failed"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "IsAddPetJobTypeCriterion"
                        },
                        "type": "function"
                    },
                    "id": "process_add_pet",
                    "next": "completed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "UnsupportedJobTypeCriterion"
                        },
                        "type": "function"
                    },
                    "id": "unsupported_job_type",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}