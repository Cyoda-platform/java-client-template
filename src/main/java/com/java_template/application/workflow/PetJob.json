{
  "desc": "Workflow for processing PetJob lifecycle and related PetEvent",
  "id": "petjob_workflow",
  "initialState": "none",
  "name": "PetJob workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "start_to_pending",
          "next": "pending"
        }
      ]
    },
    "pending": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetJobValidCriterion"
            },
            "type": "function"
          },
          "id": "pending_to_processing_valid",
          "next": "processing"
        },
        {
          "criterion": {
            "function": {
              "name": "PetJobInvalidCriterion"
            },
            "type": "function"
          },
          "id": "pending_to_failed_invalid",
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "id": "processing_to_completed_success",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "52e21216-64e9-11b2-965a-2e0ad7d884c5"
              },
              "name": "PetJobProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "name": "PetJobProcessingFailedCriterion"
            },
            "type": "function"
          },
          "id": "processing_to_failed_error",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}