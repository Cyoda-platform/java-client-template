{
    "desc": "Workflow for processing Pet entities on persistence events",
    "id": "pet_workflow",
    "initialState": "none",
    "name": "Pet entity workflow",
    "states": {
        "check_status": {
            "transitions": [
                {
                    "criterion": {
                        "class": "PetStatusNewOrAvailableCriterion",
                        "type": "class"
                    },
                    "id": "transition_status_new_or_available",
                    "next": "validate_pet"
                },
                {
                    "id": "transition_status_other",
                    "next": "skip_processing"
                }
            ]
        },
        "completed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "transition_to_check_status",
                    "next": "check_status"
                }
            ]
        },
        "process_pet": {
            "transitions": [
                {
                    "id": "transition_pet_processed",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetJobProcessor"
                        }
                    ]
                }
            ]
        },
        "skip_processing": {
            "transitions": []
        },
        "validate_pet": {
            "transitions": [
                {
                    "criterion": {
                        "class": "PetValidityCriterion",
                        "type": "class"
                    },
                    "id": "transition_pet_valid",
                    "next": "process_pet"
                },
                {
                    "id": "transition_pet_invalid",
                    "next": "validation_failed"
                }
            ]
        },
        "validation_failed": {
            "transitions": []
        }
    },
    "version": "1.0"
}