{
    "description": "Workflow FSM for PurrfectPetsJob entity lifecycle",
    "initial_state": "none",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "invalid_operation_type": {
                        "criterion": {
                            "function": {
                                "name": "OperationTypeInvalidCriterion"
                            },
                            "type": "function"
                        },
                        "next": "failed"
                    },
                    "validate_operation_type": {
                        "criterion": {
                            "function": {
                                "name": "OperationTypeValidCriterion"
                            },
                            "type": "function"
                        },
                        "next": "pending"
                    }
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "start_processing_transition": {
                        "next": "processing",
                        "processors": [
                            {
                                "name": "PurrfectPetsJobProcessor"
                            }
                        ]
                    }
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "complete_transition": {
                        "criterion": {
                            "function": {
                                "name": "JobCompletedCriterion"
                            },
                            "type": "function"
                        },
                        "next": "completed"
                    },
                    "fail_transition": {
                        "criterion": {
                            "function": {
                                "name": "JobFailedCriterion"
                            },
                            "type": "function"
                        },
                        "next": "failed"
                    }
                }
            ]
        }
    },
    "version": "1.0",
    "workflow_name": "purrfect_pets_job_workflow"
}