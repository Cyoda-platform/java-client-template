{
    "desc": "Workflow for processing PurrfectPetsJob entities with validation and processing steps",
    "id": "purrfectpetsjob_workflow",
    "initialState": "none",
    "name": "PurrfectPetsJob workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "start_validation",
                    "next": "pending_validation"
                }
            ]
        },
        "pending_validation": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PurrfectPetsJobValidJobTypeCriterion"
                        },
                        "type": "function"
                    },
                    "id": "valid_job_type",
                    "next": "processing"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PurrfectPetsJobInvalidJobTypeCriterion"
                        },
                        "type": "function"
                    },
                    "id": "invalid_job_type",
                    "next": "failed"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PurrfectPetsJobIsPetDataSyncCriterion"
                        },
                        "type": "function"
                    },
                    "id": "process_pet_data_sync",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PurrfectPetsJobProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PurrfectPetsJobIsAdoptionProcessingCriterion"
                        },
                        "type": "function"
                    },
                    "id": "process_adoption_requests",
                    "next": "completed",
                    "processors": [
                        {
                            "name": "PurrfectPetsJobProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PurrfectPetsJobProcessingFailedCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_error",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}