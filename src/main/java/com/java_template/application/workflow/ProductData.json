{
  "active": true,
  "desc": "Workflow for processing ProductPerformanceJob from creation to completion",
  "initialState": "none",
  "name": "ProductPerformanceJob Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "validating"
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "JobValidationCriterion"
            },
            "type": "function"
          },
          "name": "validation_passed",
          "next": "extracting_data"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "JobValidationFailedCriterion"
            },
            "type": "function"
          },
          "name": "validation_failed",
          "next": "failed"
        }
      ]
    },
    "extracting_data": {
      "transitions": [
        {
          "name": "data_extracted",
          "next": "analyzing_data",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "ProductDataProcessor"
            }
          ]
        }
      ]
    },
    "analyzing_data": {
      "transitions": [
        {
          "name": "analysis_completed",
          "next": "generating_report"
        }
      ]
    },
    "generating_report": {
      "transitions": [
        {
          "name": "report_generated",
          "next": "sending_email"
        }
      ]
    },
    "sending_email": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "EmailSentSuccessCriterion"
            },
            "type": "function"
          },
          "name": "email_sent_success",
          "next": "completed"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "EmailSentFailureCriterion"
            },
            "type": "function"
          },
          "name": "email_sent_failure",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}