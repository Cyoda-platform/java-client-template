{
  "active": true,
  "desc": "Workflow representing the lifecycle and validation of a Pet entity",
  "initialState": "none",
  "name": "Pet Processing Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "PetDataValidCriterion"
            },
            "type": "function"
          },
          "name": "start_validation",
          "next": "validating"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "PetDataInvalidCriterion"
            },
            "type": "function"
          },
          "name": "start_invalid_data",
          "next": "invalid_data"
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "PetStatusValidCriterion"
            },
            "type": "function"
          },
          "name": "valid_status",
          "next": "processing"
        },
        {
          "name": "invalid_status",
          "next": "processing"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "name": "save_pet",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "PetProcessor"
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "invalid_data": {
      "transitions": []
    }
  },
  "version": "1.0"
}