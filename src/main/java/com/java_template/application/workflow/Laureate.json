{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow managing the processing and validation of Laureate entities",
  "initialState": "validation",
  "active": true,
  "states": {
    "validation": {
      "transitions": [
        {
          "name": "enrich_and_persist",
          "next": "persisted",
          "manual": false,
          "processors": [
            {
              "name": "LaureateValidationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            },
            {
              "name": "LaureateEnrichmentProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "persisted": {
      "transitions": []
    }
  }
}
