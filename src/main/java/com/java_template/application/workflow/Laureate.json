{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for validating and persisting Laureate entities.",
  "initialState": "validation",
  "active": true,
  "states": {
    "validation": {
      "transitions": [
        {
          "name": "validation_passed",
          "next": "enrichment",
          "manual": false,
          "processors": [
            {
              "name": "LaureateValidationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "enrichment": {
      "transitions": [
        {
          "name": "enrich_data",
          "next": "persistence",
          "manual": false,
          "processors": [
            {
              "name": "LaureateEnrichmentProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "persistence": {
      "transitions": []
    }
  }
}
