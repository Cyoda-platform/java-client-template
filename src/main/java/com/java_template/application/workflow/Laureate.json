{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for validation, enrichment, and persistence of Laureate entities.",
  "initialState": "validation",
  "active": true,
  "states": {
    "validation": {
      "transitions": [
        {
          "name": "validate_success",
          "next": "enrichment",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "LaureateValidationSuccessCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          }
        },
        {
          "name": "validate_failure",
          "next": "validation_failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "LaureateValidationFailureCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          }
        }
      ]
    },
    "enrichment": {
      "transitions": [
        {
          "name": "enrich_data",
          "next": "persistence",
          "manual": false,
          "processors": [
            {
              "name": "LaureateEnrichmentProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "persistence": {
      "transitions": [
        {
          "name": "persist_entity",
          "next": "completed",
          "manual": false,
          "processors": [
            {
              "name": "LaureatePersistenceProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "validation_failed": {
      "transitions": []
    }
  }
}
