{
  "version": "1.0",
  "name": "Laureate Workflow",
  "desc": "Workflow for processing Laureate entity validation and enrichment",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_and_enrich",
          "next": "processed",
          "manual": false,
          "processors": [
            {
              "name": "LaureateProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "processed": {
      "transitions": []
    }
  }
}
