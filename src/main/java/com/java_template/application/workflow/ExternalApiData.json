{
    "active": true,
    "desc": "Workflow for processing DigestRequestJob from creation to completion or failure",
    "initialState": "none",
    "name": "DigestRequestJob Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "fetching_api_data": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "ExternalApiCallSuccessCriterion"
                        },
                        "type": "function"
                    },
                    "name": "api_call_success",
                    "next": "preparing_email"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "ExternalApiCallFailureCriterion"
                        },
                        "type": "function"
                    },
                    "name": "api_call_failure",
                    "next": "failed"
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "name": "start_to_validating",
                    "next": "validating"
                }
            ]
        },
        "preparing_email": {
            "transitions": [
                {
                    "name": "email_compiled",
                    "next": "sending_email"
                },
                {
                    "name": "email_compilation_failed",
                    "next": "failed"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "name": "call_external_api",
                    "next": "fetching_api_data",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "ExternalApiDataProcessor"
                        }
                    ]
                }
            ]
        },
        "sending_email": {
            "transitions": [
                {
                    "name": "email_sent",
                    "next": "completed"
                },
                {
                    "name": "email_send_failed",
                    "next": "failed"
                }
            ]
        },
        "validating": {
            "transitions": [
                {
                    "name": "job_valid",
                    "next": "processing"
                },
                {
                    "name": "job_invalid",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}