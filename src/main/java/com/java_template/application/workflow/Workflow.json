{
  "version": "1.0",
  "name": "Workflow Workflow",
  "desc": "Workflow to manage the lifecycle of a workflow entity",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_fields",
          "next": "validated",
          "manual": false
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "process_pet_and_adoption",
          "next": "processing",
          "manual": false
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "name": "complete_workflow",
          "next": "completed",
          "manual": false
        },
        {
          "name": "fail_workflow",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "WorkflowFailCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}