{
  "version": "1.0",
  "name": "Workflow Workflow",
  "desc": "Workflow entity orchestration process",
  "initialState": "pending",
  "active": true,
  "states": {
    "pending": {
      "transitions": [
        {
          "name": "validate_pet_availability",
          "next": "validating",
          "manual": false
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "check_pet_and_request_validity",
          "next": "processing",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "WorkflowValidationCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "fail_validation",
          "next": "failed",
          "manual": false
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "name": "trigger_adoption_steps",
          "next": "completed",
          "manual": false,
          "processors": [
            {
              "name": "AdoptionStepProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": [
        {
          "name": "send_confirmation",
          "next": "done",
          "manual": false
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "send_failure_notification",
          "next": "done",
          "manual": false
        }
      ]
    },
    "done": {
      "transitions": []
    }
  }
}
