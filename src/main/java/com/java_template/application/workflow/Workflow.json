{
  "active": true,
  "desc": "Workflow to process Order entity through validation and completion",
  "initialState": "none",
  "name": "Order Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "validate_quantity"
        }
      ]
    },
    "validate_quantity": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsQuantityValid"
            },
            "type": "function"
          },
          "name": "quantity_valid",
          "next": "validate_pet_availability"
        },
        {
          "name": "quantity_invalid",
          "next": "failed"
        }
      ]
    },
    "validate_pet_availability": {
      "transitions": [
        {
          "name": "pet_available",
          "next": "process_order"
        },
        {
          "name": "pet_not_available",
          "next": "failed"
        }
      ]
    },
    "process_order": {
      "transitions": [
        {
          "name": "complete_order",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "PetProcessor"
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}