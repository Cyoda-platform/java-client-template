{
  "active": true,
  "desc": "Workflow for processing WeeklyCatFactJob entity from creation to completion or failure",
  "initialState": "none",
  "name": "WeeklyCatFactJob Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "manual": false,
          "name": "start_processing",
          "next": "processing"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "manual": false,
          "name": "process_cat_fact_job",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "CatFactProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "JobFailedCriterion"
            },
            "type": "function"
          },
          "manual": false,
          "name": "process_failed",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
