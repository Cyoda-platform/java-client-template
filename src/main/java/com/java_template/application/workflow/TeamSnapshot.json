{
  "active": true,
  "desc": "Workflow for processing SnapshotJob through validation, processing, change detection and completion states",
  "initialState": "validating",
  "name": "SnapshotJob Workflow",
  "states": {
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "SnapshotJobValidationCriterion"
            },
            "type": "function"
          },
          "name": "validation_passed",
          "manual": false,
          "next": "processing"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "SnapshotJobValidationFailedCriterion"
            },
            "type": "function"
          },
          "name": "validation_failed",
          "manual": false,
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "SnapshotJobProcessingSuccessCriterion"
            },
            "type": "function"
          },
          "name": "processing_success",
          "manual": false,
          "next": "change_detection",
          "processors": [
            {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "TeamSnapshotProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "SnapshotJobProcessingFailedCriterion"
            },
            "type": "function"
          },
          "name": "processing_failed",
          "manual": false,
          "next": "failed"
        }
      ]
    },
    "change_detection": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ChangeDetectionSuccessCriterion"
            },
            "type": "function"
          },
          "name": "change_detection_success",
          "manual": false,
          "next": "completed"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ChangeDetectionFailedCriterion"
            },
            "type": "function"
          },
          "name": "change_detection_failed",
          "manual": false,
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}