{
  "version": "1.0",
  "name": "MailingList Workflow",
  "desc": "Workflow for MailingList validation and activation",
  "initialState": "CREATED",
  "active": true,
  "states": {
    "CREATED": {
      "transitions": [
        {
          "name": "validate_list",
          "next": "VALIDATED",
          "manual": false,
          "processors": [
            {
              "name": "ValidateMailingListProcessor",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "VALIDATED": {
      "transitions": [
        {
          "name": "to_active",
          "next": "ACTIVE",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "RecipientCountCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "to_inactive",
          "next": "INACTIVE",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "NoRecipientsCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "ACTIVE": {
      "transitions": []
    },
    "INACTIVE": {
      "transitions": []
    }
  }
}