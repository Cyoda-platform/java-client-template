{
    "desc": "Workflow representing the life cycle of an AdoptionRequest entity",
    "id": "adoption_request_workflow",
    "initialState": "none",
    "name": "Adoption Request Workflow",
    "states": {
        "approved": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "start_to_pending",
                    "next": "pending"
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetDoesNotExistCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pending_to_rejected_pet_not_found",
                    "next": "rejected"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetExistsCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pending_to_valid_pet_exists",
                    "next": "valid_pet_exists"
                }
            ]
        },
        "pet_available": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "RequesterIsNotValidCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pet_available_to_rejected_invalid_requester",
                    "next": "rejected"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "RequesterIsValidCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pet_available_to_approved",
                    "next": "approved",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetProcessor"
                        }
                    ]
                }
            ]
        },
        "rejected": {
            "transitions": []
        },
        "valid_pet_exists": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetIsNotAvailableCriterion"
                        },
                        "type": "function"
                    },
                    "id": "valid_pet_to_rejected_not_available",
                    "next": "rejected"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetIsAvailableCriterion"
                        },
                        "type": "function"
                    },
                    "id": "valid_pet_to_pet_available",
                    "next": "pet_available"
                }
            ]
        }
    },
    "version": "1.0"
}