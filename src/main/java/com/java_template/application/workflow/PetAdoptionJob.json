{
    "desc": "Workflow for processing pet adoption jobs from creation to completion or failure",
    "id": "pet_adoption_job_workflow",
    "initialState": "none",
    "name": "Pet Adoption Job Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "start_processing",
                    "next": "pending",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetAdoptionJobProcessor"
                        }
                    ]
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "id": "pending_to_processing",
                    "next": "processing"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetAvailabilityCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_to_completed",
                    "next": "completed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetNotFoundCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_to_failed_not_found",
                    "next": "failed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetNotAvailableCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_to_failed_not_available",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}