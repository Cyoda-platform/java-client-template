{
  "active": true,
  "desc": "Workflow for processing DigestRequestJob entity through validation, external API call, email compilation, sending and completion states.",
  "initialState": "none",
  "name": "DigestRequestJob Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "validating"
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "valid_job",
          "next": "processing"
        },
        {
          "name": "invalid_job",
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "name": "call_external_api",
          "next": "fetching_api_data",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "DigestEmailProcessor"
            }
          ]
        }
      ]
    },
    "fetching_api_data": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ExternalApiCallSuccessCriterion"
            },
            "type": "function"
          },
          "name": "api_call_success",
          "next": "preparing_email"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ExternalApiCallFailureCriterion"
            },
            "type": "function"
          },
          "name": "api_call_failure",
          "next": "failed"
        }
      ]
    },
    "preparing_email": {
      "transitions": [
        {
          "name": "email_compiled",
          "next": "sending_email"
        },
        {
          "name": "email_compilation_failed",
          "next": "failed"
        }
      ]
    },
    "sending_email": {
      "transitions": [
        {
          "name": "email_sent",
          "next": "completed"
        },
        {
          "name": "email_send_failed",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}