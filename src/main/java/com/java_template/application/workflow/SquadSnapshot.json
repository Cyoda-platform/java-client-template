{
  "active": true,
  "desc": "Workflow managing the lifecycle of SquadSnapshot entity",
  "initialState": "pending",
  "name": "SquadSnapshotWorkflow",
  "states": {
    "pending": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsValidSquadSnapshot"
            },
            "type": "function"
          },
          "name": "validate_squad_snapshot_success",
          "manual": false,
          "next": "valid"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsInvalidSquadSnapshot"
            },
            "type": "function"
          },
          "name": "validate_squad_snapshot_fail",
          "manual": false,
          "next": "failed"
        }
      ]
    },
    "valid": {
      "transitions": [
        {
          "name": "valid_to_inProgress",
          "manual": false,
          "next": "inProgress"
        }
      ]
    },
    "inProgress": {
      "transitions": [
        {
          "name": "process_snapshots",
          "manual": false,
          "next": "detectChanges",
          "processors": [
            {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "manual": false,
              "name": "SquadSnapshotProcessor"
            }
          ]
        }
      ]
    },
    "detectChanges": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "SquadSnapshotChangesDetected"
            },
            "type": "function"
          },
          "name": "changes_detected",
          "manual": false,
          "next": "changesDetected"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "SquadSnapshotNoChanges"
            },
            "type": "function"
          },
          "name": "no_changes_detected",
          "manual": false,
          "next": "noChanges"
        }
      ]
    },
    "changesDetected": {
      "transitions": [
        {
          "name": "notify_and_complete",
          "manual": true,
          "next": "completed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "noChanges": {
      "transitions": [
        {
          "name": "complete_without_changes",
          "manual": true,
          "next": "completed"
        }
      ]
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}