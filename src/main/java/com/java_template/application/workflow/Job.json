{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow that manages the lifecycle of a Job entity including scheduling, processing, and notifying subscribers.",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "validate_job",
          "next": "validating",
          "manual": false
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "validation_success",
          "next": "processing",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationSuccessCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          }
        },
        {
          "name": "validation_failure",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobValidationFailureCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          }
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "name": "ingest_data",
          "next": "completed_ingestion",
          "manual": false,
          "processors": [
            {
              "name": "JobIngestionProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "completed_ingestion": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notifying_subscribers",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberNotificationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "notifying_subscribers": {
      "transitions": [
        {
          "name": "mark_notified",
          "next": "notified_subscribers",
          "manual": false
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}
