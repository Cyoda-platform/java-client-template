{
  "version": "1.0",
  "name": "Job Workflow",
  "desc": "Workflow for Job entity managing ingestion job lifecycle",
  "initialState": "scheduled",
  "active": true,
  "states": {
    "scheduled": {
      "transitions": [
        {
          "name": "start_ingesting",
          "next": "ingesting",
          "manual": false
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "name": "complete_success",
          "next": "succeeded",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobSucceededCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "complete_failure",
          "next": "failed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "JobFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false
        }
      ]
    },
    "failed": {
      "transitions": [
        {
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "manual": false
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    }
  }
}
