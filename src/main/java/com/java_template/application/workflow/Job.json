{
  "active": true,
  "desc": "Workflow managing the lifecycle of Job ingestion and notification process",
  "initialState": "none",
  "name": "Job Workflow",
  "states": {
    "failed": {
      "transitions": [
        {
          "manual": false,
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "NotifySubscribersProcessor"
            }
          ]
        }
      ]
    },
    "ingesting": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "JobSuccessCriterion"
            },
            "type": "function"
          },
          "manual": false,
          "name": "process_laureates_success",
          "next": "succeeded"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "JobFailureCriterion"
            },
            "type": "function"
          },
          "manual": false,
          "name": "process_laureates_failure",
          "next": "failed"
        }
      ]
    },
    "notified_subscribers": {
      "transitions": []
    },
    "scheduled": {
      "transitions": [
        {
          "manual": false,
          "name": "start_ingestion",
          "next": "ingesting"
        }
      ]
    },
    "succeeded": {
      "transitions": [
        {
          "manual": false,
          "name": "notify_subscribers",
          "next": "notified_subscribers",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "NotifySubscribersProcessor"
            }
          ]
        }
      ]
    }
  },
  "version": "1.0"
}