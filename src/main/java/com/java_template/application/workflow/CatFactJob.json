{
  "desc": "Workflow for processing CatFactJob entities",
  "id": "catfactjob_workflow",
  "initialState": "none",
  "name": "CatFactJob workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "start_from_none",
          "next": "PENDING"
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "IsPendingCriterion"
            },
            "type": "function"
          },
          "id": "start_processing_transition",
          "next": "PROCESSING",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "aaa7ded4-2f5d-11b2-944c-fac101f95347"
              },
              "name": "CatFactJobProcessor"
            }
          ]
        }
      ]
    },
    "PROCESSING": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "IsSuccessCriterion"
            },
            "type": "function"
          },
          "id": "processing_to_completed",
          "next": "COMPLETED"
        },
        {
          "criterion": {
            "function": {
              "name": "IsFailedCriterion"
            },
            "type": "function"
          },
          "id": "processing_to_failed",
          "next": "FAILED"
        }
      ]
    },
    "COMPLETED": {
      "transitions": [
        {
          "id": "end_completed",
          "next": "final"
        }
      ]
    },
    "final": {
      "transitions": []
    },
    "FAILED": {
      "transitions": [
        {
          "id": "end_failed",
          "next": "final"
        }
      ]
    }
  },
  "version": "1.0"
}