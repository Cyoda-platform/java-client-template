{
    "active": true,
    "desc": "Workflow representing the order processing lifecycle",
    "initialState": "none",
    "name": "Order Workflow",
    "states": {
        "confirmed": {
            "transitions": [
                {
                    "name": "end_process",
                    "next": "final"
                }
            ]
        },
        "failed": {
            "transitions": [
                {
                    "name": "end_process",
                    "next": "final"
                }
            ]
        },
        "final": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "name": "start_validation",
                    "next": "validating"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "OrderProcessingSuccessCriterion"
                        },
                        "type": "function"
                    },
                    "name": "processing_succeeded",
                    "next": "confirmed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "OrderProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "OrderProcessingFailedCriterion"
                        },
                        "type": "function"
                    },
                    "name": "processing_failed",
                    "next": "failed"
                }
            ]
        },
        "validating": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "OrderValidCriterion"
                        },
                        "type": "function"
                    },
                    "name": "validation_passed",
                    "next": "processing"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "OrderInvalidCriterion"
                        },
                        "type": "function"
                    },
                    "name": "validation_failed",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}