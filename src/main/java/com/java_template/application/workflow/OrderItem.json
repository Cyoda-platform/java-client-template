{
  "active": true,
  "desc": "Workflow representing the order processing lifecycle",
  "initialState": "none",
  "name": "Order Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "start_validation",
          "next": "validating"
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "OrderValidCriterion"
            },
            "type": "function"
          },
          "name": "validation_passed",
          "next": "processing"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "OrderInvalidCriterion"
            },
            "type": "function"
          },
          "name": "validation_failed",
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "OrderProcessingSuccessCriterion"
            },
            "type": "function"
          },
          "name": "processing_succeeded",
          "next": "confirmed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "OrderProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "OrderProcessingFailedCriterion"
            },
            "type": "function"
          },
          "name": "processing_failed",
          "next": "failed"
        }
      ]
    },
    "confirmed": {
      "transitions": [
        {
          "name": "end_process",
          "next": "final"
        }
      ]
    },
    "final": {
      "transitions": []
    },
    "failed": {
      "transitions": [
        {
          "name": "end_process",
          "next": "final"
        }
      ]
    }
  },
  "version": "1.0"
}