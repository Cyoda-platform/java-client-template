{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Workflow for Subscriber entity validation and persistence",
  "initialState": "validation",
  "active": true,
  "states": {
    "validation": {
      "transitions": [
        {
          "name": "validate_success",
          "next": "persisted",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "SubscriberValidationSuccessCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          },
          "processors": [
            {
              "name": "ValidateSubscriberProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        },
        {
          "name": "validate_failure",
          "next": "invalid",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "SubscriberValidationFailureCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "persisted": {
      "transitions": []
    },
    "invalid": {
      "transitions": []
    }
  }
}
