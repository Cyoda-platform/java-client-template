{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Workflow to process subscriber entity creation and validation",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_and_activate",
          "next": "active",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberValidationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "active": {
      "transitions": []
    }
  }
}
