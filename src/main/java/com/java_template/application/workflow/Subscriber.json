{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Workflow to validate and persist Subscriber entities",
  "initialState": "validation",
  "active": true,
  "states": {
    "validation": {
      "transitions": [
        {
          "name": "validate_contact",
          "next": "persistence",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberValidationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "persistence": {
      "transitions": []
    }
  }
}
