{
  "version": "1.0",
  "name": "Subscriber Workflow",
  "desc": "Workflow managing the validation and persistence of Subscriber entities",
  "initialState": "validation",
  "active": true,
  "states": {
    "validation": {
      "transitions": [
        {
          "name": "persist_subscriber",
          "next": "persisted",
          "manual": false,
          "processors": [
            {
              "name": "SubscriberValidationProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "persisted": {
      "transitions": []
    }
  }
}
