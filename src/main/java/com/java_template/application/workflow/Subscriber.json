{
  "active": true,
  "desc": "Workflow for processing subscriber entity from creation to completion",
  "initialState": "none",
  "name": "Subscriber Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "manual": false,
          "name": "start_validation",
          "next": "validating"
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "EmailInvalidOrNotUnique"
            },
            "type": "function"
          },
          "manual": false,
          "name": "email_invalid_or_not_unique",
          "next": "failed"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "EmailValidAndUnique"
            },
            "type": "function"
          },
          "manual": false,
          "name": "email_valid_and_unique",
          "next": "processing"
        }
      ]
    },
    "failed": {
      "transitions": []
    },
    "processing": {
      "transitions": [
        {
          "manual": false,
          "name": "persist_success",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "SubscriberProcessor"
            }
          ]
        },
        {
          "manual": false,
          "name": "persist_failure",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    }
  },
  "version": "1.0"
}