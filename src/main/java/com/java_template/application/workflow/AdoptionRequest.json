{
  "version": "1.0",
  "name": "AdoptionRequest Workflow",
  "desc": "Workflow to manage the lifecycle of AdoptionRequest entity",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_adoption_request",
          "next": "validated",
          "manual": false
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "verify_user_eligibility",
          "next": "verified",
          "manual": false
        }
      ]
    },
    "verified": {
      "transitions": [
        {
          "name": "approve_request",
          "next": "approved",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "AdoptionApprovalCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "reject_request",
          "next": "rejected",
          "manual": false
        }
      ]
    },
    "approved": {
      "transitions": []
    },
    "rejected": {
      "transitions": []
    }
  }
}