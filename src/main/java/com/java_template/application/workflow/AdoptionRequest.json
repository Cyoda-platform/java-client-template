{
    "desc": "Workflow to manage pet adoption job processing from creation to completion or failure.",
    "id": "pet_adoption_job_workflow",
    "initialState": "none",
    "name": "Pet Adoption Job Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "start_processing",
                    "next": "processing",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "AdoptionRequestProcessor"
                        }
                    ]
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetFoundAndAvailableCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pet_found_and_available",
                    "next": "completed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetNotFoundOrUnavailableCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pet_not_found_or_unavailable",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}