{
  "desc": "Workflow managing adoption request lifecycle from creation to approval or rejection",
  "id": "adoption_request_workflow",
  "initialState": "none",
  "name": "Adoption Request Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "start_to_validate_pet_exists",
          "next": "validate_pet_exists"
        }
      ]
    },
    "validate_pet_exists": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "DoesPetExistCriterion"
            },
            "type": "function"
          },
          "id": "pet_exists_transition",
          "next": "validate_pet_available"
        },
        {
          "criterion": {
            "function": {
              "name": "DoesPetNotExistCriterion"
            },
            "type": "function"
          },
          "id": "pet_not_exists_transition",
          "next": "reject_request"
        }
      ]
    },
    "validate_pet_available": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "IsPetAvailableCriterion"
            },
            "type": "function"
          },
          "id": "pet_available_transition",
          "next": "validate_requester_info"
        },
        {
          "criterion": {
            "function": {
              "name": "IsPetNotAvailableCriterion"
            },
            "type": "function"
          },
          "id": "pet_not_available_transition",
          "next": "reject_request"
        }
      ]
    },
    "validate_requester_info": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "IsRequesterInfoValidCriterion"
            },
            "type": "function"
          },
          "id": "requester_info_valid_transition",
          "next": "approve_request"
        },
        {
          "criterion": {
            "function": {
              "name": "IsRequesterInfoInvalidCriterion"
            },
            "type": "function"
          },
          "id": "requester_info_invalid_transition",
          "next": "reject_request"
        }
      ]
    },
    "approve_request": {
      "transitions": [
        {
          "id": "approve_to_completed",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "931db586-65d1-11b2-95b2-ca2f093e3d5b"
              },
              "name": "AdoptionRequestProcessor"
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "reject_request": {
      "transitions": [
        {
          "id": "reject_to_completed",
          "next": "completed"
        }
      ]
    }
  },
  "version": "1.0"
}