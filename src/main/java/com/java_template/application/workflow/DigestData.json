{
  "active": true,
  "desc": "Workflow for processing DigestRequest through DigestData and EmailDispatch",
  "initialState": "none",
  "name": "DigestRequest Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestRequestValidCriterion"
            },
            "type": "function"
          },
          "name": "start_validation",
          "next": "pending"
        }
      ]
    },
    "pending": {
      "transitions": [
        {
          "name": "begin_processing",
          "next": "processing"
        },
        {
          "name": "invalid_request",
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestDataSuccessCriterion"
            },
            "type": "function"
          },
          "name": "digestdata_success",
          "next": "completed"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestDataFailedCriterion"
            },
            "type": "function"
          },
          "name": "digestdata_failed",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}