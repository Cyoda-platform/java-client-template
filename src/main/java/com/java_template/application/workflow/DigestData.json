{
  "active": true,
  "desc": "Workflow managing the lifecycle of a DigestRequestJob, DigestData, and DigestEmail entities",
  "initialState": "none",
  "name": "DigestRequestJob Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestRequestJobValidationCriterion"
            },
            "type": "function"
          },
          "name": "start_validation",
          "next": "validating_request"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestRequestJobValidationFailCriterion"
            },
            "type": "function"
          },
          "name": "start_invalid",
          "next": "failed"
        }
      ]
    },
    "validating_request": {
      "transitions": [
        {
          "name": "process_digest_data",
          "next": "processing_digest_data",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "DigestDataProcessor"
            }
          ]
        }
      ]
    },
    "processing_digest_data": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestDataAvailableCriterion"
            },
            "type": "function"
          },
          "name": "digest_data_available",
          "next": "compiling_digest_content"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestDataUnavailableCriterion"
            },
            "type": "function"
          },
          "name": "digest_data_unavailable",
          "next": "failed"
        }
      ]
    },
    "compiling_digest_content": {
      "transitions": [
        {
          "name": "save_digest_email",
          "next": "pending_email_send"
        }
      ]
    },
    "pending_email_send": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestEmailSentCriterion"
            },
            "type": "function"
          },
          "name": "email_sent",
          "next": "completed"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "DigestEmailFailedCriterion"
            },
            "type": "function"
          },
          "name": "email_failed",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}