{
  "desc": "Workflow for processing PetJob entity lifecycle",
  "id": "petjob_workflow",
  "initialState": "none",
  "name": "PetJob workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "transition_to_pending",
          "next": "PENDING"
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "CanProcessPetJobCriterion"
            },
            "type": "function"
          },
          "id": "pending_to_processing_can_process",
          "next": "PROCESSING",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "52e21216-64e9-11b2-965a-2e0ad7d884c5"
              },
              "name": "PetJobStartProcessor"
            }
          ]
        }
      ]
    },
    "PROCESSING": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "IsPetJobSuccessfulCriterion"
            },
            "type": "function"
          },
          "id": "processing_to_completed_success",
          "next": "COMPLETED"
        },
        {
          "criterion": {
            "function": {
              "name": "IsPetJobFailedCriterion"
            },
            "type": "function"
          },
          "id": "processing_to_failed_failure",
          "next": "FAILED"
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  },
  "version": "1.0"
}