{
    "desc": "Workflow representing PetEvent processing lifecycle with validation and status updates",
    "id": "pet_event_workflow",
    "initialState": "none",
    "name": "PetEvent Workflow",
    "states": {
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "transition_to_recorded",
                    "next": "recorded"
                }
            ]
        },
        "processed": {
            "transitions": []
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetIdMissingCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_failed_due_to_missing_petId",
                    "next": "failed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "EventTypeMissingCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_failed_due_to_missing_eventType",
                    "next": "failed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "EventTimestampMissingCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_failed_due_to_missing_eventTimestamp",
                    "next": "failed"
                },
                {
                    "id": "transition_to_processed",
                    "next": "processed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetEventProcessor"
                        }
                    ]
                }
            ]
        },
        "recorded": {
            "transitions": [
                {
                    "id": "transition_to_processing",
                    "next": "processing"
                }
            ]
        }
    },
    "version": "1.0"
}