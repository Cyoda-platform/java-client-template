          "next": "failed"
        },
        {
          "criterion": {
            "function": {
              "name": "EventTypeMissingCriterion"
            },
            "type": "function"
          },
          "id": "transition_to_failed_due_to_missing_eventType",
          "next": "failed"
        },
        {
          "criterion": {
            "function": {
              "name": "EventTimestampMissingCriterion"
            },
            "type": "function"
          },
          "id": "transition_to_failed_due_to_missing_eventTimestamp",
          "next": "failed"
        },
        {
          "id": "transition_to_processed",
          "next": "processed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "52e21216-64e9-11b2-965a-2e0ad7d884c5"
              },
              "name": "PetEventProcessor"
            }
          ]
        }
      ]
    },
    "failed": {
