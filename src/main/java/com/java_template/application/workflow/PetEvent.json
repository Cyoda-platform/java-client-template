{
    "desc": "Workflow describing the lifecycle of PetJob processing",
    "id": "petjob_workflow",
    "initialState": "none",
    "name": "PetJob Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobStartCriterion"
                        },
                        "type": "function"
                    },
                    "id": "start_job_processing",
                    "next": "pending"
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobCanStartProcessingCriterion"
                        },
                        "type": "function"
                    },
                    "id": "start_processing",
                    "next": "processing",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "add_application_resource"
                            },
                            "name": "PetJobProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobInvalidCriterion"
                        },
                        "type": "function"
                    },
                    "id": "fail_due_to_invalid",
                    "next": "failed"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobSuccessCriterion"
                        },
                        "type": "function"
                    },
                    "id": "complete_job",
                    "next": "completed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobErrorCriterion"
                        },
                        "type": "function"
                    },
                    "id": "fail_job",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}