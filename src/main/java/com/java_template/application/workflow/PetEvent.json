{
    "desc": "Workflow for processing PetJob entity lifecycle",
    "id": "petjob_workflow",
    "initialState": "none",
    "name": "PetJob workflow",
    "states": {
        "COMPLETED": {
            "transitions": []
        },
        "FAILED": {
            "transitions": []
        },
        "PENDING": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "CanProcessPetJobCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pending_to_processing_can_process",
                    "next": "PROCESSING",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetJobStartProcessor"
                        }
                    ]
                }
            ]
        },
        "PROCESSING": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "IsPetJobSuccessfulCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_to_completed_success",
                    "next": "COMPLETED"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "IsPetJobFailedCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_to_failed_failure",
                    "next": "FAILED"
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "id": "transition_to_pending",
                    "next": "PENDING"
                }
            ]
        }
    },
    "version": "1.0"
}