{
    "desc": "Workflow for processing PetEvent entities triggered by persistence events",
    "id": "pet_event_workflow",
    "initialState": "none",
    "name": "PetEvent workflow",
    "states": {
        "FAILED": {
            "transitions": []
        },
        "PROCESSED": {
            "transitions": []
        },
        "PROCESSING": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetEventProcessingSuccessCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_processed",
                    "next": "PROCESSED"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetEventProcessingFailureCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_failed",
                    "next": "FAILED"
                }
            ]
        },
        "RECORDED": {
            "transitions": [
                {
                    "id": "transition_to_processing",
                    "next": "PROCESSING",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetEventProcessor"
                        }
                    ]
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "id": "transition_to_recorded",
                    "next": "RECORDED"
                }
            ]
        }
    },
    "version": "1.0"
}