            "type": "function"
          },
          "id": "complete_processing",
          "next": "completed"
        },
        {
          "criterion": {
            "function": {
              "name": "PetJobProcessingFailedCriterion"
            },
            "type": "function"
          },
          "id": "fail_processing",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}