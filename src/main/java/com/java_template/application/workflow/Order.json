{
    "active": true,
    "desc": "Workflow for processing PetRegistrationJob entity from submission to completion or failure",
    "initialState": "none",
    "name": "PetRegistrationJob Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "name": "start_validation",
                    "next": "pending"
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetDataValidityCriterion"
                        },
                        "type": "function"
                    },
                    "name": "validate_pet_data_success",
                    "next": "processing"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetDataInvalidCriterion"
                        },
                        "type": "function"
                    },
                    "name": "validate_pet_data_failure",
                    "next": "failed"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "name": "create_pet_record_success",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "PetRegistrationJobProcessor"
                        }
                    ]
                },
                {
                    "name": "create_pet_record_failure",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}