{
  "desc": "Workflow to validate HNItem entity content and update status accordingly",
  "id": "hnitem_workflow",
  "initialState": "none",
  "name": "HNItem Validation Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "start_validation",
          "next": "invalid"
        }
      ]
    },
    "invalid": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "ContentValidCriterion"
            },
            "type": "function"
          },
          "id": "validate_content_success",
          "next": "validated",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "a97e5aec-2f7b-11b2-944c-fac101f95347"
              },
              "name": "HNItemProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "name": "ContentInvalidCriterion"
            },
            "type": "function"
          },
          "id": "validate_content_failure",
          "next": "invalid"
        }
      ]
    },
    "validated": {
      "transitions": []
    }
  },
  "version": "1.0"
}