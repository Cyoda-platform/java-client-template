{
  "active": true,
  "desc": "Workflow for validating and processing HNItem entities",
  "initialState": "none",
  "name": "HNItem Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "start_processing",
          "next": "validating"
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "paul",
                "attachEntity": true
              },
              "name": "HNItemTypeAndIdCriterion"
            },
            "type": "function"
          },
          "name": "valid_payload",
          "next": "validated",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "paul",
                "attachEntity": true
              },
              "executionMode": "SYNC",
              "name": "HNItemProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "paul",
                "attachEntity": true
              },
              "name": "HNItemTypeAndIdCriterionNegation"
            },
            "type": "function"
          },
          "name": "invalid_payload",
          "next": "invalid"
        }
      ]
    },
    "validated": {
      "transitions": []
    },
    "invalid": {
      "transitions": []
    }
  },
  "version": "1.0"
}