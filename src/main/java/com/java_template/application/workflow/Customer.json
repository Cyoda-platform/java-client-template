{
    "active": true,
    "desc": "Workflow handling customer validation, processing and completion on entity persistence event",
    "initialState": "none",
    "name": "Customer Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "name": "start_processing",
                    "next": "validating"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "name": "enrich_and_complete",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "CustomerProcessor"
                        }
                    ]
                }
            ]
        },
        "validating": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "ValidateCustomerCriterion"
                        },
                        "type": "function"
                    },
                    "name": "valid_email_and_unique",
                    "next": "processing"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "ValidateCustomerCriterionNegation"
                        },
                        "type": "function"
                    },
                    "name": "invalid_email_or_duplicate",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}