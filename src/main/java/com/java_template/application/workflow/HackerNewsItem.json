{
  "active": true,
  "desc": "Workflow for processing HackerNewsItemJob entities from creation to completion or failure",
  "initialState": "none",
  "name": "HackerNewsItemJob Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "create_pending_job",
          "next": "pending"
        }
      ]
    },
    "pending": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsPendingCriterion"
            },
            "type": "function"
          },
          "name": "start_processing_if_pending",
          "next": "processing"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsValidHnItemJsonCriterion"
            },
            "type": "function"
          },
          "name": "complete_if_valid",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "HackerNewsItemProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsInvalidHnItemJsonCriterion"
            },
            "type": "function"
          },
          "name": "fail_if_invalid",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}