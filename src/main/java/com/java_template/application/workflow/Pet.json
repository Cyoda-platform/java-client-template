{
    "desc": "Workflow representing the lifecycle of a Pet entity from creation to ready for adoption status",
    "id": "pet_workflow",
    "initialState": "none",
    "name": "Pet entity workflow",
    "states": {
        "created": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetValidCriterion"
                        },
                        "type": "function"
                    },
                    "id": "validate_pet_success",
                    "next": "validated"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetInvalidCriterion"
                        },
                        "type": "function"
                    },
                    "id": "validate_pet_failure",
                    "next": "invalid"
                }
            ]
        },
        "end": {
            "transitions": []
        },
        "invalid": {
            "transitions": [
                {
                    "id": "abort_processing",
                    "next": "end"
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "id": "create_pet",
                    "next": "created"
                }
            ]
        },
        "ready_for_adoption": {
            "transitions": [
                {
                    "id": "end_processing",
                    "next": "end"
                }
            ]
        },
        "validated": {
            "transitions": [
                {
                    "id": "ready_for_adoption",
                    "next": "ready_for_adoption",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetProcessor"
                        }
                    ]
                }
            ]
        }
    },
    "version": "1.0"
}