{
    "desc": "Workflow managing PurrfectPetsJob lifecycle from pending to completed or failed",
    "id": "purrfectpetsjob_workflow",
    "initialState": "none",
    "name": "PurrfectPetsJob workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "CanStartProcessingCriterion"
                        },
                        "type": "function"
                    },
                    "id": "start_processing_if_pending",
                    "next": "processing"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "IsJobSuccessfulCriterion"
                        },
                        "type": "function"
                    },
                    "id": "complete_if_successful",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "purrfectpets_jobs"
                            },
                            "name": "PurrfectPetsJobProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "name": "IsJobFailedCriterion"
                        },
                        "type": "function"
                    },
                    "id": "fail_if_failed",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}