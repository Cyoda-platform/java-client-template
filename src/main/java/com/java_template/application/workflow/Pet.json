{
    "desc": "Workflow for Pet entity lifecycle management",
    "id": "pet_workflow",
    "initialState": "none",
    "name": "Pet entity workflow",
    "states": {
        "active": {
            "transitions": [
                {
                    "criterion": {
                        "className": "PetArchivalCriterion",
                        "type": "class"
                    },
                    "id": "active_to_archived",
                    "next": "archived"
                }
            ]
        },
        "archived": {
            "transitions": []
        },
        "new": {
            "transitions": [
                {
                    "criterion": {
                        "className": "PetActivationCriterion",
                        "type": "class"
                    },
                    "id": "new_to_active_valid",
                    "next": "active",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "className": "PetActivationCriterionNegation",
                        "type": "class"
                    },
                    "id": "new_to_pending",
                    "next": "pending"
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "id": "none_to_new",
                    "next": "new"
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "criterion": {
                        "className": "PetActivationCriterion",
                        "type": "class"
                    },
                    "id": "pending_to_active",
                    "next": "active",
                    "processors": [
                        {
                            "name": "PetProcessor"
                        }
                    ]
                }
            ]
        }
    },
    "version": "1.0"
}