```json
{
  "version": "1.0",
  "name": "PetIngestionJob Workflow",
  "desc": "Manages the lifecycle of a pet data ingestion job, from initiation to completion or failure.",
  "initialState": "none",
  "active": true,
  "states": {
    "none": {
      "transitions": [
        {
          "name": "initiate_job",
          "next": "PENDING",
          "manual": false
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "name": "start_ingestion_process",
          "next": "IN_PROGRESS",
          "manual": false,
          "processors": [
            {
              "name": "PetProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "IN_PROGRESS": {
      "transitions": [
        {
          "name": "complete_ingestion",
          "next": "COMPLETED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionSuccessfulCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "fail_ingestion",
          "next": "FAILED",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IngestionFailedCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  }
}
