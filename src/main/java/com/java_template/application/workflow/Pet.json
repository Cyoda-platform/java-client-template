{
  "version": "1.0",
  "description": "Workflow for Pet entity representing basic lifecycle processing.",
  "initial_state": "none",
  "workflow_name": "pet_workflow",
  "states": {
    "none": {
      "transitions": {
        "start_processing": {
          "next": "processing",
          "processors": [
            {
              "name": "PetProcessor"
            }
          ]
        }
      }
    },
    "processing": {
      "transitions": {
        "finish_processing": {
          "next": "completed"
        }
      }
    },
    "completed": {
      "transitions": {}
    }
  }
}
