{
  "version": "1.0",
  "name": "Pet Workflow",
  "desc": "Workflow for Pet entity processing including validation and storage.",
  "initialState": "saved",
  "active": true,
  "states": {
    "saved": {
      "transitions": [
        {
          "name": "validate_pet",
          "next": "validation",
          "manual": false
        }
      ]
    },
    "validation": {
      "transitions": [
        {
          "name": "valid_pet",
          "next": "stored",
          "manual": false,
          "processors": [
            {
              "name": "PetValidationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        },
        {
          "name": "invalid_pet",
          "next": "failed",
          "manual": false
        }
      ]
    },
    "stored": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}
