{
    "desc": "Workflow to process PetJob entities orchestrating Pet creation and update operations",
    "id": "petjob_workflow",
    "initialState": "none",
    "name": "PetJob Processing Workflow",
    "states": {
        "complete_job": {
            "transitions": [
                {
                    "id": "end_success",
                    "next": "end"
                }
            ]
        },
        "end": {
            "transitions": []
        },
        "fail_job": {
            "transitions": [
                {
                    "id": "end_fail",
                    "next": "end"
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "id": "start_validation",
                    "next": "validate_petjob"
                }
            ]
        },
        "process_addpet": {
            "transitions": [
                {
                    "id": "process_addpet_transition",
                    "next": "complete_job",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetJobAddProcessor"
                        }
                    ]
                }
            ]
        },
        "process_updatepetstatus": {
            "transitions": [
                {
                    "id": "process_updatepetstatus_transition",
                    "next": "complete_job",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetJobUpdateProcessor"
                        }
                    ]
                }
            ]
        },
        "validate_petjob": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobTypeIsAddPetCriterion"
                        },
                        "type": "function"
                    },
                    "id": "valid_petjob",
                    "next": "process_addpet"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobTypeIsUpdatePetStatusCriterion"
                        },
                        "type": "function"
                    },
                    "id": "valid_petjob_update",
                    "next": "process_updatepetstatus"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobInvalidCriterion"
                        },
                        "type": "function"
                    },
                    "id": "invalid_petjob",
                    "next": "fail_job"
                }
            ]
        }
    },
    "version": "1.0"
}