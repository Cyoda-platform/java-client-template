{
  "version": "1.0",
  "description": "Workflow for Pet entity",
  "initial_state": "none",
  "workflow_name": "petWorkflow",
  "states": {
    "none": {
      "transitions": {
        "start_processing": {
          "next": "state_processing",
          "processors": [
            {
              "name": "PetProcessor"
            }
          ]
        }
      }
    },
    "state_processing": {
      "transitions": {
        "validate_pet": {
          "next": "state_validated",
          "processors": [
            {
              "name": "PetProcessor"
            }
          ]
        }
      }
    },
    "state_validated": {
      "transitions": {
        "finalize_pet": {
          "next": "state_completed",
          "processors": [
            {
              "name": "PetProcessor"
            }
          ]
        }
      }
    },
    "state_completed": {
      "transitions": {}
    }
  }
}