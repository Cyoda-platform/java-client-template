{
  "desc": "Workflow for processing Pet entity lifecycle",
  "id": "pet_workflow",
  "initialState": "none",
  "name": "Pet Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "none_to_created",
          "next": "created"
        }
      ]
    },
    "created": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetValidityCriterion"
            },
            "type": "function"
          },
          "id": "created_to_validated",
          "next": "validated"
        },
        {
          "criterion": {
            "function": {
              "name": "PetInvalidityCriterion"
            },
            "type": "function"
          },
          "id": "created_to_invalid",
          "next": "invalid"
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "id": "validated_to_business_logic",
          "next": "business_logic"
        }
      ]
    },
    "business_logic": {
      "transitions": [
        {
          "id": "business_logic_to_completed",
          "next": "completed"
        }
      ]
    },
    "completed": {
      "transitions": [
        {
          "id": "completed_to_end",
          "next": "end"
        }
      ]
    },
    "end": {
      "transitions": []
    },
    "invalid": {
      "transitions": [
        {
          "id": "invalid_to_terminated",
          "next": "terminated",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "bac63f2a-64b1-11b2-965a-2e0ad7d884c5"
              },
              "name": "PetProcessor"
            }
          ]
        }
      ]
    },
    "terminated": {
      "transitions": [
        {
          "id": "terminated_to_end",
          "next": "end"
        }
      ]
    }
  },
  "version": "1.0"
}