{
  "active": true,
  "desc": "Workflow for processing AdoptionRequest entities with validation and status transitions",
  "initialState": "none",
  "name": "Adoption Request Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "validate_pet_exists",
          "next": "validate_pet_available"
        }
      ]
    },
    "validate_pet_available": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "isPetAvailable"
            },
            "type": "function"
          },
          "name": "pet_available",
          "next": "validate_adopter_eligible"
        },
        {
          "name": "pet_not_available",
          "next": "reject_request"
        }
      ]
    },
    "validate_adopter_eligible": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "isAdopterEligible"
            },
            "type": "function"
          },
          "name": "adopter_eligible",
          "next": "approve_request"
        },
        {
          "name": "adopter_not_eligible",
          "next": "reject_request"
        }
      ]
    },
    "approve_request": {
      "transitions": [
        {
          "name": "approve",
          "next": "create_adopted_pet"
        }
      ]
    },
    "create_adopted_pet": {
      "transitions": [
        {
          "name": "create_pet",
          "next": "complete"
        }
      ]
    },
    "complete": {
      "transitions": []
    },
    "reject_request": {
      "transitions": [
        {
          "name": "reject",
          "next": "complete"
        }
      ]
    },
    "validate_pet_exists": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "petExists"
            },
            "type": "function"
          },
          "name": "pet_exists",
          "next": "validate_pet_available"
        },
        {
          "name": "pet_not_found",
          "next": "reject_request"
        }
      ]
    }
  },
  "version": "1.0"
}