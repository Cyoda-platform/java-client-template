{
  "version": "1.0",
  "name": "Pet Workflow",
  "desc": "Description of the workflow for Pet",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_pet_data",
          "next": "validating",
          "manual": false
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "name": "validation_success",
          "next": "processing",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "ValidatePetDataCriterion",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "validation_failure",
          "next": "failed",
          "manual": false
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "name": "apply_business_rules",
          "next": "completed",
          "manual": false,
          "processors": [
            {
              "name": "ApplyPetBusinessRulesProcessor",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  }
}
