{
    "desc": "Workflow for processing PetJob lifecycle and related PetEvent",
    "id": "petjob_workflow",
    "initialState": "none",
    "name": "PetJob workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "start_processing_petjob",
                    "next": "pending"
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobValidityCriterion"
                        },
                        "type": "function"
                    },
                    "id": "validate_petjob_valid",
                    "next": "processing"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobInvalidityCriterion"
                        },
                        "type": "function"
                    },
                    "id": "validate_petjob_invalid",
                    "next": "failed"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "id": "process_petjob_success",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetJobProcessingFailureCriterion"
                        },
                        "type": "function"
                    },
                    "id": "process_petjob_fail",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}