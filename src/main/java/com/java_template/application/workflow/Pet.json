{
  "desc": "Workflow for processing Pet entity lifecycle",
  "id": "pet_workflow",
  "initialState": "none",
  "name": "Pet Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "transition_to_pet_created",
          "next": "PetCreated"
        }
      ]
    },
    "PetCreated": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetDataValidCriterion"
            },
            "type": "function"
          },
          "id": "transition_to_active",
          "next": "Active",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "a3f07724-2ff6-11b2-ac6a-1297eff5fbfd"
              },
              "name": "PetProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "name": "PetDataInvalidCriterion"
            },
            "type": "function"
          },
          "id": "transition_to_validation_failed",
          "next": "ValidationFailed"
        }
      ]
    },
    "Active": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetCanDeactivateCriterion"
            },
            "type": "function"
          },
          "id": "transition_to_inactive",
          "next": "Inactive"
        },
        {
          "id": "transition_to_end",
          "next": "End"
        }
      ]
    },
    "Inactive": {
      "transitions": [
        {
          "id": "transition_to_end_from_inactive",
          "next": "End"
        }
      ]
    },
    "End": {
      "transitions": []
    },
    "ValidationFailed": {
      "transitions": []
    }
  },
  "version": "1.0"
}