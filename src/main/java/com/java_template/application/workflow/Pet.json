{
  "desc": "Workflow to process PetJob entity lifecycle from creation to completion",
  "id": "petjob_workflow",
  "initialState": "none",
  "name": "PetJob processing workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "transition_to_pending",
          "next": "PENDING"
        }
      ]
    },
    "PENDING": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetJobValidationCriterion"
            },
            "type": "function"
          },
          "id": "validate_job_transition",
          "next": "VALIDATED"
        },
        {
          "criterion": {
            "function": {
              "name": "PetJobInvalidCriterion"
            },
            "type": "function"
          },
          "id": "fail_invalid_job_transition",
          "next": "FAILED"
        }
      ]
    },
    "VALIDATED": {
      "transitions": [
        {
          "id": "execute_job_transition",
          "next": "PROCESSING",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "52e21216-64e9-11b2-965a-2e0ad7d884c5"
              },
              "name": "PetProcessor"
            }
          ]
        }
      ]
    },
    "PROCESSING": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetJobExecutionSuccessCriterion"
            },
            "type": "function"
          },
          "id": "job_success_transition",
          "next": "EVENT_CREATED"
        },
        {
          "criterion": {
            "function": {
              "name": "PetJobExecutionFailureCriterion"
            },
            "type": "function"
          },
          "id": "job_failure_transition",
          "next": "FAILED"
        }
      ]
    },
    "EVENT_CREATED": {
      "transitions": [
        {
          "id": "complete_job_transition",
          "next": "COMPLETED"
        }
      ]
    },
    "COMPLETED": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  },
  "version": "1.0"
}