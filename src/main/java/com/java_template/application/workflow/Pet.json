              "name": "PetJobStartCriterion"
            },
            "type": "function"
          },
          "id": "start_processing",
          "next": "pending"
        }
      ]
    },
    "pending": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetJobPayloadValidCriterion"
            },
            "type": "function"
          },
          "id": "validate_and_process",
