{
    "desc": "Workflow to manage the lifecycle of PurrfectPetsJob entity",
    "id": "purrfectpetsjob_workflow",
    "initialState": "none",
    "name": "PurrfectPetsJob workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "id": "none_to_pending",
                    "next": "pending"
                }
            ]
        },
        "pending": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "ValidFetchJobCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pending_to_processing_fetch",
                    "next": "processing",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "JobFetchProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "name": "ValidUpdateJobCriterion"
                        },
                        "type": "function"
                    },
                    "id": "pending_to_processing_update",
                    "next": "processing",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "JobUpdateProcessor"
                        }
                    ]
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "JobSuccessCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_to_completed",
                    "next": "completed"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "JobFailureCriterion"
                        },
                        "type": "function"
                    },
                    "id": "processing_to_failed",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}