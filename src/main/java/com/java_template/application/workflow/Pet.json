{
    "desc": "Workflow representing the lifecycle of a Pet entity from none to AVAILABLE and ADOPTED",
    "id": "pet_workflow",
    "initialState": "none",
    "name": "Pet lifecycle workflow",
    "states": {
        "adopted": {
            "transitions": []
        },
        "available": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "AdoptionApprovalCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_adopted_approved",
                    "next": "adopted"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "AdoptionPendingCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_available_pending",
                    "next": "available"
                }
            ]
        },
        "error": {
            "transitions": []
        },
        "new": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetValidationCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_available_valid",
                    "next": "available",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetValidationFailCriterion"
                        },
                        "type": "function"
                    },
                    "id": "transition_to_error_invalid",
                    "next": "error"
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "id": "transition_to_new",
                    "next": "new"
                }
            ]
        }
    },
    "version": "1.0"
}