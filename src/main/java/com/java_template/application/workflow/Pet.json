{
    "desc": "Workflow for processing Pet entity lifecycle from creation to persistence",
    "id": "pet_workflow",
    "initialState": "none",
    "name": "Pet entity workflow",
    "states": {
        "created": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetValidityCriterion"
                        },
                        "type": "function"
                    },
                    "id": "validate_pet",
                    "next": "validated"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetInvalidityCriterion"
                        },
                        "type": "function"
                    },
                    "id": "invalid_pet_terminate",
                    "next": "terminated"
                }
            ]
        },
        "enriched": {
            "transitions": [
                {
                    "id": "persist_pet",
                    "next": "processed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "PetProcessor"
                        }
                    ]
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "id": "start_validation",
                    "next": "created"
                }
            ]
        },
        "processed": {
            "transitions": []
        },
        "terminated": {
            "transitions": []
        },
        "validated": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "name": "PetNeedsEnrichmentCriterion"
                        },
                        "type": "function"
                    },
                    "id": "need_enrichment",
                    "next": "enriched"
                },
                {
                    "criterion": {
                        "function": {
                            "name": "PetDoesNotNeedEnrichmentCriterion"
                        },
                        "type": "function"
                    },
                    "id": "skip_enrichment",
                    "next": "processed"
                }
            ]
        }
    },
    "version": "1.0"
}