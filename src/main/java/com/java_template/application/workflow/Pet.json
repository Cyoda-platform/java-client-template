{
    "active": true,
    "desc": "Workflow for processing AdoptionRequest entities with validation and status transitions",
    "initialState": "none",
    "name": "Adoption Request Workflow",
    "states": {
        "approve_request": {
            "transitions": [
                {
                    "name": "approve",
                    "next": "create_adopted_pet"
                }
            ]
        },
        "complete": {
            "transitions": []
        },
        "create_adopted_pet": {
            "transitions": [
                {
                    "name": "create_pet",
                    "next": "complete"
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "name": "validate_pet_exists",
                    "next": "validate_pet_available"
                }
            ]
        },
        "reject_request": {
            "transitions": [
                {
                    "name": "reject",
                    "next": "complete"
                }
            ]
        },
        "validate_adopter_eligible": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "isAdopterEligible"
                        },
                        "type": "function"
                    },
                    "name": "adopter_eligible",
                    "next": "approve_request"
                },
                {
                    "name": "adopter_not_eligible",
                    "next": "reject_request"
                }
            ]
        },
        "validate_pet_available": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "isPetAvailable"
                        },
                        "type": "function"
                    },
                    "name": "pet_available",
                    "next": "validate_adopter_eligible"
                },
                {
                    "name": "pet_not_available",
                    "next": "reject_request"
                }
            ]
        },
        "validate_pet_exists": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "petExists"
                        },
                        "type": "function"
                    },
                    "name": "pet_exists",
                    "next": "validate_pet_available"
                },
                {
                    "name": "pet_not_found",
                    "next": "reject_request"
                }
            ]
        }
    },
    "version": "1.0"
}