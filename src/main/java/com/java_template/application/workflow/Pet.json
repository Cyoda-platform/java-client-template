{
    "active": true,
    "desc": "Description of the workflow for Pet",
    "initialState": "none",
    "name": "Pet Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "created": {
            "transitions": [
                {
                    "manual": false,
                    "name": "validate_pet_data",
                    "next": "validating"
                }
            ]
        },
        "failed": {
            "transitions": []
        },
        "processing": {
            "transitions": [
                {
                    "manual": false,
                    "name": "apply_business_rules",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "ApplyPetBusinessRulesProcessor"
                        }
                    ]
                }
            ]
        },
        "validating": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "ValidatePetDataCriterion"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "validation_success",
                    "next": "processing"
                },
                {
                    "manual": false,
                    "name": "validation_failure",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}