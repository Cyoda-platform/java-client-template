{
  "version": "1.0",
  "name": "Pet Workflow",
  "desc": "Workflow for processing Pet entity",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_pet_data",
          "next": "validated",
          "manual": false,
          "processors": [
            {
              "name": "PetDataValidator",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "enrich_pet_data",
          "next": "enriched",
          "manual": false,
          "processors": [
            {
              "name": "PetDataEnricher",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "enriched": {
      "transitions": [
        {
          "name": "complete_process",
          "next": "completed",
          "manual": false
        }
      ]
    },
    "completed": {
      "transitions": []
    }
  }
}
