      "transitions": [
        {
          "id": "none_to_new",
          "next": "new"
        }
      ]
    },
    "new": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetActivationCriterion"
            },
            "type": "function"
          },
          "id": "new_to_active_valid",
          "next": "active",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "0a4afdac-2bae-11b2-944c-fac101f95347"
              },
              "name": "PetProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "name": "PetActivationCriterionNegation"
            },
            "type": "function"
          },
          "id": "new_to_pending",
          "next": "pending"
        }
      ]
    },
    "active": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetArchivalCriterion"
            },
            "type": "function"
          },
          "id": "active_to_archived",
          "next": "archived"
        }
      ]
    },
    "archived": {
      "transitions": []
    },
    "pending": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetActivationCriterion"
            },
            "type": "function"
          },
          "id": "pending_to_active",
          "next": "active",
          "processors": [
            {
              "name": "PetProcessor"
            }
          ]
        }
      ]
    }
  },
  "version": "1.0"
}