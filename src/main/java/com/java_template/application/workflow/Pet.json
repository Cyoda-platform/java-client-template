{
    "active": true,
    "desc": "Workflow representing the lifecycle of PurrfectPetsJob orchestration entity",
    "initialState": "none",
    "name": "PurrfectPetsJob Workflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsPetStatusValidCriterion"
                        },
                        "type": "function"
                    },
                    "name": "start_processing_if_pet_status_valid",
                    "next": "processing",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "PurrfectPetsJobProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsPetStatusInvalidCriterion"
                        },
                        "type": "function"
                    },
                    "name": "fail_if_pet_status_invalid",
                    "next": "failed"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsProcessingSuccessCriterion"
                        },
                        "type": "function"
                    },
                    "name": "complete_on_success",
                    "next": "completed"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsProcessingFailedCriterion"
                        },
                        "type": "function"
                    },
                    "name": "fail_on_error",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}