{
  "desc": "Workflow for processing PetIngestionJob lifecycle from validation to completion",
  "id": "pet_ingestion_job_workflow",
  "initialState": "none",
  "name": "Pet Ingestion Job Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "id": "start_validation",
          "next": "validate_job"
        }
      ]
    },
    "validate_job": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "PetIngestionJobValidationCriterion"
            },
            "type": "function"
          },
          "id": "validation_success",
          "next": "processing"
        },
        {
          "criterion": {
            "function": {
              "name": "PetIngestionJobValidationFailedCriterion"
            },
            "type": "function"
          },
          "id": "validation_failed",
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "id": "fetch_and_persist_pets",
          "next": "persist_pets",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application",
                "calculation_nodes_tags": "c8b72332-65c0-11b2-965a-2e0ad7d884c5"
              },
              "name": "PetIngestionJobProcessor"
            }
          ]
        }
      ]
    },
    "persist_pets": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "name": "AllPetsPersistedSuccessfullyCriterion"
            },
            "type": "function"
          },
          "id": "pets_persisted_success",
          "next": "completed"
        },
        {
          "criterion": {
            "function": {
              "name": "PetsPersistedFailureCriterion"
            },
            "type": "function"
          },
          "id": "pets_persisted_failure",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}