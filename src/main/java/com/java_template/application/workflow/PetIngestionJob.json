{
  "active": true,
  "desc": "Workflow managing pet ingestion job lifecycle with states and transitions",
  "initialState": "none",
  "name": "PetIngestionJob Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "PetIngestionJobSourceValidCriterion"
            },
            "type": "function"
          },
          "name": "start_processing_if_source_valid",
          "next": "pending"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "PetIngestionJobSourceInvalidCriterion"
            },
            "type": "function"
          },
          "name": "fail_if_source_invalid",
          "next": "failed"
        }
      ]
    },
    "pending": {
      "transitions": [
        {
          "name": "begin_processing",
          "next": "processing",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "PetIngestionJobProcessor"
            }
          ]
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "PetsCreatedSuccessfullyCriterion"
            },
            "type": "function"
          },
          "name": "complete_if_pets_created_successfully",
          "next": "completed"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ErrorOccurredCriterion"
            },
            "type": "function"
          },
          "name": "fail_if_error_occurred",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}