{
  "active": true,
  "desc": "Workflow for managing SnapshotJob lifecycle including validation, processing, change detection, and completion",
  "initialState": "validating",
  "name": "SnapshotJob Workflow",
  "states": {
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ValidDateAndSeasonCriterion"
            },
            "type": "function"
          },
          "name": "valid_date_and_season",
          "manual": false,
          "next": "processing"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "name": "InvalidDateOrSeasonCriterion"
            },
            "type": "function"
          },
          "name": "invalid_date_or_season",
          "manual": false,
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "name": "processing_successful",
          "manual": false,
          "next": "change_detection",
          "processors": [
            {
              "config": {
                "attachEntity": true,
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "SnapshotJobProcessor"
            }
          ]
        },
        {
          "name": "processing_failed",
          "manual": false,
          "next": "failed"
        }
      ]
    },
    "change_detection": {
      "transitions": [
        {
          "name": "changes_detected_and_notified",
          "manual": true,
          "next": "completed"
        },
        {
          "name": "change_detection_failed",
          "manual": true,
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}