{
    "active": true,
    "desc": "Workflow for managing SnapshotJob lifecycle including validation, processing, change detection, and completion",
    "initialState": "none",
    "name": "SnapshotJob Workflow",
    "states": {
        "change_detection": {
            "transitions": [
                {
                    "name": "changes_detected_and_notified",
                    "next": "completed"
                },
                {
                    "name": "change_detection_failed",
                    "next": "failed"
                }
            ]
        },
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "name": "start_validation",
                    "next": "validating"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "name": "processing_successful",
                    "next": "change_detection",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "SnapshotJobProcessor"
                        }
                    ]
                },
                {
                    "name": "processing_failed",
                    "next": "failed"
                }
            ]
        },
        "validating": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "ValidDateAndSeasonCriterion"
                        },
                        "type": "function"
                    },
                    "name": "valid_date_and_season",
                    "next": "processing"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "InvalidDateOrSeasonCriterion"
                        },
                        "type": "function"
                    },
                    "name": "invalid_date_or_season",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}