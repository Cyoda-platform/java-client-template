{
  "version": "1.0",
  "name": "Mail Workflow",
  "desc": "Workflow for processing Mail entity including validation and sending happy or gloomy mail content.",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validate_mail",
          "next": "validated",
          "manual": false,
          "processors": [
            {
              "name": "MailValidationProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "send_happy_mail_content",
          "next": "completed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IsHappyCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          },
          "processors": [
            {
              "name": "SendHappyMailContentProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        },
        {
          "name": "send_gloomy_mail_content",
          "next": "completed",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "IsNotHappyCriterion",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          },
          "processors": [
            {
              "name": "SendGloomyMailContentProcessor",
              "executionMode": "SYNC",
              "config": {"calculationNodesTags": "cyoda_application"}
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    }
  }
}