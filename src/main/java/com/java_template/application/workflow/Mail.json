{
  "active": true,
  "desc": "Workflow for processing mail entity through validation and sending states",
  "initialState": "none",
  "name": "MailWorkflow",
  "states": {
    "none": {
      "transitions": [
        {
          "manual": false,
          "name": "start_mail_created",
          "next": "MailCreated"
        }
      ]
    },
    "MailCreated": {
      "transitions": [
        {
          "manual": false,
          "name": "start_validation",
          "next": "Validating"
        }
      ]
    },
    "Validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "CheckMailHappiness"
            },
            "type": "function"
          },
          "manual": false,
          "name": "validate_happy",
          "next": "Processing"
        }
      ]
    },
    "Processing": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "CheckMailIsHappyFlag"
            },
            "type": "function"
          },
          "manual": false,
          "name": "process_happy_mail",
          "next": "HappyMailSent",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "MailProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "CheckMailIsNotHappyFlag"
            },
            "type": "function"
          },
          "manual": false,
          "name": "process_gloomy_mail",
          "next": "GloomyMailSent"
        }
      ]
    },
    "HappyMailSent": {
      "transitions": [
        {
          "manual": false,
          "name": "end_workflow_happy",
          "next": "end"
        }
      ]
    },
    "end": {
      "transitions": []
    },
    "GloomyMailSent": {
      "transitions": [
        {
          "manual": false,
          "name": "end_workflow_gloomy",
          "next": "end"
        }
      ]
    }
  },
  "version": "1.0"
}