{
  "version": "1.0",
  "name": "Mail Workflow",
  "desc": "Workflow to process Mail entity based on isHappy attribute",
  "initialState": "created",
  "active": true,
  "states": {
    "created": {
      "transitions": [
        {
          "name": "validateMail",
          "next": "validated",
          "manual": false
        }
      ]
    },
    "validated": {
      "transitions": [
        {
          "name": "processHappy",
          "next": "sendHappy",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "CheckMailIsHappy",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        },
        {
          "name": "processGloomy",
          "next": "sendGloomy",
          "manual": false,
          "criterion": {
            "type": "function",
            "function": {
              "name": "CheckMailIsGloomy",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          }
        }
      ]
    },
    "sendHappy": {
      "transitions": [
        {
          "name": "sendHappyMail",
          "next": "completed",
          "manual": false,
          "processors": [
            {
              "name": "SendHappyMail",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "sendGloomy": {
      "transitions": [
        {
          "name": "sendGloomyMail",
          "next": "completed",
          "manual": false,
          "processors": [
            {
              "name": "SendGloomyMail",
              "executionMode": "SYNC",
              "config": {
                "calculationNodesTags": "cyoda_application"
              }
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    }
  }
}