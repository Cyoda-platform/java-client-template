{
    "active": true,
    "desc": "Workflow for processing Mail entity from creation to completion or failure",
    "initialState": "none",
    "name": "MailWorkflow",
    "states": {
        "completed": {
            "transitions": []
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "manual": false,
                    "name": "start_processing",
                    "next": "processing"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsMailHappy"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "process_happy_mail",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "MailProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsMailGloomy"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "process_gloomy_mail",
                    "next": "completed",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "MailProcessor"
                        }
                    ]
                },
                {
                    "manual": false,
                    "name": "process_invalid_mail",
                    "next": "failed"
                }
            ]
        }
    },
    "version": "1.0"
}