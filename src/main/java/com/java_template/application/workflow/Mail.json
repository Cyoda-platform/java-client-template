{
  "active": true,
  "desc": "Workflow for processing Mail entity from creation to completion",
  "initialState": "none",
  "name": "Mail Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "manual": false,
          "name": "transition_to_validation",
          "next": "validation"
        }
      ]
    },
    "validation": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsValidMail"
            },
            "type": "function"
          },
          "manual": false,
          "name": "validation_passed",
          "next": "sending"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsInvalidMail"
            },
            "type": "function"
          },
          "manual": false,
          "name": "validation_failed",
          "next": "failed"
        }
      ]
    },
    "sending": {
      "transitions": [
        {
          "manual": false,
          "name": "send_mail",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "MailProcessor"
            }
          ]
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}