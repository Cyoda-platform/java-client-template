{
    "active": true,
    "desc": "Workflow for processing mail entity from creation to sent or failed",
    "initialState": "none",
    "name": "Mail Workflow",
    "states": {
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "manual": false,
                    "name": "create_mail",
                    "next": "validating"
                }
            ]
        },
        "sendingGloomyMail": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "SendSuccessful"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "send_gloomy_success",
                    "next": "sent",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "MailProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "SendFailed"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "send_gloomy_failure",
                    "next": "failed"
                }
            ]
        },
        "sendingHappyMail": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "SendSuccessful"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "send_happy_success",
                    "next": "sent",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "MailProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "SendFailed"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "send_happy_failure",
                    "next": "failed"
                }
            ]
        },
        "sent": {
            "transitions": []
        },
        "validating": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "CheckMailHappy"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "valid_mail_happy",
                    "next": "sendingHappyMail"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "CheckMailGloomy"
                        },
                        "type": "function"
                    },
                    "manual": false,
                    "name": "valid_mail_gloomy",
                    "next": "sendingGloomyMail"
                }
            ]
        }
    },
    "version": "1.0"
}