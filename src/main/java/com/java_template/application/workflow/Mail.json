{
    "active": true,
    "desc": "Workflow representing the mail entity lifecycle and sending logic",
    "initialState": "none",
    "name": "Mail Workflow",
    "states": {
        "created": {
            "transitions": [
                {
                    "name": "process_mail",
                    "next": "processing",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "MailProcessor"
                        }
                    ]
                }
            ]
        },
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "name": "create_to_created",
                    "next": "created"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsMailSentSuccessfully"
                        },
                        "type": "function"
                    },
                    "name": "sent_if_successful",
                    "next": "sent"
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "IsMailSendingFailed"
                        },
                        "type": "function"
                    },
                    "name": "failed_if_unsuccessful",
                    "next": "failed"
                }
            ]
        },
        "sent": {
            "transitions": []
        }
    },
    "version": "1.0"
}