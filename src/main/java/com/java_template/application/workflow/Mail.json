{
    "active": true,
    "desc": "Workflow for processing Mail entity through happy/gloomy mail sending",
    "initialState": "none",
    "name": "Mail Entity Workflow",
    "states": {
        "failed": {
            "transitions": []
        },
        "none": {
            "transitions": [
                {
                    "name": "start_processing",
                    "next": "processing"
                }
            ]
        },
        "processing": {
            "transitions": [
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "CheckMailIsHappy"
                        },
                        "type": "function"
                    },
                    "name": "send_happy_mail",
                    "next": "sent",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "MailProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "CheckMailIsGloomy"
                        },
                        "type": "function"
                    },
                    "name": "send_gloomy_mail",
                    "next": "sent",
                    "processors": [
                        {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "executionMode": "SYNC",
                            "name": "MailProcessor"
                        }
                    ]
                },
                {
                    "criterion": {
                        "function": {
                            "config": {
                                "calculationNodesTags": "cyoda_application"
                            },
                            "name": "CheckMailIsNotHappyNorGloomy"
                        },
                        "type": "function"
                    },
                    "name": "fail_processing",
                    "next": "failed"
                }
            ]
        },
        "sent": {
            "transitions": []
        }
    },
    "version": "1.0"
}