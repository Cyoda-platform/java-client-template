{
  "active": true,
  "desc": "Workflow for processing mail entity through validation and sending happy or gloomy mails",
  "initialState": "none",
  "name": "Mail Business Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "start_processing",
          "next": "MailCreated"
        }
      ]
    },
    "MailCreated": {
      "transitions": [
        {
          "name": "to_validating",
          "next": "Validating"
        }
      ]
    },
    "Validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsMailHappyCriterion"
            },
            "type": "function"
          },
          "name": "valid_happy_mail",
          "next": "HappyMail"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsMailGloomyCriterion"
            },
            "type": "function"
          },
          "name": "valid_gloomy_mail",
          "next": "GloomyMail"
        },
        {
          "name": "invalid_mail",
          "next": "Failed"
        }
      ]
    },
    "HappyMail": {
      "transitions": [
        {
          "name": "send_happy_mail",
          "next": "SentHappy",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "MailProcessor"
            }
          ]
        },
        {
          "name": "happy_mail_failed",
          "next": "Failed"
        }
      ]
    },
    "SentHappy": {
      "transitions": []
    },
    "Failed": {
      "transitions": []
    },
    "GloomyMail": {
      "transitions": [
        {
          "name": "send_gloomy_mail",
          "next": "SentGloomy"
        },
        {
          "name": "gloomy_mail_failed",
          "next": "Failed"
        }
      ]
    },
    "SentGloomy": {
      "transitions": []
    }
  },
  "version": "1.0"
}