{
  "active": true,
  "desc": "Workflow for processing mail entity from creation to final sending states",
  "initialState": "none",
  "name": "Mail Processing Workflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "create_to_created",
          "next": "CREATED"
        }
      ]
    },
    "CREATED": {
      "transitions": [
        {
          "name": "created_to_processing",
          "next": "PROCESSING",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "MailProcessor"
            }
          ]
        }
      ]
    },
    "PROCESSING": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsHappyCriterion"
            },
            "type": "function"
          },
          "name": "processing_to_sent_happy",
          "next": "SENT_HAPPY"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "IsGloomyCriterion"
            },
            "type": "function"
          },
          "name": "processing_to_sent_gloomy",
          "next": "SENT_GLOOMY"
        },
        {
          "name": "processing_to_failed",
          "next": "FAILED"
        }
      ]
    },
    "SENT_HAPPY": {
      "transitions": []
    },
    "SENT_GLOOMY": {
      "transitions": []
    },
    "FAILED": {
      "transitions": []
    }
  },
  "version": "1.0"
}