{
    "description": "GameScore entity lifecycle workflow",
    "initial_state": "none",
    "states": {
        "new": {
            "transitions": [
                {
                    "mark_as_processed": {
                        "criterion": {
                            "function": {
                                "name": "GameScoreCanMarkProcessedCriterion"
                            },
                            "type": "function"
                        },
                        "next": "processed",
                        "processors": [
                            {
                                "name": "GameScoreProcessor"
                            }
                        ]
                    }
                },
                {
                    "cannot_mark_processed": {
                        "next": "new"
                    }
                }
            ]
        },
        "none": {
            "transitions": [
                {
                    "transition_to_new": {
                        "next": "new"
                    }
                }
            ]
        },
        "processed": {
            "transitions": []
        }
    },
    "version": "1.0",
    "workflow_name": "gamescore_workflow"
}