{
  "active": true,
  "desc": "Workflow for processing email notifications with validation, fetching scores, and sending email",
  "initialState": "none",
  "name": "EmailNotificationWorkflow",
  "states": {
    "none": {
      "transitions": [
        {
          "name": "start_workflow",
          "next": "validating"
        }
      ]
    },
    "validating": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ValidationCriterion"
            },
            "type": "function"
          },
          "name": "validation_success",
          "next": "processing"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "ValidationFailedCriterion"
            },
            "type": "function"
          },
          "name": "validation_failed",
          "next": "failed"
        }
      ]
    },
    "processing": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "FetchScoresSuccessCriterion"
            },
            "type": "function"
          },
          "name": "fetch_scores_success",
          "next": "notification_preparing"
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "FetchScoresFailedCriterion"
            },
            "type": "function"
          },
          "name": "fetch_scores_failed",
          "next": "failed"
        }
      ]
    },
    "notification_preparing": {
      "transitions": [
        {
          "name": "prepare_notification",
          "next": "sending_email"
        }
      ]
    },
    "sending_email": {
      "transitions": [
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "EmailSentCriterion"
            },
            "type": "function"
          },
          "name": "email_sent",
          "next": "completed",
          "processors": [
            {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "executionMode": "SYNC",
              "name": "EmailNotificationProcessor"
            }
          ]
        },
        {
          "criterion": {
            "function": {
              "config": {
                "calculationNodesTags": "cyoda_application"
              },
              "name": "EmailFailedCriterion"
            },
            "type": "function"
          },
          "name": "email_failed",
          "next": "failed"
        }
      ]
    },
    "completed": {
      "transitions": []
    },
    "failed": {
      "transitions": []
    }
  },
  "version": "1.0"
}