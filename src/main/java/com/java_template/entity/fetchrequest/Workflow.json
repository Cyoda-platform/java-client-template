{
    "description": "NBA Scores Fetch & Notify FSM",
    "initial_state": "none",
    "states": {
        "completed": {
            "transitions": {}
        },
        "error": {
            "transitions": {}
        },
        "fetching": {
            "transitions": {
                "fetch_complete": {
                    "next": "notifying"
                },
                "fetch_failed": {
                    "next": "error"
                }
            }
        },
        "none": {
            "transitions": {
                "invalid_fetch_request": {
                    "condition": {
                        "function": {
                            "name": "isValidFetchRequest",
                            "negate": true
                        },
                        "type": "function"
                    },
                    "next": "error"
                },
                "start_fetch": {
                    "action": {
                        "name": "fetchGamesAndNotifySubscribersAsync"
                    },
                    "condition": {
                        "function": {
                            "name": "isValidFetchRequest"
                        },
                        "type": "function"
                    },
                    "next": "fetching"
                }
            }
        },
        "notifying": {
            "transitions": {
                "notify_complete": {
                    "next": "completed"
                },
                "notify_failed": {
                    "next": "error"
                }
            }
        }
    },
    "workflow_name": "nba_scores_workflow"
}