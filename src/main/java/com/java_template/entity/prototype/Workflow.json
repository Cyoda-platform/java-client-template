{
  "description": "FSM for processing Hacker News item with validation, enrichment, and supplementary data fetch",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "invalid_entity": {
          "condition": {
            "function": {
              "name": "not_validateEntity"
            },
            "type": "function"
          },
          "next": "error"
        },
        "validate_entity": {
          "condition": {
            "function": {
              "name": "validateEntity"
            },
            "type": "function"
          },
          "next": "validated"
        }
      }
    },
    "error": {
      "transitions": {}
    },
    "validated": {
      "transitions": {
        "enrich_entity": {
          "action": {
            "name": "enrichEntity"
          },
          "next": "enriched"
        }
      }
    },
    "enriched": {
      "transitions": {
        "fetch_supplementary_data": {
          "action": {
            "name": "fetchSupplementaryData"
          },
          "next": "merged"
        }
      }
    },
    "merged": {
      "transitions": {
        "complete": {
          "next": "complete"
        }
      }
    },
    "complete": {
      "transitions": {}
    }
  },
  "workflow_name": "process_hackernews_item"
}