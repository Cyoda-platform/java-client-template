{
  "description": "FSM workflow for prototype entity processing",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_processing": {
          "action": {
            "name": "enrichEntity"
          },
          "next": "processing"
        }
      }
    },
    "processing": {
      "transitions": {
        "to_error": {
          "condition": {
            "function": {
              "name": "conditionProcessingFailed"
            },
            "type": "function"
          },
          "next": "error"
        },
        "to_processed": {
          "condition": {
            "function": {
              "name": "conditionIsProcessed"
            },
            "type": "function"
          },
          "next": "processed"
        }
      }
    },
    "error": {
      "transitions": {}
    },
    "processed": {
      "transitions": {}
    }
  },
  "workflow_name": "prototype_entity_workflow"
}