{
  "description": "Prototype ingestion task FSM with states, transitions, actions, and concurrency control",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_ingestion": {
          "action": {
            "name": "updateStatus"
          },
          "next": "fetching_ids"
        }
      }
    },
    "fetching_ids": {
      "transitions": {
        "error_fetching_ids": {
          "action": {
            "name": "updateStatus"
          },
          "next": "failed"
        },
        "ids_fetched": {
          "action": {
            "name": "updateStatus"
          },
          "next": "fetching_comments"
        }
      }
    },
    "failed": {
      "transitions": {}
    },
    "fetching_comments": {
      "transitions": {
        "comments_fetched": {
          "action": {
            "name": "updateStatus"
          },
          "next": "completed"
        },
        "error_fetching_comments": {
          "action": {
            "name": "updateStatus"
          },
          "next": "failed"
        }
      }
    },
    "completed": {
      "transitions": {}
    }
  },
  "workflow_name": "prototype_workflow"
}