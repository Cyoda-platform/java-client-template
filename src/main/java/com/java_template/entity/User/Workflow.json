```json
{
  "version": "1.0",
  "description": "FSM workflow to validate, hash password, store, authenticate, and notify user data",
  "initial_state": "none",
  "workflow_name": "user_data_processing_workflow",
  "states": {
    "none": {
      "transitions": {
        "start_validation": {
          "next": "validate"
        }
      }
    },
    "validate": {
      "transitions": {
        "validation_passed": {
          "next": "hash_password",
          "action": {
            "name": "validateUserData"
          }
        },
        "validation_failed": {
          "next": "end_error",
          "action": {
            "name": "handleValidationError"
          }
        }
      }
    },
    "hash_password": {
      "transitions": {
        "hash_complete": {
          "next": "store",
          "action": {
            "name": "hashUserPassword"
          }
        }
      }
    },
    "store": {
      "transitions": {
        "store_data": {
          "next": "authenticate",
          "action": {
            "name": "storeUserData"
          }
        }
      }
    },
    "authenticate": {
      "transitions": {
        "authenticate_user": {
          "next": "notify",
          "action": {
            "name": "authenticateUser"
          }
        }
      }
    },
    "notify": {
      "transitions": {
        "send_notification": {
          "next": "end_success",
          "action": {
            "name": "notifyUser"
          }
        }
      }
    },
    "end_success": {
      "transitions": {}
    },
    "end_error": {
      "transitions": {}
    }
  }
}
