{
  "description": "Weekly Cat Fact Subscription FSM workflow",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_fetch_fact": {
          "next": "fact_fetching"
        }
      }
    },
    "fact_fetching": {
      "transitions": {
        "fact_fetched_invalid": {
          "action": {
            "name": "fetchCatFact"
          },
          "condition": {
            "function": {
              "name": "isFactValid",
              "negate": true
            },
            "type": "function"
          },
          "next": "terminal_error"
        },
        "fact_fetched_valid": {
          "action": {
            "name": "fetchCatFact"
          },
          "condition": {
            "function": {
              "name": "isFactValid"
            },
            "type": "function"
          },
          "next": "subscribers_loading"
        }
      }
    },
    "terminal_error": {
      "transitions": {}
    },
    "subscribers_loading": {
      "transitions": {
        "no_subscribers": {
          "action": {
            "name": "loadSubscribersCount"
          },
          "condition": {
            "function": {
              "name": "hasSubscribers",
              "negate": true
            },
            "type": "function"
          },
          "next": "terminal_no_subscribers"
        },
        "subscribers_present": {
          "action": {
            "name": "loadSubscribersCount"
          },
          "condition": {
            "function": {
              "name": "hasSubscribers"
            },
            "type": "function"
          },
          "next": "sending_emails"
        }
      }
    },
    "terminal_no_subscribers": {
      "transitions": {}
    },
    "sending_emails": {
      "transitions": {
        "emails_sent": {
          "action": {
            "name": "sendEmailsAsync"
          },
          "next": "terminal_success"
        }
      }
    },
    "terminal_success": {
      "transitions": {}
    }
  },
  "workflow_name": "weekly_cat_fact_workflow"
}