{
  "description": "WeatherRequest workflow with alert checking",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_validation": {
          "action": {
            "name": "validateFields"
          },
          "next": "validating"
        }
      }
    },
    "validating": {
      "transitions": {
        "validation_failure": {
          "action": {
            "name": "setFailedStatus"
          },
          "next": "failed"
        },
        "validation_success": {
          "action": {
            "name": "fetchAndSetWeatherData"
          },
          "next": "fetching_data"
        }
      }
    },
    "failed": {
      "transitions": {}
    },
    "fetching_data": {
      "transitions": {
        "fetch_failure": {
          "action": {
            "name": "setFailedStatus"
          },
          "next": "failed"
        },
        "fetch_success": {
          "action": {
            "name": "checkWeatherAlerts"
          },
          "next": "checking_alerts"
        }
      }
    },
    "checking_alerts": {
      "transitions": {
        "alerts_found": {
          "action": {
            "name": "notifyUsers"
          },
          "next": "notifying_users"
        },
        "no_alerts": {
          "next": "completed"
        }
      }
    },
    "notifying_users": {
      "transitions": {
        "notification_complete": {
          "next": "completed"
        }
      }
    },
    "completed": {
      "transitions": {}
    }
  },
  "workflow_name": "WeatherRequestWithAlertsWorkflow"
}