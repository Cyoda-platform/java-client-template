{
    "description": "FSM for processing Data with validation and completion checks",
    "initial_state": "none",
    "states": {
        "complete": {
            "transitions": {}
        },
        "error": {
            "transitions": {}
        },
        "none": {
            "transitions": {
                "invalid_data": {
                    "condition": {
                        "function": {
                            "name": "isDataValid"
                        },
                        "type": "function"
                    },
                    "next": "error"
                },
                "validate_data": {
                    "condition": {
                        "function": {
                            "name": "isDataValid"
                        },
                        "type": "function"
                    },
                    "next": "validate"
                }
            }
        },
        "processing": {
            "transitions": {
                "check_complete": {
                    "condition": {
                        "function": {
                            "name": "isProcessingComplete"
                        },
                        "type": "function"
                    },
                    "next": "complete"
                },
                "processing_incomplete": {
                    "condition": {
                        "function": {
                            "name": "isProcessingComplete"
                        },
                        "type": "function"
                    },
                    "next": "error"
                }
            }
        },
        "validate": {
            "transitions": {
                "process_data": {
                    "action": {
                        "name": "processExample"
                    },
                    "next": "processing"
                }
            }
        }
    },
    "version": "1.0",
    "workflow_name": "data_processing_workflow"
}