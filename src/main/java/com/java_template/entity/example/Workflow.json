{
    "description": "Purrfect Pets API FSM workflow",
    "initial_state": "none",
    "states": {
        "completed": {
            "transitions": {}
        },
        "fetch_external_data": {
            "transitions": {
                "to_prepare_response": {
                    "action": {
                        "name": "fetchExternalPetsAsync"
                    },
                    "next": "prepare_response"
                }
            }
        },
        "none": {
            "transitions": {
                "to_validate_input": {
                    "next": "validate_input"
                }
            }
        },
        "prepare_response": {
            "transitions": {
                "to_completed": {
                    "next": "completed"
                }
            }
        },
        "process_local_data": {
            "transitions": {
                "to_prepare_response": {
                    "action": {
                        "name": "processLocalPet"
                    },
                    "next": "prepare_response"
                }
            }
        },
        "validate_input": {
            "transitions": {
                "to_fetch_external_data": {
                    "condition": {
                        "function": {
                            "name": "shouldFetchExternalData"
                        },
                        "type": "function"
                    },
                    "next": "fetch_external_data"
                },
                "to_process_local_data": {
                    "condition": {
                        "function": {
                            "name": "shouldProcessLocalData"
                        },
                        "type": "function"
                    },
                    "next": "process_local_data"
                }
            }
        }
    },
    "version": "1.0",
    "workflow_name": "purrfect_pets_workflow"
}