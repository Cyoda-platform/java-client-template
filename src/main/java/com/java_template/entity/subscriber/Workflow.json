{
  "description": "NBA Scores Fetch and Notify Workflow",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "invalid_fetch_request": {
          "condition": {
            "function": {
              "name": "isInvalidFetchRequest"
            },
            "type": "function"
          },
          "next": "error"
        },
        "to_fetching": {
          "action": {
            "name": "fetchGamesAndNotifySubscribersAsync"
          },
          "condition": {
            "function": {
              "name": "isValidFetchRequest"
            },
            "type": "function"
          },
          "next": "fetching"
        }
      }
    },
    "error": {
      "transitions": {}
    },
    "fetching": {
      "transitions": {
        "to_notifying": {
          "condition": {
            "function": {
              "name": "alwaysTrue"
            },
            "type": "function"
          },
          "next": "notifying"
        }
      }
    },
    "notifying": {
      "transitions": {
        "to_completed": {
          "condition": {
            "function": {
              "name": "alwaysTrue"
            },
            "type": "function"
          },
          "next": "completed"
        }
      }
    },
    "completed": {
      "transitions": {}
    }
  },
  "workflow_name": "nba_scores_workflow"
}