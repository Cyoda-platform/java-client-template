{
  "description": "NBA Scores Notification System FSM Workflow",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "invalid_subscribe_transition": {
          "condition": {
            "function": {
              "name": "isEmailInvalid"
            },
            "type": "function"
          },
          "next": "error_invalid_email"
        },
        "subscribe_transition": {
          "action": {
            "name": "processSubscriber"
          },
          "condition": {
            "function": {
              "name": "isEmailValid"
            },
            "type": "function"
          },
          "next": "subscribed"
        }
      }
    },
    "error_invalid_email": {
      "transitions": {}
    },
    "subscribed": {
      "transitions": {
        "fetch_scores_transition": {
          "action": {
            "name": "fetchAndStoreScores"
          },
          "condition": {
            "function": {
              "name": "hasScoresToFetch"
            },
            "type": "function"
          },
          "next": "scores_fetched"
        },
        "unsubscribe_transition": {
          "action": {
            "name": "processUnsubscribe"
          },
          "condition": {
            "function": {
              "name": "wantsToUnsubscribe"
            },
            "type": "function"
          },
          "next": "unsubscribed"
        }
      }
    },
    "scores_fetched": {
      "transitions": {
        "no_subscribers_transition": {
          "condition": {
            "function": {
              "name": "noSubscribers"
            },
            "type": "function"
          },
          "next": "subscribed"
        },
        "notify_subscribers_transition": {
          "action": {
            "name": "sendDailyNotifications"
          },
          "condition": {
            "function": {
              "name": "hasSubscribers"
            },
            "type": "function"
          },
          "next": "notified"
        }
      }
    },
    "notified": {
      "transitions": {
        "reset_transition": {
          "condition": {
            "function": {
              "name": "dailyScheduleTrigger"
            },
            "type": "function"
          },
          "next": "subscribed"
        }
      }
    },
    "unsubscribed": {
      "transitions": {}
    }
  },
  "workflow_name": "nba_scores_workflow"
}