{
    "description": "NBA game score processing FSM",
    "initial_state": "none",
    "states": {
        "complete": {
            "transitions": {}
        },
        "none": {
            "transitions": {
                "start_processing": {
                    "action": {
                        "name": "normalizeScores"
                    },
                    "next": "normalize_scores"
                }
            }
        },
        "normalize_scores": {
            "transitions": {
                "complete": {
                    "action": {
                        "name": "processGame"
                    },
                    "next": "complete"
                }
            }
        }
    },
    "version": "1.0",
    "workflow_name": "game_workflow"
}