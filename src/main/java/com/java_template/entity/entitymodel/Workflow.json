{
  "description": "FSM for entity processing workflow with async enrichment and validation",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_processing": {
          "next": "processing"
        }
      }
    },
    "processing": {
      "transitions": {
        "process_failed": {
          "condition": {
            "function": {
              "name": "processFailed"
            },
            "type": "function"
          },
          "next": "error"
        },
        "process_with_valid_related_id": {
          "action": {
            "name": "processEntity"
          },
          "condition": {
            "function": {
              "name": "hasValidRelatedId"
            },
            "type": "function"
          },
          "next": "persisted"
        },
        "process_without_valid_related_id": {
          "action": {
            "name": "processEntity"
          },
          "condition": {
            "function": {
              "name": "notHasValidRelatedId"
            },
            "type": "function"
          },
          "next": "persisted"
        }
      }
    },
    "error": {
      "transitions": {}
    },
    "persisted": {
      "transitions": {
        "read_entity": {
          "next": "persisted"
        }
      }
    }
  },
  "workflow_name": "entity_processing_workflow"
}