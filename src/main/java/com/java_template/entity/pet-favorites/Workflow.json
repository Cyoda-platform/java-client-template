{
  "description": "Workflow for processing pet favorites with validation and processing steps",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "validate_required_fields": {
          "condition": {
            "function": {
              "name": "hasRequiredFields"
            },
            "type": "function"
          },
          "next": "validated"
        },
        "validation_failed": {
          "condition": {
            "function": {
              "name": "negateHasRequiredFields"
            },
            "type": "function"
          },
          "next": "error"
        }
      }
    },
    "validated": {
      "transitions": {
        "process_favorites": {
          "action": {
            "name": "processpet_favorites"
          },
          "next": "processed"
        }
      }
    },
    "processed": {
      "transitions": {
        "persist_entity": {
          "action": {
            "name": "persistFavorite"
          },
          "next": "persisted"
        }
      }
    },
    "persisted": {
      "transitions": {
        "complete_workflow": {
          "next": "completed"
        }
      }
    },
    "completed": {
      "transitions": {}
    },
    "error": {
      "transitions": {}
    }
  },
  "workflow_name": "processpet_favorites_workflow"
}