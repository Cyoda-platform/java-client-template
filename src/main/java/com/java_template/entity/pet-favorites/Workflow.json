{
    "description": "Workflow for processing pet favorites with validation and processing steps",
    "initial_state": "none",
    "states": {
        "completed": {
            "transitions": {}
        },
        "error": {
            "transitions": {}
        },
        "none": {
            "transitions": {
                "validate_required_fields": {
                    "condition": {
                        "function": {
                            "name": "hasRequiredFields"
                        },
                        "type": "function"
                    },
                    "next": "validated"
                },
                "validation_failed": {
                    "condition": {
                        "function": {
                            "name": "negateHasRequiredFields"
                        },
                        "type": "function"
                    },
                    "next": "error"
                }
            }
        },
        "persisted": {
            "transitions": {
                "complete_workflow": {
                    "next": "completed"
                }
            }
        },
        "processed": {
            "transitions": {
                "persist_entity": {
                    "action": {
                        "name": "persistFavorite"
                    },
                    "next": "persisted"
                }
            }
        },
        "validated": {
            "transitions": {
                "process_favorites": {
                    "action": {
                        "name": "processpet_favorites"
                    },
                    "next": "processed"
                }
            }
        }
    },
    "workflow_name": "processpet_favorites_workflow"
}