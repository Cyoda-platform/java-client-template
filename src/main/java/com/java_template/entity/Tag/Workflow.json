{
  "description": "FSM for Validate, Store, and Cache Tag data",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_validation": {
          "next": "validate"
        }
      }
    },
    "validate": {
      "transitions": {
        "validation_failed": {
          "action": {
            "name": "handleValidationFailure"
          },
          "condition": {
            "function": {
              "name": "isValidationFailed"
            },
            "type": "function"
          },
          "next": "end"
        },
        "validation_passed": {
          "action": {
            "name": "validateTagData"
          },
          "condition": {
            "function": {
              "name": "isValidationSuccessful"
            },
            "type": "function"
          },
          "next": "store"
        }
      }
    },
    "end": {
      "transitions": {}
    },
    "store": {
      "transitions": {
        "store_failure": {
          "action": {
            "name": "handleStoreFailure"
          },
          "condition": {
            "function": {
              "name": "isStoreFailed"
            },
            "type": "function"
          },
          "next": "end"
        },
        "store_success": {
          "action": {
            "name": "storeTagData"
          },
          "condition": {
            "function": {
              "name": "isStoreSuccessful"
            },
            "type": "function"
          },
          "next": "cache"
        }
      }
    },
    "cache": {
      "transitions": {
        "cache_failure": {
          "action": {
            "name": "handleCacheFailure"
          },
          "condition": {
            "function": {
              "name": "isCacheFailed"
            },
            "type": "function"
          },
          "next": "end"
        },
        "cache_success": {
          "action": {
            "name": "cacheTagData"
          },
          "condition": {
            "function": {
              "name": "isCacheSuccessful"
            },
            "type": "function"
          },
          "next": "end"
        }
      }
    }
  },
  "workflow_name": "tag_data_processing_workflow"
}