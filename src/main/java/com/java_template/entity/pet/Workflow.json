{
  "description": "Pet entity workflow FSM",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_validation": {
          "action": {
            "name": "processValidate"
          },
          "next": "validate"
        }
      }
    },
    "validate": {
      "transitions": {
        "validation_success": {
          "action": {
            "name": "processEnrich"
          },
          "next": "enrich"
        }
      }
    },
    "enrich": {
      "transitions": {
        "enrichment_done": {
          "action": {
            "name": "processAsyncOps"
          },
          "next": "asyncOps"
        }
      }
    },
    "asyncOps": {
      "transitions": {
        "complete": {
          "next": "completed"
        }
      }
    },
    "completed": {
      "transitions": {}
    }
  },
  "workflow_name": "pet_workflow"
}