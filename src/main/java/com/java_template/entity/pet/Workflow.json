{
    "description": "Pet entity workflow FSM",
    "initial_state": "none",
    "states": {
        "asyncOps": {
            "transitions": {
                "complete": {
                    "next": "completed"
                }
            }
        },
        "completed": {
            "transitions": {}
        },
        "enrich": {
            "transitions": {
                "enrichment_done": {
                    "action": {
                        "name": "processAsyncOps"
                    },
                    "next": "asyncOps"
                }
            }
        },
        "none": {
            "transitions": {
                "start_validation": {
                    "action": {
                        "name": "processValidate"
                    },
                    "next": "validate"
                }
            }
        },
        "validate": {
            "transitions": {
                "validation_success": {
                    "action": {
                        "name": "processEnrich"
                    },
                    "next": "enrich"
                }
            }
        }
    },
    "workflow_name": "pet_workflow"
}