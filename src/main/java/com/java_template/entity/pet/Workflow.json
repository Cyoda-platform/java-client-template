{
  "description": "Purrfect Pets processing workflow",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "init_pet": {
          "action": {
            "name": "initializePet"
          },
          "next": "initialized"
        }
      }
    },
    "initialized": {
      "transitions": {
        "check_pet_type_exists": {
          "condition": {
            "function": {
              "name": "hasPetType"
            },
            "type": "function"
          },
          "next": "enrich_category"
        },
        "skip_category_enrich": {
          "condition": {
            "function": {
              "name": "hasNotPetType"
            },
            "type": "function"
          },
          "next": "completed"
        }
      }
    },
    "enrich_category": {
      "transitions": {
        "enrich_and_complete": {
          "action": {
            "name": "enrichPetWithCategory"
          },
          "next": "completed"
        }
      }
    },
    "completed": {
      "transitions": {}
    }
  },
  "workflow_name": "processPet_workflow"
}