```json
{
  "version": "1.0",
  "description": "FSM workflow to validate, enrich, store, notify, and cache pet data",
  "initial_state": "none",
  "workflow_name": "pet_data_processing_workflow",
  "states": {
    "none": {
      "transitions": {
        "start_validation": {
          "next": "validate"
        }
      }
    },
    "validate": {
      "transitions": {
        "validation_passed": {
          "next": "enrich",
          "action": {
            "name": "validatePetData"
          }
        },
        "validation_failed": {
          "next": "end_error",
          "action": {
            "name": "handleValidationError"
          }
        }
      }
    },
    "enrich": {
      "transitions": {
        "enrich_data": {
          "next": "store",
          "action": {
            "name": "enrichPetData"
          }
        }
      }
    },
    "store": {
      "transitions": {
        "store_data": {
          "next": "notify",
          "action": {
            "name": "storePetData"
          }
        }
      }
    },
    "notify": {
      "transitions": {
        "send_notification": {
          "next": "cache",
          "action": {
            "name": "notifyUsers"
          }
        }
      }
    },
    "cache": {
      "transitions": {
        "update_cache": {
          "next": "end_success",
          "action": {
            "name": "updatePetCache"
          }
        }
      }
    },
    "end_success": {
      "transitions": {}
    },
    "end_error": {
      "transitions": {}
    }
  }
}
