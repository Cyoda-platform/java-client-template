{
    "description": "Pet entity workflow FSM",
    "initial_state": "none",
    "states": {
        "async_side_effects": {
            "transitions": {
                "finish": {
                    "next": "completed"
                }
            }
        },
        "completed": {
            "transitions": {}
        },
        "none": {
            "transitions": {
                "start_processing": {
                    "action": {
                        "name": "normalizeStatus"
                    },
                    "next": "normalizing_status"
                }
            }
        },
        "normalizing_status": {
            "transitions": {
                "continue_processing": {
                    "action": {
                        "name": "additionalAsyncSideEffects"
                    },
                    "next": "async_side_effects"
                }
            }
        }
    },
    "version": "1.0",
    "workflow_name": "pet_workflow"
}