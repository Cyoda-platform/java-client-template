{
  "description": "Purrfect Pets entity workflow FSM",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "to_normalize_status": {
          "next": "normalize_status"
        }
      }
    },
    "normalize_status": {
      "transitions": {
        "to_check_sync_flag": {
          "action": {
            "name": "normalizeStatus"
          },
          "next": "check_sync_from_petstore"
        }
      }
    },
    "check_sync_from_petstore": {
      "transitions": {
        "sync_false": {
          "next": "finalize"
        },
        "sync_true": {
          "condition": {
            "function": {
              "name": "shouldSyncFromPetstore"
            },
            "type": "function"
          },
          "next": "process_pet_sync"
        }
      }
    },
    "finalize": {
      "transitions": {}
    },
    "process_pet_sync": {
      "transitions": {
        "to_finalize": {
          "action": {
            "name": "processPetSync"
          },
          "next": "finalize"
        }
      }
    }
  },
  "workflow_name": "purrfect_pets_workflow"
}