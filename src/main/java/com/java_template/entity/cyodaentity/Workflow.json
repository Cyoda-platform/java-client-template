{
  "description": "NBA Score Fetch and Subscriber Notification Workflow",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_score_fetch_processing": {
          "condition": {
            "function": {
              "name": "isScoreFetchEvent"
            },
            "type": "function"
          },
          "next": "fetch_scores"
        },
        "start_subscription_processing": {
          "condition": {
            "function": {
              "name": "isSubscriptionEvent"
            },
            "type": "function"
          },
          "next": "process_subscriber"
        }
      }
    },
    "fetch_scores": {
      "transitions": {
        "fetch_external_scores": {
          "action": {
            "name": "fetchNbaScores"
          },
          "next": "validate_scores"
        }
      }
    },
    "validate_scores": {
      "transitions": {
        "scores_invalid": {
          "next": "end_fetch_error"
        },
        "scores_valid": {
          "condition": {
            "function": {
              "name": "isFetchedDataValid"
            },
            "type": "function"
          },
          "next": "persist_scores"
        }
      }
    },
    "end_fetch_error": {
      "transitions": {}
    },
    "persist_scores": {
      "transitions": {
        "check_subscribers": {
          "next": "check_subscriber_count"
        }
      }
    },
    "check_subscriber_count": {
      "transitions": {
        "has_subscribers": {
          "condition": {
            "function": {
              "name": "hasSubscribers"
            },
            "type": "function"
          },
          "next": "send_notifications"
        },
        "no_subscribers": {
          "next": "end_fetch_success"
        }
      }
    },
    "send_notifications": {
      "transitions": {
        "notifications_sent": {
          "action": {
            "name": "sendNotifications"
          },
          "next": "end_fetch_success"
        }
      }
    },
    "end_fetch_success": {
      "transitions": {}
    },
    "process_subscriber": {
      "transitions": {
        "normalize_email": {
          "action": {
            "name": "processSubscriber"
          },
          "next": "validate_email"
        }
      }
    },
    "validate_email": {
      "transitions": {
        "email_invalid": {
          "next": "end_invalid_subscription"
        },
        "email_valid": {
          "condition": {
            "function": {
              "name": "isValidEmail"
            },
            "type": "function"
          },
          "next": "persist_subscriber"
        }
      }
    },
    "end_invalid_subscription": {
      "transitions": {}
    },
    "persist_subscriber": {
      "transitions": {
        "complete_subscription": {
          "next": "end_subscription_success"
        }
      }
    },
    "end_subscription_success": {
      "transitions": {}
    }
  },
  "workflow_name": "nba_score_notification_workflow"
}