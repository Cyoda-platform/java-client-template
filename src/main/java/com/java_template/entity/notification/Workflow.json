{
  "description": "NotificationWorkflow FSM for processing notifications",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "start_prepare_message": {
          "action": {
            "name": "prepareMessage"
          },
          "next": "prepare_message"
        }
      }
    },
    "prepare_message": {
      "transitions": {
        "to_validate_recipient": {
          "action": {
            "name": "validateRecipient"
          },
          "next": "validate_recipient"
        }
      }
    },
    "validate_recipient": {
      "transitions": {
        "recipient_empty": {
          "action": {
            "name": "validateRecipient"
          },
          "condition": {
            "function": {
              "name": "isRecipientEmpty"
            },
            "type": "function"
          },
          "next": "end_failed"
        },
        "recipient_not_empty": {
          "action": {
            "name": "validateRecipient"
          },
          "condition": {
            "function": {
              "name": "isRecipientNotEmpty"
            },
            "type": "function"
          },
          "next": "send_notification"
        }
      }
    },
    "end_failed": {
      "transitions": {}
    },
    "send_notification": {
      "transitions": {
        "send": {
          "action": {
            "name": "sendNotification"
          },
          "next": "end_sent"
        }
      }
    },
    "end_sent": {
      "transitions": {}
    }
  },
  "workflow_name": "notification_workflow"
}