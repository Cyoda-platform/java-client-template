{
  "description": "CyodaPrototype NBA Scores Notification Workflow FSM",
  "initial_state": "none",
  "states": {
    "none": {
      "transitions": {
        "fetch_scores": {
          "action": {
            "name": "processFetchScores"
          },
          "next": "scores_fetched"
        }
      }
    },
    "scores_fetched": {
      "transitions": {
        "send_notifications": {
          "action": {
            "name": "processSendNotifications"
          },
          "next": "notifications_sent"
        }
      }
    },
    "notifications_sent": {
      "transitions": {
        "complete": {
          "next": "end"
        }
      }
    },
    "end": {
      "transitions": {}
    }
  },
  "workflow_name": "CyodaPrototypeWorkflow"
}