{
    "description": "CyodaPrototype NBA Scores Notification Workflow FSM",
    "initial_state": "none",
    "states": {
        "end": {
            "transitions": {}
        },
        "none": {
            "transitions": {
                "fetch_scores": {
                    "action": {
                        "name": "processFetchScores"
                    },
                    "next": "scores_fetched"
                }
            }
        },
        "notifications_sent": {
            "transitions": {
                "complete": {
                    "next": "end"
                }
            }
        },
        "scores_fetched": {
            "transitions": {
                "send_notifications": {
                    "action": {
                        "name": "processSendNotifications"
                    },
                    "next": "notifications_sent"
                }
            }
        }
    },
    "version": "1.0",
    "workflow_name": "CyodaPrototypeWorkflow"
}