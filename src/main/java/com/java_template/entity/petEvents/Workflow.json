            "start_state": "Status_normalized",
            "start_state_description": "Status field normalized"
        },
        {
            "automated": true,
            "description": "Enrich pet entity with category details and create pet event",
            "end_state": "Category_enriched",
            "end_state_description": "Category details enriched and pet event created",
            "name": "enrich_category",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
