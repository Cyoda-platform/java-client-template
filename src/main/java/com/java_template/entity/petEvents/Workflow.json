                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "None",
            "start_state_description": "Initial state"
        },
        {
            "automated": true,
            "description": "Add processing timestamp to the entity",
            "end_state": "Timestamp_added",
            "end_state_description": "Timestamp added to entity",
            "name": "add_timestamp",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
