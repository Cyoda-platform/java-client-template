{
    "description": "NBA Score Fetch Request Workflow FSM",
    "initial_state": "none",
    "states": {
        "addNewGames": {
            "transitions": {
                "new_games_added": {
                    "action": {
                        "name": "notifySubscribers"
                    },
                    "next": "notifySubscribers"
                }
            }
        },
        "deleteOldGames": {
            "transitions": {
                "old_games_deleted": {
                    "action": {
                        "name": "addNewGames"
                    },
                    "next": "addNewGames"
                }
            }
        },
        "done": {
            "transitions": {}
        },
        "fetchExternalScores": {
            "transitions": {
                "scores_fetched": {
                    "action": {
                        "name": "deleteOldGames"
                    },
                    "next": "deleteOldGames"
                }
            }
        },
        "none": {
            "transitions": {
                "fetch_scores": {
                    "action": {
                        "name": "fetchExternalScores"
                    },
                    "next": "fetchExternalScores"
                }
            }
        },
        "notifySubscribers": {
            "transitions": {
                "notifications_sent": {
                    "action": {
                        "name": "completeWorkflow"
                    },
                    "next": "done"
                }
            }
        }
    },
    "version": "1.0",
    "workflow_name": "scoreFetchRequest_workflow"
}