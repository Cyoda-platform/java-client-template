{
    "description": "Workflow to process cover photos by updating title, creating notification, and initializing view count",
    "name": "cover_photo_workflow",
    "transitions": [
        {
            "automated": true,
            "description": "Append [Processed] to photo title if missing",
            "end_state": "TitleUpdated",
            "end_state_description": "Photo title updated",
            "name": "update_title",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "processUpdateTitle"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "None",
            "start_state_description": "Initial state"
        },
        {
            "automated": true,
            "description": "Create notification about new cover photo",
            "end_state": "NotificationCreated",
            "end_state_description": "Notification created",
            "name": "create_notification",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "processCreateNotification"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "TitleUpdated",
            "start_state_description": "Photo title updated"
        },
        {
            "automated": true,
            "description": "Initialize photo view count",
            "end_state": "ViewCountInitialized",
            "end_state_description": "Photo view count initialized",
            "name": "initialize_view_count",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "processInitViewCount"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "NotificationCreated",
            "start_state_description": "Notification created"
        }
    ]
}