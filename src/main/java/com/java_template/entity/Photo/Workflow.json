{
    "description": "Workflow to process cover photos by updating title, creating notification, and initializing view count",
    "name": "cover_photo_processing_workflow",
    "transitions": [
        {
            "automated": true,
            "description": "Append [Processed] to photo title if missing",
            "end_state": "Title_updated",
            "end_state_description": "Photo title updated",
            "name": "update_photo_title",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "processUpdateTitle"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "None",
            "start_state_description": "Initial state"
        },
        {
            "automated": true,
            "description": "Create notification of new cover photo",
            "end_state": "Notification_created",
            "end_state_description": "Notification created for cover photo",
            "name": "create_notification",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "processCreateNotification"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "Title_updated",
            "start_state_description": "Photo title updated"
        },
        {
            "automated": true,
            "description": "Initialize view count for the cover photo",
            "end_state": "View_count_initialized",
            "end_state_description": "View count initialized",
            "name": "initialize_view_count",
            "processes": {
                "externalized_processors": [
                    {
                        "description": "",
                        "name": "processInitViewCount"
                    }
                ],
                "schedule_transition_processors": []
            },
            "start_state": "Notification_created",
            "start_state_description": "Notification created for cover photo"
        }
    ]
}